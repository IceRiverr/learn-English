  "segments": [
    {
      "id": "s001",
      "start": 0.27,
      "end": 1.55,
      "text": "Lesson 9.",
      "translations": {
        "zh-Hans": "第9课。"
      }
    },
    {
      "id": "s002",
      "start": 2.53,
      "end": 4.33,
      "text": "How Are You Today?",
      "translations": {
        "zh-Hans": "你今天好吗？"
      }
    },
    {
      "id": "s003",
      "start": 5.79,
      "end": 10.21,
      "text": "Listen to the tape, then answer this question.",
      "translations": {
        "zh-Hans": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "start": 11.55,
      "end": 13.07,
      "text": "How is Emma?",
      "translations": {
        "zh-Hans": "埃玛怎么样？"
      }
    },
    {
      "id": "s005",
      "start": 15.26,
      "end": 16.3,
      "text": "Hello, Helen.",
      "translations": {
        "zh-Hans": "你好，海伦。"
      }
    },
    {
      "id": "s006",
      "start": 17.14,
      "end": 18.02,
      "text": "Hi, Stephen.",
      "translations": {
        "zh-Hans": "你好，史蒂文。"
      }
    },
    {
      "id": "s007",
      "start": 19.1,
      "end": 20.76,
      "text": "How are you today?",
      "translations": {
        "zh-Hans": "你今天好吗？"
      }
    },
    {
      "id": "s008",
      "start": 21.54,
      "end": 23.84,
      "text": "I'm very well, thank you.",
      "translations": {
        "zh-Hans": "我很好，谢谢你。"
      }
    },
    {
      "id": "s009",
      "start": 24.32,
      "end": 24.9,
      "text": "And you?",
      "translations": {
        "zh-Hans": "你呢？"
      }
    },
    {
      "id": "s010",
      "start": 25.64,
      "end": 27.3,
      "text": "I'm fine, thanks.",
      "translations": {
        "zh-Hans": "我很好，谢谢。"
      }
    },
    {
      "id": "s011",
      "start": 28.78,
      "end": 29.9,
      "text": "How is Tony?",
      "translations": {
        "zh-Hans": "托尼怎么样？"
      }
    },
    {
      "id": "s012",
      "start": 29.9,
      "end": 32.56,
      "text": "He's fine, thanks.",
      "translations": {
        "zh-Hans": "他很好，谢谢。"
      }
    },
    {
      "id": "s013",
      "start": 33.48,
      "end": 34.12,
      "text": "How's Emma?",
      "translations": {
        "zh-Hans": "埃玛怎么样？"
      }
    },
    {
      "id": "s014",
      "start": 35,
      "end": 37.46,
      "text": "She's very well, too, Helen.",
      "translations": {
        "zh-Hans": "她也很好，海伦。"
      }
    },
    {
      "id": "s015",
      "start": 39.28,
      "end": 40.12,
      "text": "Goodbye, Helen.",
      "translations": {
        "zh-Hans": "再见，海伦。"
      }
    },
    {
      "id": "s016",
      "start": 40.8,
      "end": 41.94,
      "text": "Nice to see you.",
      "translations": {
        "zh-Hans": "很高兴见到你。"
      }
    },
    {
      "id": "s017",
      "start": 42.72,
      "end": 45.4,
      "text": "Nice to see you, too, Stephen.",
      "translations": {
        "zh-Hans": "我也很高兴见到你，史蒂文。"
      }
    },
    {
      "id": "s018",
      "start": 46.24,
      "end": 46.6,
      "text": "Goodbye.",
      "translations": {
        "zh-Hans": "再见。"
      }
    }
  ]
}
