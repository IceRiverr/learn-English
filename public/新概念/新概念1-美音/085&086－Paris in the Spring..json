  "segments": [
    {
      "id": "s001",
      "start": 0.24,
      "end": 4.9,
      "text": "Lesson 85—Paris in the Spring.",
      "translations": {
        "zh-Hans": "第85课——巴黎之春。"
      }
    },
    {
      "id": "s002",
      "start": 6.58,
      "end": 10.16,
      "text": "Listen to the tape, then answer this question.",
      "translations": {
        "zh-Hans": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s003",
      "start": 11.82,
      "end": 15.92,
      "text": "At what time of year did Ken visit Paris?",
      "translations": {
        "zh-Hans": "肯是在一年中的什么时候游览巴黎的？"
      }
    },
    {
      "id": "s004",
      "start": 18.67,
      "end": 19.47,
      "text": "Hello, Ken.",
      "translations": {
        "zh-Hans": "你好，肯。"
      }
    },
    {
      "id": "s005",
      "start": 20.25,
      "end": 21.15,
      "text": "Hi, George.",
      "translations": {
        "zh-Hans": "你好，乔治。"
      }
    },
    {
      "id": "s006",
      "start": 22.29,
      "end": 24.47,
      "text": "Have you just been to the cinema?",
      "translations": {
        "zh-Hans": "你刚去过电影院吗？"
      }
    },
    {
      "id": "s007",
      "start": 25.21,
      "end": 26.61,
      "text": "Yes, I have.",
      "translations": {
        "zh-Hans": "是的，刚去过。"
      }
    },
    {
      "id": "s008",
      "start": 27.55,
      "end": 28.31,
      "text": "What's on?",
      "translations": {
        "zh-Hans": "放映什么片子？"
      }
    },
    {
      "id": "s009",
      "start": 29.05,
      "end": 30.91,
      "text": "Paris in the Spring.",
      "translations": {
        "zh-Hans": "《巴黎之春》。"
      }
    },
    {
      "id": "s010",
      "start": 31.63,
      "end": 34.17,
      "text": "Oh, I've already seen it.",
      "translations": {
        "zh-Hans": "哦，我已经看过了。"
      }
    },
    {
      "id": "s011",
      "start": 34.79,
      "end": 37.93,
      "text": "I saw it on television last year.",
      "translations": {
        "zh-Hans": "我去年在电视上看的。"
      }
    },
    {
      "id": "s012",
      "start": 38.83,
      "end": 42.43,
      "text": "It's an old film, but it's very good.",
      "translations": {
        "zh-Hans": "这是一部老电影，但很好看。"
      }
    },
    {
      "id": "s013",
      "start": 43.63,
      "end": 45.87,
      "text": "Paris is a beautiful city.",
      "translations": {
        "zh-Hans": "巴黎是一座美丽的城市。"
      }
    },
    {
      "id": "s014",
      "start": 46.75,
      "end": 48.37,
      "text": "I've never been there.",
      "translations": {
        "zh-Hans": "我从未去过那里。"
      }
    },
    {
      "id": "s015",
      "start": 49.03,
      "end": 53.39,
      "text": "Have you ever been there? Yes, I have.",
      "translations": {
        "zh-Hans": "你去过那里吗？是的，去过。"
      }
    },
    {
      "id": "s016",
      "start": 53.89,
      "end": 55.77,
      "text": "I was there in April.",
      "translations": {
        "zh-Hans": "我是四月份去的。"
      }
    },
    {
      "id": "s017",
      "start": 57.33,
      "end": 59.61,
      "text": "Paris in the Spring, eh?",
      "translations": {
        "zh-Hans": "巴黎之春，是吗？"
      }
    },
    {
      "id": "s018",
      "start": 60.19,
      "end": 64.15,
      "text": "It was spring, but the weather was awful.",
      "translations": {
        "zh-Hans": "当时是春天，但天气糟透了。"
      }
    },
    {
      "id": "s019",
      "start": 64.83,
      "end": 66.89,
      "text": "It rained all the time.",
      "translations": {
        "zh-Hans": "一直在下雨。"
      }
    },
    {
      "id": "s020",
      "start": 67.91,
      "end": 69.63,
      "text": "Just like London.",
      "translations": {
        "zh-Hans": "就像伦敦一样。"
      }
    }
  ]
}
