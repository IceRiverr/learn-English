      }
    },
    {
      "id": "s002",
      "start": 5.12,
      "end": 8.94,
      "text": "Listen to the tape, then answer this question.",
      "translations": {
        "zh-Hans": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s003",
      "start": 10.02,
      "end": 11.84,
      "text": "Is Chang-woo Chinese?",
      "translations": {
        "zh-Hans": "昌宇是中国人吗？"
      }
    },
    {
      "id": "s004",
      "start": 14.04,
      "end": 14.94,
      "text": "Good morning.",
      "translations": {
        "zh-Hans": "早上好。"
      }
    },
    {
      "id": "s005",
      "start": 16.04,
      "end": 17.72,
      "text": "Good morning, Mr.",
      "translations": {
        "zh-Hans": "早上好，"
      }
    },
    {
      "id": "s006",
      "start": 18.14,
      "end": 18.2,
      "text": "Blake.",
      "translations": {
        "zh-Hans": "布莱克先生。"
      }
    },
    {
      "id": "s007",
      "start": 19.62,
      "end": 22.56,
      "text": "This is Miss Sophie DuPont.",
      "translations": {
        "zh-Hans": "这位是索菲·杜邦小姐。"
      }
    },
    {
      "id": "s008",
      "start": 23.86,
      "end": 25.8,
      "text": "Sophie is a new student.",
      "translations": {
        "zh-Hans": "索菲是一名新学生。"
      }
    },
    {
      "id": "s009",
      "start": 26.96,
      "end": 27.86,
      "text": "She is French.",
      "translations": {
        "zh-Hans": "她是法国人。"
      }
    },
    {
      "id": "s010",
      "start": 28.74,
      "end": 31.72,
      "text": "Sophie, this is Hans.",
      "translations": {
        "zh-Hans": "索菲，这位是汉斯。"
      }
    },
    {
      "id": "s011",
      "start": 32.5,
      "end": 33.72,
      "text": "He is German.",
      "translations": {
        "zh-Hans": "他是德国人。"
      }
    },
    {
      "id": "s012",
      "start": 34.6,
      "end": 36.26,
      "text": "Nice to meet you.",
