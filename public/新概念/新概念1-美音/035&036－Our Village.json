  "segments": [
    {
      "id": "s001",
      "start": 0.37,
      "end": 2.07,
      "text": "Lesson 35.",
      "translations": {
        "zh-Hans": "第35课。"
      }
    },
    {
      "id": "s002",
      "start": 3.17,
      "end": 4.23,
      "text": "Our Village.",
      "translations": {
        "zh-Hans": "我们的村庄。"
      }
    },
    {
      "id": "s003",
      "start": 6.31,
      "end": 10.15,
      "text": "Listen to the tape, then answer this question.",
      "translations": {
        "zh-Hans": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "start": 11.81,
      "end": 16.99,
      "text": "Are the children coming out of the park or going into it?",
      "translations": {
        "zh-Hans": "孩子们是在走出公园，还是走进公园？"
      }
    },
    {
      "id": "s005",
      "start": 18.81,
      "end": 22.39,
      "text": "This is a photograph of our village.",
      "translations": {
        "zh-Hans": "这是我们村庄的一张照片。"
      }
    },
    {
      "id": "s006",
      "start": 23.55,
      "end": 25.91,
      "text": "Our village is in a valley.",
      "translations": {
        "zh-Hans": "我们的村庄坐落在一个山谷中。"
      }
    },
    {
      "id": "s007",
      "start": 26.85,
      "end": 29.19,
      "text": "It is between two hills.",
      "translations": {
        "zh-Hans": "它位于两座小山之间。"
      }
    },
    {
      "id": "s008",
      "start": 29.19,
      "end": 32.55,
      "text": "The village is on a river.",
      "translations": {
        "zh-Hans": "村庄坐落在一条河边。"
      }
    },
    {
      "id": "s009",
      "start": 34.75,
      "end": 38.59,
      "text": "Here is another photograph of the village.",
      "translations": {
        "zh-Hans": "这是村庄的另一张照片。"
      }
    },
    {
      "id": "s010",
      "start": 39.65,
      "end": 45.19,
      "text": "My wife and I are walking along the banks of the river.",
      "translations": {
        "zh-Hans": "我和妻子正沿着河岸散步。"
      }
    },
    {
      "id": "s011",
      "start": 46.25,
      "end": 48.27,
      "text": "We are on the left.",
      "translations": {
        "zh-Hans": "我们在左边。"
      }
    },
    {
      "id": "s012",
      "start": 49.51,
      "end": 51.91,
      "text": "There is a boy in the water.",
      "translations": {
        "zh-Hans": "水里有个男孩。"
      }
    },
    {
      "id": "s013",
      "start": 52.89,
      "end": 55.73,
      "text": "He is swimming across the river.",
      "translations": {
        "zh-Hans": "他正游过这条河。"
      }
    },
    {
      "id": "s014",
      "start": 58.21,
      "end": 60.39,
      "text": "Here is another photograph.",
      "translations": {
        "zh-Hans": "这是另一张照片。"
      }
    },
    {
      "id": "s015",
      "start": 61.39,
      "end": 63.75,
      "text": "This is the school building.",
      "translations": {
        "zh-Hans": "这是学校大楼。"
      }
    },
    {
      "id": "s016",
      "start": 64.65,
      "end": 66.91,
      "text": "It is beside a park.",
      "translations": {
        "zh-Hans": "它在一座公园旁边。"
      }
    },
    {
      "id": "s017",
      "start": 68.03,
      "end": 70.33,
      "text": "The park is on the right.",
      "translations": {
        "zh-Hans": "公园在右边。"
      }
    },
    {
      "id": "s018",
      "start": 71.57,
      "end": 74.99,
      "text": "Some children are coming out of the building.",
      "translations": {
        "zh-Hans": "一些孩子正从大楼里出来。"
      }
    },
    {
      "id": "s019",
      "start": 75.99,
      "end": 79.25,
      "text": "Some of them are going into the park.",
      "translations": {
        "zh-Hans": "他们中的一些人正走进公园。"
      }
    }
  ]
}
