{
  "version": 1,
  "course": {
    "id": "nce1-003-004-sorry-sir",
    "title": "Lesson 3: Sorry, sir.",
    "audioFilename": "003&004－Sorry, Sir..mp3",
    "duration": 60.264,
    "language": "en"
  },
  "segments": [
    {
      "id": "s001",
      "start": 0.4,
      "end": 1.78,
      "text": "Lesson 3.",
      "translations": {
        "zh-Hans": "第3课。"
      }
    },
    {
      "id": "s002",
      "start": 3.22,
      "end": 4.06,
      "text": "Sorry, Sir.",
      "translations": {
        "zh-Hans": "对不起，先生。"
      }
    },
    {
      "id": "s003",
      "start": 5.82,
      "end": 9.92,
      "text": "Listen to the tape, then answer this question.",
      "translations": {
        "zh-Hans": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "start": 11.9,
      "end": 14.72,
      "text": "Does the man get his umbrella back?",
      "translations": {
        "zh-Hans": "这位男士拿回自己的雨伞了吗？"
      }
    },
    {
      "id": "s005",
      "start": 17.56,
      "end": 20.44,
      "text": "My coat and my umbrella, please.",
      "translations": {
        "zh-Hans": "请把我的大衣和雨伞给我。"
      }
    },
    {
      "id": "s006",
      "start": 21.98,
      "end": 23.48,
      "text": "Here is my ticket.",
      "translations": {
        "zh-Hans": "这是我的牌子。"
      }
    },
    {
      "id": "s007",
      "start": 24.48,
      "end": 26.16,
      "text": "Thank you, Sir.",
      "translations": {
        "zh-Hans": "谢谢您，先生。"
      }
    },
    {
      "id": "s008",
      "start": 27.02,
      "end": 27.98,
      "text": "Number 5.",
      "translations": {
        "zh-Hans": "5号。"
      }
    },
    {
      "id": "s009",
      "start": 28.82,
      "end": 32.12,
      "text": "Here's your umbrella and your coat.",
      "translations": {
        "zh-Hans": "这是您的雨伞和大衣。"
      }
    },
    {
      "id": "s010",
      "start": 33.74,
      "end": 36.52,
      "text": "This is not my umbrella.",
      "translations": {
        "zh-Hans": "这不是我的雨伞。"
      }
    },
    {
      "id": "s011",
      "start": 37.68,
      "end": 38.48,
      "text": "Sorry, Sir.",
      "translations": {
        "zh-Hans": "对不起，先生。"
      }
    },
    {
      "id": "s012",
      "start": 39.6,
      "end": 41.46,
      "text": "Is this your umbrella?",
      "translations": {
        "zh-Hans": "这是您的雨伞吗？"
      }
    },
    {
      "id": "s013",
      "start": 42.5,
      "end": 44.22,
      "text": "No, it isn't.",
      "translations": {
        "zh-Hans": "不，不是。"
      }
    },
    {
      "id": "s014",
      "start": 45.74,
      "end": 46.9,
      "text": "Is this it?",
      "translations": {
        "zh-Hans": "是这把吗？"
      }
    },
    {
      "id": "s015",
      "start": 47.7,
      "end": 49.62,
      "text": "Yes, it is.",
      "translations": {
        "zh-Hans": "是的，是这把。"
      }
    },
    {
      "id": "s016",
      "start": 50.42,
      "end": 52.2,
      "text": "Thank you very much.",
      "translations": {
        "zh-Hans": "非常感谢。"
      }
    }
  ]
}
