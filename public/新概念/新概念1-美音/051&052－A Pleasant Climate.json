  "segments": [
    {
      "id": "s001",
      "start": 0.18,
      "end": 1.88,
      "text": "Lesson 51.",
      "translations": {
        "zh-Hans": "第51课。"
      }
    },
    {
      "id": "s002",
      "start": 2.98,
      "end": 4.68,
      "text": "A Pleasant Climate.",
      "translations": {
        "zh-Hans": "宜人的气候。"
      }
    },
    {
      "id": "s003",
      "start": 6.38,
      "end": 10.52,
      "text": "Listen to the tape, then answer this question.",
      "translations": {
        "zh-Hans": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "start": 11.98,
      "end": 14.7,
      "text": "Does it ever snow in Greece?",
      "translations": {
        "zh-Hans": "希腊下过雪吗？"
      }
    },
    {
      "id": "s005",
      "start": 17.1,
      "end": 18.9,
      "text": "Where do you come from?",
      "translations": {
        "zh-Hans": "你来自哪里？"
      }
    },
    {
      "id": "s006",
      "start": 19.86,
      "end": 21.76,
      "text": "I come from Greece.",
      "translations": {
        "zh-Hans": "我来自希腊。"
      }
    },
    {
      "id": "s007",
      "start": 22.98,
      "end": 25.94,
      "text": "What's the climate like in your country?",
      "translations": {
        "zh-Hans": "你们国家的气候怎么样？"
      }
    },
    {
      "id": "s008",
      "start": 27.06,
      "end": 29.06,
      "text": "It's very pleasant.",
      "translations": {
        "zh-Hans": "非常宜人。"
      }
    },
    {
      "id": "s009",
      "start": 29.06,
      "end": 32.72,
      "text": "What's the weather like in spring?",
      "translations": {
        "zh-Hans": "春天的天气怎么样？"
      }
    },
    {
      "id": "s010",
      "start": 34.34,
      "end": 36.74,
      "text": "It's often windy in March.",
      "translations": {
        "zh-Hans": "三月经常刮风。"
      }
    },
    {
      "id": "s011",
      "start": 37.86,
      "end": 44.1,
      "text": "It's always warm in April and May, but it rains sometimes.",
      "translations": {
        "zh-Hans": "四月和五月总是很暖和，但有时会下雨。"
      }
    },
    {
      "id": "s012",
      "start": 45.58,
      "end": 47.62,
      "text": "What's it like in summer?",
      "translations": {
        "zh-Hans": "夏天怎么样？"
      }
    },
    {
      "id": "s013",
      "start": 48.98,
      "end": 53.44,
      "text": "It's always hot in June, July, and August.",
      "translations": {
        "zh-Hans": "六月、七月和八月总是很热。"
      }
    },
    {
      "id": "s014",
      "start": 54.68,
      "end": 57.2,
      "text": "The sun shines every day.",
      "translations": {
        "zh-Hans": "每天都有阳光。"
      }
    },
    {
      "id": "s015",
      "start": 57.9,
      "end": 60.9,
      "text": "Is it cold or warm in autumn?",
      "translations": {
        "zh-Hans": "秋天冷还是暖和？"
      }
    },
    {
      "id": "s016",
      "start": 62.22,
      "end": 66.04,
      "text": "It's always warm in September and October.",
      "translations": {
        "zh-Hans": "九月和十月总是很暖和。"
      }
    },
    {
      "id": "s017",
      "start": 67.06,
      "end": 72.4,
      "text": "It's often cold in November, and it rains sometimes.",
      "translations": {
        "zh-Hans": "十一月经常很冷，有时还会下雨。"
      }
    },
    {
      "id": "s018",
      "start": 73.48,
      "end": 75.86,
      "text": "Is it very cold in winter?",
      "translations": {
        "zh-Hans": "冬天很冷吗？"
      }
    },
    {
      "id": "s019",
      "start": 77.2,
      "end": 82.34,
      "text": "It's often cold in December, January, and February.",
      "translations": {
        "zh-Hans": "十二月、一月和二月经常很冷。"
      }
    },
    {
      "id": "s020",
      "start": 83.22,
      "end": 84.82,
      "text": "It snows sometimes.",
      "translations": {
        "zh-Hans": "有时会下雪。"
      }
    }
  ]
}
