      "text": "Lesson 27.",
      "translations": {
        "zh-Hans": "第27课。"
      }
    },
    {
      "id": "s002",
      "start": 3.36,
      "end": 3.64,
      "text": "Mrs.",
      "translations": {
        "zh-Hans": "史密斯太太的"
      }
    },
    {
      "id": "s003",
      "start": 4.16,
      "end": 5.42,
      "text": "Smith's Living Room.",
      "translations": {
        "zh-Hans": "客厅。"
      }
    },
    {
      "id": "s004",
      "start": 6.92,
      "end": 11.26,
      "text": "Listen to the tape, then answer this question.",
      "translations": {
        "zh-Hans": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s005",
      "start": 12.88,
      "end": 14.6,
      "text": "Where are the books?",
      "translations": {
        "zh-Hans": "书在哪里？"
      }
    },
    {
      "id": "s006",
      "start": 16.62,
      "end": 17.32,
      "text": "Mrs.",
      "translations": {
        "zh-Hans": "史密斯太太的"
      }
    },
    {
      "id": "s007",
      "start": 17.76,
      "end": 20,
      "text": "Smith's living room is large.",
      "translations": {
        "zh-Hans": "客厅很大。"
      }
    },
    {
      "id": "s008",
      "start": 21.66,
      "end": 24.72,
      "text": "There is a television in the room.",
      "translations": {
        "zh-Hans": "房间里有一台电视机。"
      }
    },
    {
      "id": "s009",
      "start": 25.72,
      "end": 29.6,
      "text": "The television is near the window.",
      "translations": {
        "zh-Hans": "电视机靠近窗户。"
      }
    },
    {
      "id": "s010",
      "start": 31.34,
      "end": 35.26,
      "text": "There are some magazines on the television.",
      "translations": {
        "zh-Hans": "电视机上放着几本杂志。"
      }
    },
    {
      "id": "s011",
      "start": 36.46,
      "end": 39.32,
      "text": "There is a table in the room.",
      "translations": {
        "zh-Hans": "房间里有一张桌子。"
      }
    },
    {
      "id": "s012",
      "start": 40.4,
      "end": 43.78,
      "text": "There are some newspapers on the table.",
      "translations": {
        "zh-Hans": "桌子上放着几份报纸。"
      }
    },
    {
      "id": "s013",
      "start": 45.1,
      "end": 48.14,
      "text": "There are some armchairs in the room.",
      "translations": {
        "zh-Hans": "房间里有几把扶手椅。"
      }
    },
    {
      "id": "s014",
      "start": 49.22,
      "end": 52.2,
      "text": "The armchairs are near the table.",
      "translations": {
        "zh-Hans": "扶手椅在桌子附近。"
      }
    },
    {
      "id": "s015",
      "start": 52.2,
      "end": 56.3,
      "text": "There is a stereo in the room.",
      "translations": {
        "zh-Hans": "房间里有一套音响。"
      }
    },
    {
      "id": "s016",
      "start": 57.2,
      "end": 60.44,
      "text": "The stereo is near the door.",
      "translations": {
        "zh-Hans": "音响靠近门。"
      }
    },
    {
      "id": "s017",
      "start": 61.56,
      "end": 64.38,
      "text": "There are some books on the stereo.",
      "translations": {
        "zh-Hans": "音响上放着几本书。"
      }
    },
    {
      "id": "s018",
      "start": 65.68,
      "end": 68.56,
      "text": "There are some pictures in the room.",
      "translations": {
        "zh-Hans": "房间里有几幅画。"
      }
    },
    {
      "id": "s019",
      "start": 69.54,
      "end": 72.04,
      "text": "The pictures are on the wall.",
      "translations": {
        "zh-Hans": "这些画挂在墙上。"
      }
    }
  ]
}
