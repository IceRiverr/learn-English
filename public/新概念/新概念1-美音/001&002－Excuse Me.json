  "segments": [
    {
      "id": "s001",
      "start": 0.3,
      "end": 1.76,
      "text": "Lesson 1.",
      "translations": {
        "zh-Hans": "第1课。"
      }
    },
    {
      "id": "s002",
      "start": 2.66,
      "end": 4.28,
      "text": "Excuse Me.",
      "translations": {
        "zh-Hans": "对不起。"
      }
    },
    {
      "id": "s003",
      "start": 5.78,
      "end": 9.62,
      "text": "Listen to the tape, then answer this question.",
      "translations": {
        "zh-Hans": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "start": 10.72,
      "end": 12.82,
      "text": "Whose handbag is it?",
      "translations": {
        "zh-Hans": "这是谁的手提包？"
      }
    },
    {
      "id": "s005",
      "start": 15.26,
      "end": 16.06,
      "text": "Excuse me.",
      "translations": {
        "zh-Hans": "对不起。"
      }
    },
    {
      "id": "s006",
      "start": 16.56,
      "end": 17.16,
      "text": "Yes.",
      "translations": {
        "zh-Hans": "什么事？"
      }
    },
    {
      "id": "s007",
      "start": 18.32,
      "end": 20.34,
      "text": "Is this your handbag?",
      "translations": {
        "zh-Hans": "这是您的手提包吗？"
      }
    },
    {
      "id": "s008",
      "start": 21.5,
      "end": 22.06,
      "text": "Pardon.",
      "translations": {
        "zh-Hans": "请再说一遍。"
      }
    },
    {
      "id": "s009",
      "start": 23.26,
      "end": 25.76,
      "text": "Is this your handbag?",
      "translations": {
        "zh-Hans": "这是您的手提包吗？"
      }
    },
    {
      "id": "s010",
      "start": 26.6,
      "end": 28.26,
      "text": "Yes, it is.",
      "translations": {
        "zh-Hans": "是的，是我的。"
      }
    },
    {
      "id": "s011",
      "start": 29.44,
      "end": 31.04,
      "text": "Thank you very much.",
      "translations": {
        "zh-Hans": "非常感谢。"
      }
    }
  ]
}
