  },
  "segments": [
    {
      "id": "s001",
      "start": 0.4,
      "end": 2.96,
      "text": "Lesson 121.",
      "translations": {
        "zh-Hans": "第121课。"
      }
    },
    {
      "id": "s002",
      "start": 3.88,
      "end": 5.88,
      "text": "The Man in a Hat.",
      "translations": {
        "zh-Hans": "戴帽子的男士。"
      }
    },
    {
      "id": "s003",
      "start": 7.24,
      "end": 11.5,
      "text": "Listen to the tape, then answer this question.",
      "translations": {
        "zh-Hans": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "start": 13.06,
      "end": 18.02,
      "text": "Why didn't Carolyn recognize the customer straight away?",
      "translations": {
        "zh-Hans": "为什么卡罗琳没有马上认出那位顾客？"
      }
    },
    {
      "id": "s005",
      "start": 20.38,
      "end": 29.74,
      "text": "I bought two expensive dictionaries here half an hour ago, but I forgot to take them with me.",
      "translations": {
        "zh-Hans": "半小时前我在这里买了两本很贵的词典，可我忘了把它们带走。"
      }
    },
    {
      "id": "s006",
      "start": 29.74,
      "end": 32.24,
      "text": "Who served you, sir?",
      "translations": {
        "zh-Hans": "先生，是谁接待您的？"
      }
    },
    {
      "id": "s007",
      "start": 33.56,
      "end": 36.72,
      "text": "The lady who is standing behind the counter.",
      "translations": {
        "zh-Hans": "就是站在柜台后面的那位女士。"
      }
    },
    {
      "id": "s008",
      "start": 37.82,
      "end": 39.66,
      "text": "Which books did you buy?",
      "translations": {
        "zh-Hans": "您买的是哪几本书？"
      }
    },
    {
      "id": "s009",
      "start": 41.02,
      "end": 43.64,
      "text": "The books which are on the counter.",
      "translations": {
        "zh-Hans": "就是柜台上的那几本。"
      }
    },
    {
      "id": "s010",
      "start": 44.84,
      "end": 53.6,
      "text": "Did you serve this gentleman half an hour ago, He says he's the man who bought these books.",
      "translations": {
        "zh-Hans": "半小时前是你接待这位先生的吗？他说这些书是他买的。"
      }
    },
    {
      "id": "s011",
      "start": 53.6,
      "end": 56.56,
      "text": "I can't remember.",
      "translations": {
        "zh-Hans": "我记不起来了。"
      }
    },
    {
      "id": "s012",
      "start": 57.5,
      "end": 61.4,
      "text": "The man who I served was wearing a hat.",
      "translations": {
        "zh-Hans": "我接待的那位男士当时戴着帽子。"
      }
    },
    {
      "id": "s013",
      "start": 62.5,
      "end": 64.72,
      "text": "Have you got a hat, sir?",
      "translations": {
        "zh-Hans": "先生，您有帽子吗？"
      }
    },
    {
      "id": "s014",
      "start": 65.88,
      "end": 67.2,
      "text": "Yes, I have.",
      "translations": {
        "zh-Hans": "有。"
      }
    },
    {
      "id": "s015",
      "start": 68.22,
      "end": 70.12,
      "text": "Would you put it on, please?",
      "translations": {
        "zh-Hans": "请您把帽子戴上好吗？"
      }
    },
    {
      "id": "s016",
      "start": 70.98,
      "end": 71.68,
      "text": "All right.",
      "translations": {
        "zh-Hans": "好的。"
      }
    },
    {
      "id": "s017",
      "start": 72.6,
      "end": 77.54,
      "text": "Is this the man that you served, Yes.",
      "translations": {
        "zh-Hans": "这就是你接待过的那位男士吗？是的。"
      }
    },
    {
      "id": "s018",
      "start": 78.22,
      "end": 80.52,
      "text": "I recognize him now.",
      "translations": {
        "zh-Hans": "我现在认出他了。"
      }
    }
  ]
}
