    "language": "en"
  },
  "segments": [
    {
      "id": "s001",
      "start": 0.08,
      "end": 1.86,
      "text": "Lesson 45.",
      "translations": {
        "zh-Hans": "第45课。"
      }
    },
    {
      "id": "s002",
      "start": 2.88,
      "end": 4.44,
      "text": "The Boss's Letter.",
      "translations": {
        "zh-Hans": "老板的信。"
      }
    },
    {
      "id": "s003",
      "start": 6.34,
      "end": 10.58,
      "text": "Listen to the tape, then answer this question.",
      "translations": {
        "zh-Hans": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "start": 12.02,
      "end": 15.14,
      "text": "Why can't Pamela type the letter?",
      "translations": {
        "zh-Hans": "帕梅拉为什么不能把这封信打出来？"
      }
    },
    {
      "id": "s005",
      "start": 17.7,
      "end": 20.8,
      "text": "Can you come here a minute, please, Bob?",
      "translations": {
        "zh-Hans": "鲍勃，请你来一下好吗？"
      }
    },
    {
      "id": "s006",
      "start": 21.74,
      "end": 22.54,
      "text": "Yes, sir.",
      "translations": {
        "zh-Hans": "好的，先生。"
      }
    },
    {
      "id": "s007",
      "start": 24.04,
      "end": 25,
      "text": "Where's Pamela?",
      "translations": {
        "zh-Hans": "帕梅拉在哪里？"
      }
    },
    {
      "id": "s008",
      "start": 26.1,
      "end": 27.52,
      "text": "She's next door.",
      "translations": {
        "zh-Hans": "她在隔壁。"
      }
    },
    {
      "id": "s009",
      "start": 28.26,
      "end": 30.12,
      "text": "She's in her office, sir.",
      "translations": {
        "zh-Hans": "她在自己的办公室里，先生。"
      }
    },
    {
      "id": "s010",
      "start": 30.98,
      "end": 34.32,
      "text": "Can she type this letter for me?",
      "translations": {
        "zh-Hans": "她能替我把这封信打出来吗？"
      }
    },
    {
      "id": "s011",
      "start": 35.28,
      "end": 36.34,
      "text": "Ask her, please.",
      "translations": {
        "zh-Hans": "请去问问她。"
      }
    },
    {
      "id": "s012",
      "start": 37.06,
      "end": 37.7,
      "text": "Yes, sir.",
      "translations": {
        "zh-Hans": "好的，先生。"
      }
    },
    {
      "id": "s013",
      "start": 39.42,
      "end": 43.3,
      "text": "Can you type this letter for the boss, Pamela?",
      "translations": {
        "zh-Hans": "帕梅拉，你能替老板把这封信打出来吗？"
      }
    },
    {
      "id": "s014",
      "start": 44.08,
      "end": 46.58,
      "text": "Yes, of course I can.",
      "translations": {
        "zh-Hans": "能，我当然能。"
      }
    },
    {
      "id": "s015",
      "start": 47.7,
      "end": 48.64,
      "text": "Here you are.",
      "translations": {
        "zh-Hans": "给你。"
      }
    },
    {
      "id": "s016",
      "start": 49.34,
      "end": 50.5,
      "text": "Thank you, Bob.",
      "translations": {
        "zh-Hans": "谢谢你，鲍勃。"
      }
    },
    {
      "id": "s017",
      "start": 51.92,
      "end": 52.38,
      "text": "Bob?",
      "translations": {
        "zh-Hans": "鲍勃？"
      }
    },
    {
      "id": "s018",
      "start": 53.04,
      "end": 55.14,
      "text": "Yes, what's the matter?",
      "translations": {
        "zh-Hans": "怎么了？"
      }
    },
    {
      "id": "s019",
      "start": 55.84,
      "end": 58.3,
      "text": "I can't type this letter.",
      "translations": {
        "zh-Hans": "这封信我打不了。"
      }
    },
    {
      "id": "s020",
      "start": 58.3,
      "end": 60.94,
      "text": "I can't read it.",
      "translations": {
        "zh-Hans": "我看不懂。"
      }
    },
    {
      "id": "s021",
      "start": 61.64,
      "end": 64.86,
      "text": "The Boss's handwriting is terrible.",
      "translations": {
        "zh-Hans": "老板的字迹太糟糕了。"
      }
    }
  ]
}
