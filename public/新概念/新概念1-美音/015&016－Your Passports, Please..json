{
  "version": 1,
  "course": {
    "id": "nce1-015-016-your-passports-please",
    "title": "Lesson 15: Your passports, please.",
    "audioFilename": "015&016－Your Passports, Please..mp3",
    "duration": 79.02,
    "language": "en"
  },
  "segments": [
    {
      "id": "s001",
      "start": 0.21,
      "end": 1.91,
      "text": "Lesson 15.",
      "translations": {
        "zh-Hans": "第15课。"
      }
    },
    {
      "id": "s002",
      "start": 2.81,
      "end": 10.63,
      "text": "Your Passports, Listen to the tape, then answer this question.",
      "translations": {
        "zh-Hans": "请出示护照。听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s003",
      "start": 12.29,
      "end": 15.79,
      "text": "Is there a problem with the customs officer?",
      "translations": {
        "zh-Hans": "海关官员那里有什么问题吗？"
      }
    },
    {
      "id": "s004",
      "start": 18.81,
      "end": 20.03,
      "text": "Are you Swedish?",
      "translations": {
        "zh-Hans": "你们是瑞典人吗？"
      }
    },
    {
      "id": "s005",
      "start": 21.23,
      "end": 23.31,
      "text": "No, we are not.",
      "translations": {
        "zh-Hans": "不，我们不是。"
      }
    },
    {
      "id": "s006",
      "start": 23.95,
      "end": 24.89,
      "text": "We are Danish.",
      "translations": {
        "zh-Hans": "我们是丹麦人。"
      }
    },
    {
      "id": "s007",
      "start": 26.53,
      "end": 29.09,
      "text": "Are your friends Danish too?",
      "translations": {
        "zh-Hans": "你们的朋友也是丹麦人吗？"
      }
    },
    {
      "id": "s008",
      "start": 29.09,
      "end": 32.45,
      "text": "No, they aren't.",
      "translations": {
        "zh-Hans": "不，他们不是。"
      }
    },
    {
      "id": "s009",
      "start": 33.43,
      "end": 35.23,
      "text": "They are Norwegian.",
      "translations": {
        "zh-Hans": "他们是挪威人。"
      }
    },
    {
      "id": "s010",
      "start": 37.47,
      "end": 39.23,
      "text": "Your Passports, Please.",
      "translations": {
        "zh-Hans": "请出示护照。"
      }
    },
    {
      "id": "s011",
      "start": 40.63,
      "end": 41.73,
      "text": "Here they are.",
      "translations": {
        "zh-Hans": "给您。"
      }
    },
    {
      "id": "s012",
      "start": 43.03,
      "end": 44.67,
      "text": "Are these your cases?",
      "translations": {
        "zh-Hans": "这些是你们的箱子吗？"
      }
    },
    {
      "id": "s013",
      "start": 45.97,
      "end": 47.53,
      "text": "No, they aren't.",
      "translations": {
        "zh-Hans": "不，不是。"
      }
    },
    {
      "id": "s014",
      "start": 48.97,
      "end": 50.93,
      "text": "Our cases are brown.",
      "translations": {
        "zh-Hans": "我们的箱子是棕色的。"
      }
    },
    {
      "id": "s015",
      "start": 52.95,
      "end": 54.15,
      "text": "Here they are.",
      "translations": {
        "zh-Hans": "箱子在这里。"
      }
    },
    {
      "id": "s016",
      "start": 55.99,
      "end": 57.31,
      "text": "Are you tourists?",
      "translations": {
        "zh-Hans": "你们是游客吗？"
      }
    },
    {
      "id": "s017",
      "start": 58.21,
      "end": 60.49,
      "text": "Yes, we are.",
      "translations": {
        "zh-Hans": "是的，我们是。"
      }
    },
    {
      "id": "s018",
      "start": 61.81,
      "end": 64.45,
      "text": "Are your friends tourists too?",
      "translations": {
        "zh-Hans": "你们的朋友也是游客吗？"
      }
    },
    {
      "id": "s019",
      "start": 65.43,
      "end": 66.95,
      "text": "Yes, they are.",
      "translations": {
        "zh-Hans": "是的，他们是。"
      }
    },
    {
      "id": "s020",
      "start": 68.59,
      "end": 69.59,
      "text": "That's fine.",
      "translations": {
        "zh-Hans": "那就没问题了。"
      }
    },
    {
      "id": "s021",
      "start": 70.63,
      "end": 72.27,
      "text": "Thank you very much.",
      "translations": {
        "zh-Hans": "非常感谢。"
      }
    }
  ]
}
