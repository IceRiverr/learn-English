  "segments": [
    {
      "id": "s001",
      "start": 0.21,
      "end": 4.11,
      "text": "Lesson 41–Penny's Bag.",
      "translations": {
        "zh-Hans": "第41课——彭妮的提包。"
      }
    },
    {
      "id": "s002",
      "start": 5.91,
      "end": 10.09,
      "text": "Listen to the tape, then answer this question.",
      "translations": {
        "zh-Hans": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s003",
      "start": 11.93,
      "end": 15.03,
      "text": "Who is the tin of tobacco for?",
      "translations": {
        "zh-Hans": "那听烟丝是给谁的？"
      }
    },
    {
      "id": "s004",
      "start": 17.86,
      "end": 20.24,
      "text": "Is that bag heavy, Penny?",
      "translations": {
        "zh-Hans": "那个提包重吗，彭妮？"
      }
    },
    {
      "id": "s005",
      "start": 20.86,
      "end": 21.88,
      "text": "Not very.",
      "translations": {
        "zh-Hans": "不太重。"
      }
    },
    {
      "id": "s006",
      "start": 23.1,
      "end": 23.44,
      "text": "Here.",
      "translations": {
        "zh-Hans": "来。"
      }
    },
    {
      "id": "s007",
      "start": 24.4,
      "end": 26.16,
      "text": "Put it on this chair.",
      "translations": {
        "zh-Hans": "把它放在这把椅子上。"
      }
    },
    {
      "id": "s008",
      "start": 27.06,
      "end": 28.52,
      "text": "What's in it?",
      "translations": {
        "zh-Hans": "里面有什么？"
      }
    },
    {
      "id": "s009",
      "start": 28.52,
      "end": 30.82,
      "text": "A piece of cheese.",
      "translations": {
        "zh-Hans": "一块奶酪。"
      }
    },
    {
      "id": "s010",
      "start": 32.04,
      "end": 33.52,
      "text": "A loaf of bread.",
      "translations": {
        "zh-Hans": "一个面包。"
      }
    },
    {
      "id": "s011",
      "start": 34.66,
      "end": 36.18,
      "text": "A bar of soap.",
      "translations": {
        "zh-Hans": "一块肥皂。"
      }
    },
    {
      "id": "s012",
      "start": 37.4,
      "end": 39.06,
      "text": "A bar of chocolate.",
      "translations": {
        "zh-Hans": "一块巧克力。"
      }
    },
    {
      "id": "s013",
      "start": 40.08,
      "end": 41.5,
      "text": "A bottle of milk.",
      "translations": {
        "zh-Hans": "一瓶牛奶。"
      }
    },
    {
      "id": "s014",
      "start": 42.62,
      "end": 44.32,
      "text": "A pound of sugar.",
      "translations": {
        "zh-Hans": "一磅糖。"
      }
    },
    {
      "id": "s015",
      "start": 45.74,
      "end": 47.76,
      "text": "Half a pound of coffee.",
      "translations": {
        "zh-Hans": "半磅咖啡。"
      }
    },
    {
      "id": "s016",
      "start": 49.08,
      "end": 51.66,
      "text": "A quarter of a pound of tea.",
      "translations": {
        "zh-Hans": "四分之一磅茶叶。"
      }
    },
    {
      "id": "s017",
      "start": 53.02,
      "end": 55.32,
      "text": "And a tin of tobacco.",
      "translations": {
        "zh-Hans": "还有一听烟丝。"
      }
    },
    {
      "id": "s018",
      "start": 56.82,
      "end": 60.68,
      "text": "Is that tin of tobacco for me?",
      "translations": {
        "zh-Hans": "那听烟丝是给我的吗？"
      }
    },
    {
      "id": "s019",
      "start": 61.98,
      "end": 65.16,
      "text": "Well, it's certainly not for me.",
      "translations": {
        "zh-Hans": "嗯，反正肯定不是给我的。"
      }
    }
  ]
}
