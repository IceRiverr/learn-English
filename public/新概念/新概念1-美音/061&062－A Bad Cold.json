{
  "version": 1,
  "course": {
    "id": "nce1-061-062-a-bad-cold",
    "title": "Lesson 61: A bad cold",
    "audioFilename": "061&062－A Bad Cold.mp3",
    "duration": 81.789,
    "language": "en"
  },
  "segments": [
    {
      "id": "s001",
      "start": 0.27,
      "end": 1.93,
      "text": "Lesson 61.",
      "translations": {
        "zh-Hans": "第61课。"
      }
    },
    {
      "id": "s002",
      "start": 3.07,
      "end": 4.31,
      "text": "A Bad Cold.",
      "translations": {
        "zh-Hans": "重感冒。"
      }
    },
    {
      "id": "s003",
      "start": 6.17,
      "end": 9.69,
      "text": "Listen to the tape, then answer this question.",
      "translations": {
        "zh-Hans": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "start": 11.29,
      "end": 13.83,
      "text": "What is good news for Jimmy?",
      "translations": {
        "zh-Hans": "对吉米来说，什么是好消息？"
      }
    },
    {
      "id": "s005",
      "start": 16.6,
      "end": 17.5,
      "text": "Where's Jimmy?",
      "translations": {
        "zh-Hans": "吉米在哪里？"
      }
    },
    {
      "id": "s006",
      "start": 18.06,
      "end": 19.28,
      "text": "He's in bed.",
      "translations": {
        "zh-Hans": "他躺在床上。"
      }
    },
    {
      "id": "s007",
      "start": 20.68,
      "end": 22.52,
      "text": "What's the matter with him?",
      "translations": {
        "zh-Hans": "他怎么了？"
      }
    },
    {
      "id": "s008",
      "start": 22.94,
      "end": 24.5,
      "text": "He feels ill.",
      "translations": {
        "zh-Hans": "他觉得不舒服。"
      }
    },
    {
      "id": "s009",
      "start": 25.84,
      "end": 27.3,
      "text": "He looks ill.",
      "translations": {
        "zh-Hans": "他看起来病了。"
      }
    },
    {
      "id": "s010",
      "start": 27.84,
      "end": 29.72,
      "text": "We must call the doctor.",
      "translations": {
        "zh-Hans": "我们必须叫医生。"
      }
    },
    {
      "id": "s011",
      "start": 29.72,
      "end": 32.4,
      "text": "Yes, we must.",
      "translations": {
        "zh-Hans": "是的，必须叫。"
      }
    },
    {
      "id": "s012",
      "start": 34.28,
      "end": 38.12,
      "text": "Can you remember the doctor's telephone number?",
      "translations": {
        "zh-Hans": "你记得医生的电话号码吗？"
      }
    },
    {
      "id": "s013",
      "start": 38.88,
      "end": 39.18,
      "text": "Yes.",
      "translations": {
        "zh-Hans": "记得。"
      }
    },
    {
      "id": "s014",
      "start": 40.22,
      "end": 44.38,
      "text": "It's 0-9-7-5-4.",
      "translations": {
        "zh-Hans": "是0-9-7-5-4。"
      }
    },
    {
      "id": "s015",
      "start": 45.86,
      "end": 47.44,
      "text": "Open your mouth, Jimmy.",
      "translations": {
        "zh-Hans": "张开嘴，吉米。"
      }
    },
    {
      "id": "s016",
      "start": 48.44,
      "end": 49.84,
      "text": "Show me your tongue.",
      "translations": {
        "zh-Hans": "让我看看你的舌头。"
      }
    },
    {
      "id": "s017",
      "start": 50.6,
      "end": 51.52,
      "text": "Say, ah.",
      "translations": {
        "zh-Hans": "说“啊”。"
      }
    },
    {
      "id": "s018",
      "start": 53.4,
      "end": 56.02,
      "text": "What's the matter with him, doctor?",
      "translations": {
        "zh-Hans": "医生，他怎么了？"
      }
    },
    {
      "id": "s019",
      "start": 57.02,
      "end": 59.6,
      "text": "He has a bad cold, Mr. Williams,",
      "translations": {
        "zh-Hans": "威廉斯先生，他得了重感冒，"
      }
    },
    {
      "id": "s020",
      "start": 60.54,
      "end": 64.36,
      "text": "so he must stay in bed for a week.",
      "translations": {
        "zh-Hans": "所以他必须卧床一周。"
      }
    },
    {
      "id": "s021",
      "start": 65.8,
      "end": 68.3,
      "text": "That's good news for Jimmy.",
      "translations": {
        "zh-Hans": "这对吉米来说是个好消息。"
      }
    },
    {
      "id": "s022",
      "start": 69.4,
      "end": 70.18,
      "text": "Good news?",
      "translations": {
        "zh-Hans": "好消息？"
      }
    },
    {
      "id": "s023",
      "start": 70.68,
      "end": 71.08,
      "text": "Why?",
      "translations": {
        "zh-Hans": "为什么？"
      }
    },
    {
      "id": "s024",
      "start": 72.28,
      "end": 75.08,
      "text": "Because he doesn't like school.",
      "translations": {
        "zh-Hans": "因为他不喜欢上学。"
      }
    }
  ]
}
