  "segments": [
    {
      "id": "s001",
      "start": 0.4,
      "end": 2.06,
      "text": "Lesson 33.",
      "translations": {
        "zh-Hans": "第33课。"
      }
    },
    {
      "id": "s002",
      "start": 3.38,
      "end": 4.5,
      "text": "A Fine Day.",
      "translations": {
        "zh-Hans": "天气晴朗。"
      }
    },
    {
      "id": "s003",
      "start": 6.22,
      "end": 10,
      "text": "Listen to the tape, then answer this question.",
      "translations": {
        "zh-Hans": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "start": 11.62,
      "end": 13.62,
      "text": "Where is the Jones family?",
      "translations": {
        "zh-Hans": "琼斯一家在哪里？"
      }
    },
    {
      "id": "s005",
      "start": 16.15,
      "end": 18.59,
      "text": "It is a fine day today.",
      "translations": {
        "zh-Hans": "今天天气很好。"
      }
    },
    {
      "id": "s006",
      "start": 19.93,
      "end": 26.11,
      "text": "There are some clouds in the sky, but the sun is shining.",
      "translations": {
        "zh-Hans": "天空中有几朵云，但阳光灿烂。"
      }
    },
    {
      "id": "s007",
      "start": 27.31,
      "end": 28.17,
      "text": "Mr.",
      "translations": {
        "zh-Hans": "琼斯先生"
      }
    },
    {
      "id": "s008",
      "start": 28.83,
      "end": 30.45,
      "text": "Jones is with his family.",
      "translations": {
        "zh-Hans": "琼斯和家人在一起。"
      }
    },
    {
      "id": "s009",
      "start": 31.77,
      "end": 34.11,
      "text": "They are walking over the bridge.",
      "translations": {
        "zh-Hans": "他们正走过桥。"
      }
    },
    {
      "id": "s010",
      "start": 35.89,
      "end": 38.41,
      "text": "There are some boats on the river.",
      "translations": {
        "zh-Hans": "河上有几条船。"
      }
    },
    {
      "id": "s011",
      "start": 39.91,
      "end": 40.35,
      "text": "Mr.",
      "translations": {
        "zh-Hans": "琼斯"
      }
    },
    {
      "id": "s012",
      "start": 40.53,
      "end": 44.13,
      "text": "Jones and his wife are looking at them.",
      "translations": {
        "zh-Hans": "先生和他的妻子正在看着它们。"
      }
    },
    {
      "id": "s013",
      "start": 46.31,
      "end": 48.69,
      "text": "Sally is looking at a big ship.",
      "translations": {
        "zh-Hans": "萨莉正在看一艘大轮船。"
      }
    },
    {
      "id": "s014",
      "start": 50.19,
      "end": 53.19,
      "text": "The ship is going under the bridge.",
      "translations": {
        "zh-Hans": "那艘轮船正从桥下驶过。"
      }
    },
    {
      "id": "s015",
      "start": 54.19,
      "end": 57.51,
      "text": "Tim is looking at an airplane.",
      "translations": {
        "zh-Hans": "蒂姆正在看一架飞机。"
      }
    },
    {
      "id": "s016",
      "start": 59.45,
      "end": 63.05,
      "text": "The airplane is flying over the river.",
      "translations": {
        "zh-Hans": "那架飞机正从河上空飞过。"
      }
    }
  ]
}
