      "end": 4.01,
      "text": "Which Book.",
      "translations": {
        "zh-Hans": "哪一本书？"
      }
    },
    {
      "id": "s003",
      "start": 5.39,
      "end": 9.85,
      "text": "Listen to the tape, then answer this question.",
      "translations": {
        "zh-Hans": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "start": 11.53,
      "end": 14.21,
      "text": "Which book does the man want?",
      "translations": {
        "zh-Hans": "这位男士想要哪一本书？"
      }
    },
    {
      "id": "s005",
      "start": 16.68,
      "end": 19.14,
      "text": "Give me a book, please, Jane.",
      "translations": {
        "zh-Hans": "简，请给我一本书。"
      }
    },
    {
      "id": "s006",
      "start": 20.22,
      "end": 21.06,
      "text": "Which book?",
      "translations": {
        "zh-Hans": "哪一本？"
      }
    },
    {
      "id": "s007",
      "start": 21.96,
      "end": 22.56,
      "text": "This one?",
      "translations": {
        "zh-Hans": "这一本吗？"
      }
    },
    {
      "id": "s008",
      "start": 23.9,
      "end": 26.5,
      "text": "No, not that one.",
      "translations": {
        "zh-Hans": "不，不是那一本。"
      }
    },
    {
      "id": "s009",
      "start": 27.08,
      "end": 28.34,
      "text": "The red one.",
      "translations": {
        "zh-Hans": "红色的那一本。"
      }
    },
    {
      "id": "s010",
      "start": 28.34,
      "end": 30.2,
      "text": "This one?",
      "translations": {
        "zh-Hans": "这一本吗？"
      }
    },
    {
      "id": "s011",
      "start": 31.18,
      "end": 32.06,
      "text": "Yes, please.",
      "translations": {
        "zh-Hans": "是的，请给我。"
      }
    },
    {
      "id": "s012",
      "start": 33,
      "end": 33.84,
      "text": "Here you are.",
      "translations": {
        "zh-Hans": "给你。"
      }
    },
    {
      "id": "s013",
      "start": 34.74,
      "end": 35.36,
      "text": "Thank you.",
      "translations": {
        "zh-Hans": "谢谢。"
      }
    }
  ]
