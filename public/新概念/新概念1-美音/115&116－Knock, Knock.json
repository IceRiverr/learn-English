{
  "version": 1,
  "course": {
    "id": "nce1-115-116-knock-knock",
    "title": "Lesson 115: Knock, knock!",
    "audioFilename": "115&116－Knock, Knock.mp3",
    "duration": 93.884,
    "language": "en"
  },
  "segments": [
    {
      "id": "s001",
      "start": 0.34,
      "end": 5.32,
      "text": "Lesson 115–Knock, Knock.",
      "translations": {
        "zh-Hans": "第115课——敲敲门。"
      }
    },
    {
      "id": "s002",
      "start": 7.24,
      "end": 11.22,
      "text": "Listen to the tape, then answer this question.",
      "translations": {
        "zh-Hans": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s003",
      "start": 12.94,
      "end": 15.36,
      "text": "What does Jim have to drink?",
      "translations": {
        "zh-Hans": "吉姆喝了什么？"
      }
    },
    {
      "id": "s004",
      "start": 18.02,
      "end": 20.32,
      "text": "Isn't there anyone at home?",
      "translations": {
        "zh-Hans": "家里没有人吗？"
      }
    },
    {
      "id": "s005",
      "start": 21.6,
      "end": 23.44,
      "text": "I'll knock again, Helen.",
      "translations": {
        "zh-Hans": "海伦，我再敲一次。"
      }
    },
    {
      "id": "s006",
      "start": 24.64,
      "end": 26.52,
      "text": "Everything's very quiet.",
      "translations": {
        "zh-Hans": "一切都静悄悄的。"
      }
    },
    {
      "id": "s007",
      "start": 27.58,
      "end": 30.34,
      "text": "I'm sure there's no one at home.",
      "translations": {
        "zh-Hans": "我肯定家里没人。"
      }
    },
    {
      "id": "s008",
      "start": 30.34,
      "end": 32.64,
      "text": "But that's impossible.",
      "translations": {
        "zh-Hans": "但那不可能。"
      }
    },
    {
      "id": "s009",
      "start": 33.82,
      "end": 36.94,
      "text": "Carol and Tom invited us to lunch.",
      "translations": {
        "zh-Hans": "卡罗尔和汤姆邀请我们来吃午饭。"
      }
    },
    {
      "id": "s010",
      "start": 37.88,
      "end": 39.22,
      "text": "Look through the window.",
      "translations": {
        "zh-Hans": "从窗户往里看看。"
      }
    },
    {
      "id": "s011",
      "start": 40.66,
      "end": 42.22,
      "text": "Can you see anything?",
      "translations": {
        "zh-Hans": "你能看到什么吗？"
      }
    },
    {
      "id": "s012",
      "start": 43.62,
      "end": 44.96,
      "text": "Nothing at all.",
      "translations": {
        "zh-Hans": "什么也看不见。"
      }
    },
    {
      "id": "s013",
      "start": 45.88,
      "end": 47.92,
      "text": "Let's try the back door.",
      "translations": {
        "zh-Hans": "我们试试后门。"
      }
    },
    {
      "id": "s014",
      "start": 48.8,
      "end": 49.68,
      "text": "Look!",
      "translations": {
        "zh-Hans": "看！"
      }
    },
    {
      "id": "s015",
      "start": 50.64,
      "end": 52.3,
      "text": "Everyone's in the garden.",
      "translations": {
        "zh-Hans": "大家都在花园里。"
      }
    },
    {
      "id": "s016",
      "start": 53.32,
      "end": 54.22,
      "text": "Hello, Helen.",
      "translations": {
        "zh-Hans": "你好，海伦。"
      }
    },
    {
      "id": "s017",
      "start": 55.24,
      "end": 56.24,
      "text": "Hello, Jim.",
      "translations": {
        "zh-Hans": "你好，吉姆。"
      }
    },
    {
      "id": "s018",
      "start": 57.24,
      "end": 60.6,
      "text": "Everybody wants to have lunch in the garden.",
      "translations": {
        "zh-Hans": "大家都想在花园里吃午饭。"
      }
    },
    {
      "id": "s019",
      "start": 61.44,
      "end": 63.86,
      "text": "It's nice and warm out here.",
      "translations": {
        "zh-Hans": "外面又暖和又舒服。"
      }
    },
    {
      "id": "s020",
      "start": 65.08,
      "end": 67.3,
      "text": "Come and have something to drink.",
      "translations": {
        "zh-Hans": "来喝点东西吧。"
      }
    },
    {
      "id": "s021",
      "start": 68.66,
      "end": 69.66,
      "text": "Thanks, Carol.",
      "translations": {
        "zh-Hans": "谢谢，卡罗尔。"
      }
    },
    {
      "id": "s022",
      "start": 70.88,
      "end": 73.64,
      "text": "May I have a glass of beer, please?",
      "translations": {
        "zh-Hans": "请给我一杯啤酒好吗？"
      }
    },
    {
      "id": "s023",
      "start": 74.66,
      "end": 75.04,
      "text": "Beer?",
      "translations": {
        "zh-Hans": "啤酒？"
      }
    },
    {
      "id": "s024",
      "start": 75.58,
      "end": 77.12,
      "text": "There's none left.",
      "translations": {
        "zh-Hans": "一点也没剩。"
      }
    },
    {
      "id": "s025",
      "start": 77.9,
      "end": 80.32,
      "text": "You can have some lemonade.",
      "translations": {
        "zh-Hans": "你可以喝柠檬水。"
      }
    },
    {
      "id": "s026",
      "start": 81.3,
      "end": 82.1,
      "text": "Lemonade?",
      "translations": {
        "zh-Hans": "柠檬水？"
      }
    },
    {
      "id": "s027",
      "start": 82.1,
      "end": 85.96,
      "text": "Don't believe her, She's only joking.",
      "translations": {
        "zh-Hans": "别信她，她只是在开玩笑。"
      }
    },
    {
      "id": "s028",
      "start": 86.72,
      "end": 87.6,
      "text": "Have some beer.",
      "translations": {
        "zh-Hans": "喝点啤酒吧。"
      }
    }
  ]
}
