  "segments": [
    {
      "id": "s001",
      "start": 0.37,
      "end": 2.19,
      "text": "Lesson 53.",
      "translations": {
        "zh-Hans": "第53课。"
      }
    },
    {
      "id": "s002",
      "start": 3.39,
      "end": 5.37,
      "text": "An Interesting Climate.",
      "translations": {
        "zh-Hans": "有趣的气候。"
      }
    },
    {
      "id": "s003",
      "start": 7.49,
      "end": 11.41,
      "text": "Listen to the tape, then answer this question.",
      "translations": {
        "zh-Hans": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "start": 13.76,
      "end": 18.7,
      "text": "What is the favorite subject of conversation in England?",
      "translations": {
        "zh-Hans": "英国人最爱谈论的话题是什么？"
      }
    },
    {
      "id": "s005",
      "start": 21.73,
      "end": 23.39,
      "text": "Where do you come from?",
      "translations": {
        "zh-Hans": "你来自哪里？"
      }
    },
    {
      "id": "s006",
      "start": 24.85,
      "end": 26.55,
      "text": "I come from England.",
      "translations": {
        "zh-Hans": "我来自英国。"
      }
    },
    {
      "id": "s007",
      "start": 27.83,
      "end": 30.57,
      "text": "What's the climate like in your country?",
      "translations": {
        "zh-Hans": "你们国家的气候怎么样？"
      }
    },
    {
      "id": "s008",
      "start": 30.57,
      "end": 35.69,
      "text": "It's mild, but it's not always pleasant.",
      "translations": {
        "zh-Hans": "气候温和，但并不总是宜人。"
      }
    },
    {
      "id": "s009",
      "start": 37.49,
      "end": 43.47,
      "text": "The weather's often cold in the north and windy in the east.",
      "translations": {
        "zh-Hans": "北部经常很冷，东部经常刮风。"
      }
    },
    {
      "id": "s010",
      "start": 44.45,
      "end": 50.87,
      "text": "It's often wet in the west and sometimes warm in the south.",
      "translations": {
        "zh-Hans": "西部经常潮湿，南部有时很暖和。"
      }
    },
    {
      "id": "s011",
      "start": 52.37,
      "end": 54.95,
      "text": "Which seasons do you like best?",
      "translations": {
        "zh-Hans": "你最喜欢哪些季节？"
      }
    },
    {
      "id": "s012",
      "start": 55.95,
      "end": 59.05,
      "text": "I like spring and summer.",
      "translations": {
        "zh-Hans": "我喜欢春天和夏天。"
      }
    },
    {
      "id": "s013",
      "start": 59.99,
      "end": 64.57,
      "text": "The days are long and the nights are short.",
      "translations": {
        "zh-Hans": "白天长，夜晚短。"
      }
    },
    {
      "id": "s014",
      "start": 65.57,
      "end": 69.33,
      "text": "The sun rises early and sets late.",
      "translations": {
        "zh-Hans": "太阳升得早，落得晚。"
      }
    },
    {
      "id": "s015",
      "start": 70.69,
      "end": 73.69,
      "text": "I don't like autumn and winter.",
      "translations": {
        "zh-Hans": "我不喜欢秋天和冬天。"
      }
    },
    {
      "id": "s016",
      "start": 74.93,
      "end": 79.39,
      "text": "The days are short and the nights are long.",
      "translations": {
        "zh-Hans": "白天短，夜晚长。"
      }
    },
    {
      "id": "s017",
      "start": 80.39,
      "end": 85.07,
      "text": "The sun rises late and sets early.",
      "translations": {
        "zh-Hans": "太阳升得晚，落得早。"
      }
    },
    {
      "id": "s018",
      "start": 86.63,
      "end": 92.55,
      "text": "Our climate is not very good, but it's certainly interesting.",
      "translations": {
        "zh-Hans": "我们的气候不算很好，但的确很有意思。"
      }
    },
    {
      "id": "s019",
      "start": 93.61,
      "end": 96.97,
      "text": "It's our favorite subject of conversation.",
      "translations": {
        "zh-Hans": "天气是我们最喜欢谈论的话题。"
      }
    }
  ]
}
