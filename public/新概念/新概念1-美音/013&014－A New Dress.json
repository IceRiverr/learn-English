  "segments": [
    {
      "id": "s001",
      "start": 0.08,
      "end": 1.7,
      "text": "Lesson 13.",
      "translations": {
        "zh-Hans": "第13课。"
      }
    },
    {
      "id": "s002",
      "start": 2.66,
      "end": 3.9,
      "text": "A New Dress.",
      "translations": {
        "zh-Hans": "一件新连衣裙。"
      }
    },
    {
      "id": "s003",
      "start": 5.74,
      "end": 10.02,
      "text": "Listen to the tape, then answer this question.",
      "translations": {
        "zh-Hans": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "start": 11.74,
      "end": 14.5,
      "text": "What color is Anna's hat?",
      "translations": {
        "zh-Hans": "安娜的帽子是什么颜色的？"
      }
    },
    {
      "id": "s005",
      "start": 16.5,
      "end": 19.18,
      "text": "What color's your new dress?",
      "translations": {
        "zh-Hans": "你的新连衣裙是什么颜色的？"
      }
    },
    {
      "id": "s006",
      "start": 20.3,
      "end": 21.38,
      "text": "It's green.",
      "translations": {
        "zh-Hans": "是绿色的。"
      }
    },
    {
      "id": "s007",
      "start": 22.58,
      "end": 25,
      "text": "Come upstairs and see it.",
      "translations": {
        "zh-Hans": "上楼来看看吧。"
      }
    },
    {
      "id": "s008",
      "start": 25.66,
      "end": 26.46,
      "text": "Thank you.",
      "translations": {
        "zh-Hans": "谢谢。"
      }
    },
    {
      "id": "s009",
      "start": 27.41,
      "end": 27.92,
      "text": "Look!",
      "translations": {
        "zh-Hans": "看！"
      }
    },
    {
      "id": "s010",
      "start": 28.58,
      "end": 29.7,
      "text": "Here it is.",
      "translations": {
        "zh-Hans": "就是这件。"
      }
    },
    {
      "id": "s011",
      "start": 30.74,
      "end": 32.6,
      "text": "That's a nice dress.",
      "translations": {
        "zh-Hans": "这件连衣裙真漂亮。"
      }
    },
    {
      "id": "s012",
      "start": 33.52,
      "end": 34.94,
      "text": "It's very smart.",
      "translations": {
        "zh-Hans": "它很时髦。"
      }
    },
    {
      "id": "s013",
      "start": 36.2,
      "end": 38.02,
      "text": "My hat's new, too.",
      "translations": {
        "zh-Hans": "我的帽子也是新的。"
      }
    },
    {
      "id": "s014",
      "start": 39.26,
      "end": 40.8,
      "text": "What color is it?",
      "translations": {
        "zh-Hans": "是什么颜色的？"
      }
    },
    {
      "id": "s015",
      "start": 41.66,
      "end": 43.5,
      "text": "It's the same color.",
      "translations": {
        "zh-Hans": "颜色是一样的。"
      }
    },
    {
      "id": "s016",
      "start": 44.16,
      "end": 45.84,
      "text": "It's green, too.",
      "translations": {
        "zh-Hans": "也是绿色的。"
      }
    },
    {
      "id": "s017",
      "start": 47.16,
      "end": 49.72,
      "text": "That is a lovely hat.",
      "translations": {
        "zh-Hans": "这顶帽子真可爱。"
      }
    }
  ]
}
