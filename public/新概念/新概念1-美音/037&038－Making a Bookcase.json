  "segments": [
    {
      "id": "s001",
      "start": 0.24,
      "end": 1.9,
      "text": "Lesson 37.",
      "translations": {
        "zh-Hans": "第37课。"
      }
    },
    {
      "id": "s002",
      "start": 3.18,
      "end": 4.74,
      "text": "Making a Bookcase.",
      "translations": {
        "zh-Hans": "制作书柜。"
      }
    },
    {
      "id": "s003",
      "start": 6.32,
      "end": 10.22,
      "text": "Listen to the tape, then answer this question.",
      "translations": {
        "zh-Hans": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "start": 12.44,
      "end": 15.04,
      "text": "What is Susan's favorite color?",
      "translations": {
        "zh-Hans": "苏珊最喜欢什么颜色？"
      }
    },
    {
      "id": "s005",
      "start": 17.4,
      "end": 19.3,
      "text": "You're working hard, George.",
      "translations": {
        "zh-Hans": "你干得真卖力，乔治。"
      }
    },
    {
      "id": "s006",
      "start": 20.62,
      "end": 22.1,
      "text": "What are you doing?",
      "translations": {
        "zh-Hans": "你在做什么？"
      }
    },
    {
      "id": "s007",
      "start": 23.14,
      "end": 25.3,
      "text": "I'm making a bookcase.",
      "translations": {
        "zh-Hans": "我在做一个书柜。"
      }
    },
    {
      "id": "s008",
      "start": 26.84,
      "end": 29.24,
      "text": "Give me that hammer, please, Dan.",
      "translations": {
        "zh-Hans": "丹，请把那把锤子给我。"
      }
    },
    {
      "id": "s009",
      "start": 30.4,
      "end": 31.74,
      "text": "Which hammer?",
      "translations": {
        "zh-Hans": "哪一把锤子？"
      }
    },
    {
      "id": "s010",
      "start": 32.78,
      "end": 33.4,
      "text": "This one?",
      "translations": {
        "zh-Hans": "这把吗？"
      }
    },
    {
      "id": "s011",
      "start": 34.12,
      "end": 36.12,
      "text": "No, not that one.",
      "translations": {
        "zh-Hans": "不，不是那把。"
      }
    },
    {
      "id": "s012",
      "start": 36.48,
      "end": 37.5,
      "text": "The big one.",
      "translations": {
        "zh-Hans": "大的那把。"
      }
    },
    {
      "id": "s013",
      "start": 38.58,
      "end": 39.92,
      "text": "Here you are.",
      "translations": {
        "zh-Hans": "给你。"
      }
    },
    {
      "id": "s014",
      "start": 40.46,
      "end": 41.46,
      "text": "Thanks, Dan.",
      "translations": {
        "zh-Hans": "谢谢，丹。"
      }
    },
    {
      "id": "s015",
      "start": 43.24,
      "end": 46.66,
      "text": "What are you going to do now, George?",
      "translations": {
        "zh-Hans": "乔治，你现在准备做什么？"
      }
    },
    {
      "id": "s016",
      "start": 47.62,
      "end": 49.76,
      "text": "I'm going to paint it.",
      "translations": {
        "zh-Hans": "我准备给它刷漆。"
      }
    },
    {
      "id": "s017",
      "start": 51,
      "end": 54.18,
      "text": "What color are you going to paint it?",
      "translations": {
        "zh-Hans": "你准备把它漆成什么颜色？"
      }
    },
    {
      "id": "s018",
      "start": 55.18,
      "end": 57.94,
      "text": "I'm going to paint it pink.",
      "translations": {
        "zh-Hans": "我准备把它漆成粉红色。"
      }
    },
    {
      "id": "s019",
      "start": 57.94,
      "end": 59.72,
      "text": "Pink?",
      "translations": {
        "zh-Hans": "粉红色？"
      }
    },
    {
      "id": "s020",
      "start": 60.62,
      "end": 63.24,
      "text": "This bookcase isn't for me.",
      "translations": {
        "zh-Hans": "这个书柜不是给我做的。"
      }
    },
    {
      "id": "s021",
      "start": 64.02,
      "end": 66.16,
      "text": "It's for my daughter, Susan.",
      "translations": {
        "zh-Hans": "是给我女儿苏珊做的。"
      }
    },
    {
      "id": "s022",
      "start": 67.16,
      "end": 69.34,
      "text": "Pink's her favorite color.",
      "translations": {
        "zh-Hans": "粉红色是她最喜欢的颜色。"
      }
    }
  ]
}
