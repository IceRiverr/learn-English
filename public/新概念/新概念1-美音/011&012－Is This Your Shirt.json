    "id": "nce1-011-012-is-this-your-shirt",
    "title": "Lesson 11: Is this your shirt?",
    "audioFilename": "011&012－Is This Your Shirt.mp3",
    "duration": 59.246,
    "language": "en"
  },
  "segments": [
    {
      "id": "s001",
      "start": 0.53,
      "end": 1.91,
      "text": "Lesson 11.",
      "translations": {
        "zh-Hans": "第11课。"
      }
    },
    {
      "id": "s002",
      "start": 3.31,
      "end": 4.87,
      "text": "Is This Your Shirt?",
      "translations": {
        "zh-Hans": "这是你的衬衫吗？"
      }
    },
    {
      "id": "s003",
      "start": 6.23,
      "end": 11.11,
      "text": "Listen to the tape, then answer this question.",
      "translations": {
        "zh-Hans": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "start": 13.33,
      "end": 14.93,
      "text": "Whose shirt is white?",
      "translations": {
        "zh-Hans": "谁的衬衫是白色的？"
      }
    },
    {
      "id": "s005",
      "start": 17.18,
      "end": 18.8,
      "text": "Whose shirt is that?",
      "translations": {
        "zh-Hans": "那是谁的衬衫？"
      }
    },
    {
      "id": "s006",
      "start": 20.02,
      "end": 22.02,
      "text": "Is this your shirt, Dave?",
      "translations": {
        "zh-Hans": "戴夫，这是你的衬衫吗？"
      }
    },
    {
      "id": "s007",
      "start": 23.12,
      "end": 24,
      "text": "No, sir.",
      "translations": {
        "zh-Hans": "不是，先生。"
      }
    },
    {
      "id": "s008",
      "start": 24.54,
      "end": 26.24,
      "text": "It's not my shirt.",
      "translations": {
        "zh-Hans": "这不是我的衬衫。"
      }
    },
    {
      "id": "s009",
      "start": 27.24,
      "end": 29.58,
      "text": "This is my shirt.",
      "translations": {
        "zh-Hans": "这件才是我的衬衫。"
      }
    },
    {
      "id": "s010",
      "start": 30.38,
      "end": 31.84,
      "text": "My shirt's blue.",
      "translations": {
        "zh-Hans": "我的衬衫是蓝色的。"
      }
    },
    {
      "id": "s011",
      "start": 33.22,
      "end": 35.38,
      "text": "Is this shirt Tim's?",
      "translations": {
        "zh-Hans": "这件衬衫是蒂姆的吗？"
      }
    },
    {
      "id": "s012",
      "start": 36.58,
      "end": 38.26,
      "text": "Perhaps it is, sir.",
      "translations": {
        "zh-Hans": "也许是他的，先生。"
      }
    },
    {
      "id": "s013",
      "start": 39.58,
      "end": 41.14,
      "text": "Tim's shirt's white.",
      "translations": {
        "zh-Hans": "蒂姆的衬衫是白色的。"
      }
    },
    {
      "id": "s014",
      "start": 42.2,
      "end": 42.56,
      "text": "Tim!",
      "translations": {
        "zh-Hans": "蒂姆！"
      }
    },
    {
      "id": "s015",
      "start": 43.54,
      "end": 44.4,
      "text": "Yes, sir?",
      "translations": {
        "zh-Hans": "什么事，先生？"
      }
    },
    {
      "id": "s016",
      "start": 45.26,
      "end": 46.8,
      "text": "Is this your shirt?",
      "translations": {
        "zh-Hans": "这是你的衬衫吗？"
      }
    },
    {
      "id": "s017",
      "start": 47.32,
      "end": 48.12,
      "text": "Yes, sir.",
      "translations": {
        "zh-Hans": "是的，先生。"
      }
    },
    {
      "id": "s018",
      "start": 48.76,
      "end": 49.82,
      "text": "Here you are.",
      "translations": {
        "zh-Hans": "给你。"
      }
    },
    {
      "id": "s019",
      "start": 50.42,
      "end": 50.72,
      "text": "Catch!",
      "translations": {
        "zh-Hans": "接着！"
      }
    },
    {
      "id": "s020",
      "start": 51.68,
      "end": 52.62,
      "text": "Thank you, sir.",
      "translations": {
        "zh-Hans": "谢谢您，先生。"
      }
    }
  ]
}
