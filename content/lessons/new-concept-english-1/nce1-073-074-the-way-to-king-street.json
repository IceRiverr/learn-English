  "segments": [
    {
      "id": "s001",
      "text": "Lesson 73–The Way to King Street.",
      "translation": {
        "text": "第73课——去国王街的路。"
      }
    },
    {
      "id": "s002",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s002a",
      "text": "Why did the man need a phrasebook?",
      "translation": {
        "text": "那个男人为什么需要一本常用语手册？"
      }
    },
    {
      "id": "s002b",
      "text": "Last week Mrs. Mills went to London.",
      "translation": {
        "text": "上星期，米尔斯太太去了伦敦。"
      }
    },
    {
      "id": "s002c",
      "text": "She does not know London very well, and she lost her way.",
      "translation": {
        "text": "她不太熟悉伦敦，因此迷了路。"
      }
    },
    {
      "id": "s003",
      "text": "She saw a man near a bus stop.",
      "translation": {
        "text": "她在公共汽车站附近看见一个男人。"
      }
    },
    {
      "id": "s004",
      "text": "I can ask him the way, she said to herself.",
      "translation": {
        "text": "“我可以向他问路，”她心里想。"
      }
    },
    {
      "id": "s005",
      "text": "Excuse me, she said.",
      "translation": {
        "text": "“打扰一下，”她说。"
      }
    },
    {
      "id": "s006",
      "text": "Can you tell me the way to King Street, please?",
      "translation": {
        "text": "“请问您能告诉我去国王街怎么走吗？”"
      }
    },
    {
      "id": "s007",
      "text": "The man smiled pleasantly.",
      "translation": {
        "text": "那个男人友好地笑了笑。"
      }
    },
    {
      "id": "s008",
      "text": "He did not understand English.",
      "translation": {
        "text": "他听不懂英语。"
      }
    },
    {
      "id": "s009",
      "text": "He spoke German.",
      "translation": {
        "text": "他说德语。"
      }
    },
    {
      "id": "s010",
      "text": "He was a tourist.",
      "translation": {
        "text": "他是一名游客。"
      }
    },
    {
      "id": "s011",
      "text": "Then he put his hand into his pocket and took out a phrasebook.",
      "translation": {
        "text": "然后，他把手伸进口袋，拿出一本常用语手册。"
      }
    },
    {
      "id": "s012",
      "text": "He opened the book and found a phrase.",
      "translation": {
        "text": "他打开书，找到一句话。"
      }
    },
    {
      "id": "s013",
      "text": "He read the phrase slowly.",
      "translation": {
        "text": "他慢慢地读出那句话。"
      }
    },
    {
      "id": "s014",
      "text": "I am sorry, he said.",
      "translation": {
        "text": "“对不起，”他说，"
      }
    },
    {
      "id": "s015",
      "text": "I do not speak English.",
      "translation": {
        "text": "“我不会说英语。”"
      }
    }
  ],
