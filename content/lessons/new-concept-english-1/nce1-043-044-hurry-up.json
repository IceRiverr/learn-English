  "segments": [
    {
      "id": "s001",
      "text": "Lesson 43.",
      "translation": {
        "text": "第43课。"
      }
    },
    {
      "id": "s002",
      "text": "Hurry Up.",
      "translation": {
        "text": "快点！"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "How do you know Sam doesn't make the tea very often?",
      "translation": {
        "text": "你怎么知道萨姆不常沏茶？"
      }
    },
    {
      "id": "s005",
      "text": "Can you make the tea, Sam?",
      "translation": {
        "text": "萨姆，你会沏茶吗？"
      }
    },
    {
      "id": "s006",
      "text": "Yes, of course I can, Penny.",
      "translation": {
        "text": "会，我当然会，彭妮。"
      }
    },
    {
      "id": "s007",
      "text": "Is there any water in this kettle?",
      "translation": {
        "text": "这个水壶里有水吗？"
      }
    },
    {
      "id": "s008",
      "text": "Yes, there is.",
      "translation": {
        "text": "有。"
      }
    },
    {
      "id": "s009",
      "text": "Where's the tea?",
      "translation": {
        "text": "茶叶在哪里？"
      }
    },
    {
      "id": "s010",
      "text": "It's over there, behind the teapot.",
      "translation": {
        "text": "在那边，茶壶后面。"
      }
    },
    {
      "id": "s011",
      "text": "Can you see it?",
      "translation": {
        "text": "你看得见吗？"
      }
    },
    {
      "id": "s012",
      "text": "I can see the teapot, but I can't see the tea.",
      "translation": {
        "text": "我看得见茶壶，可看不见茶叶。"
      }
    },
    {
      "id": "s013",
      "text": "There it is.",
      "translation": {
        "text": "就在那里。"
      }
    },
    {
      "id": "s014",
      "text": "It's in front of you.",
      "translation": {
        "text": "就在你面前。"
      }
    },
    {
      "id": "s015",
      "text": "Ah, yes.",
      "translation": {
        "text": "啊，是的。"
      }
    },
    {
      "id": "s016",
      "text": "I can see it now.",
      "translation": {
        "text": "我现在看见了。"
      }
    },
    {
      "id": "s017",
      "text": "Where are the cups?",
      "translation": {
        "text": "茶杯在哪里？"
      }
    },
    {
      "id": "s018",
      "text": "There are some in the cupboard.",
      "translation": {
        "text": "碗橱里有几只。"
      }
    },
    {
      "id": "s019",
      "text": "Can you find them?",
      "translation": {
        "text": "你能找到吗？"
      }
    },
    {
      "id": "s020",
      "text": "Yes, here they are.",
      "translation": {
        "text": "能，在这里。"
      }
    },
    {
      "id": "s021",
      "text": "Hurry up, Sam.",
      "translation": {
        "text": "快点，萨姆。"
      }
    },
    {
      "id": "s022",
      "text": "The kettle's boiling.",
      "translation": {
        "text": "水开了。"
      }
    }
  ],
