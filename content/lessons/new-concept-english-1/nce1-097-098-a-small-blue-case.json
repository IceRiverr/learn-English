  "segments": [
    {
      "id": "s001",
      "text": "Lesson 97.",
      "translation": {
        "text": "第97课。"
      }
    },
    {
      "id": "s002",
      "text": "A Small Blue Case.",
      "translation": {
        "text": "一只蓝色小箱子。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "Does Mr. Hall",
      "translation": {
        "text": "霍尔先生"
      }
    },
    {
      "id": "s005",
      "text": "get his case back?",
      "translation": {
        "text": "拿回自己的箱子了吗？"
      }
    },
    {
      "id": "s006",
      "text": "I left a suitcase on the train to London the other day.",
      "translation": {
        "text": "前几天我把一只手提箱落在了去伦敦的火车上。"
      }
    },
    {
      "id": "s007",
      "text": "Can you describe it, sir?",
      "translation": {
        "text": "您能描述一下吗，先生？"
      }
    },
    {
      "id": "s008",
      "text": "It's a small blue case, and it's got a zip.",
      "translation": {
        "text": "是一只蓝色小箱子，带拉链。"
      }
    },
    {
      "id": "s009",
      "text": "There's a label on the handle with my name and address on it.",
      "translation": {
        "text": "提手上有个标签，写着我的姓名和地址。"
      }
    },
    {
      "id": "s010",
      "text": "Is this case yours?",
      "translation": {
        "text": "这只箱子是您的吗？"
      }
    },
    {
      "id": "s011",
      "text": "No, that's not mine.",
      "translation": {
        "text": "不，那只不是我的。"
      }
    },
    {
      "id": "s012",
      "text": "What about this one?",
      "translation": {
        "text": "这只呢？"
      }
    },
    {
      "id": "s013",
      "text": "This one's got a label.",
      "translation": {
        "text": "这只上面有标签。"
      }
    },
    {
      "id": "s014",
      "text": "Let me see it.",
      "translation": {
        "text": "让我看看。"
      }
    },
    {
      "id": "s015",
      "text": "What's your name and address?",
      "translation": {
        "text": "您的姓名和地址是什么？"
      }
    },
    {
      "id": "s016",
      "text": "David Hall, 83 Bridge Street.",
      "translation": {
        "text": "戴维·霍尔，桥街83号。"
      }
    },
    {
      "id": "s017",
      "text": "That's right.",
      "translation": {
        "text": "没错。"
      }
    },
    {
      "id": "s018",
      "text": "D. N.",
      "translation": {
        "text": "D. N."
      }
    },
    {
      "id": "s019",
      "text": "Hall, 83 Bridge Street.",
      "translation": {
        "text": "霍尔，桥街83号。"
      }
    },
    {
      "id": "s020",
      "text": "Three pounds, fifty pence, please.",
      "translation": {
        "text": "请付3英镑50便士。"
      }
    },
    {
      "id": "s021",
      "text": "Here you are.",
      "translation": {
        "text": "给您。"
      }
    },
    {
      "id": "s022",
      "text": "Thank you.",
      "translation": {
        "text": "谢谢。"
      }
    },
    {
      "id": "s023",
      "text": "Hey!",
      "translation": {
        "text": "嘿！"
      }
    },
    {
      "id": "s024",
      "text": "What's the matter?",
      "translation": {
        "text": "怎么了？"
      }
    },
    {
      "id": "s025",
      "text": "This case doesn't belong to me.",
      "translation": {
        "text": "这只箱子不是我的。"
      }
    },
    {
      "id": "s026",
      "text": "You've given me the wrong case.",
      "translation": {
        "text": "您给错箱子了。"
      }
    }
  ],
