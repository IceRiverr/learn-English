  "segments": [
    {
      "id": "s001",
      "text": "Lesson 9.",
      "translation": {
        "text": "第9课。"
      }
    },
    {
      "id": "s002",
      "text": "How Are You Today?",
      "translation": {
        "text": "你今天好吗？"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "How is Emma?",
      "translation": {
        "text": "埃玛怎么样？"
      }
    },
    {
      "id": "s005",
      "text": "Hello, Helen.",
      "translation": {
        "text": "你好，海伦。"
      }
    },
    {
      "id": "s006",
      "text": "Hi, Stephen.",
      "translation": {
        "text": "你好，史蒂文。"
      }
    },
    {
      "id": "s007",
      "text": "How are you today?",
      "translation": {
        "text": "你今天好吗？"
      }
    },
    {
      "id": "s008",
      "text": "I'm very well, thank you.",
      "translation": {
        "text": "我很好，谢谢你。"
      }
    },
    {
      "id": "s009",
      "text": "And you?",
      "translation": {
        "text": "你呢？"
      }
    },
    {
      "id": "s010",
      "text": "I'm fine, thanks.",
      "translation": {
        "text": "我很好，谢谢。"
      }
    },
    {
      "id": "s011",
      "text": "How is Tony?",
      "translation": {
        "text": "托尼怎么样？"
      }
    },
    {
      "id": "s012",
      "text": "He's fine, thanks.",
      "translation": {
        "text": "他很好，谢谢。"
      }
    },
    {
      "id": "s013",
      "text": "How's Emma?",
      "translation": {
        "text": "埃玛怎么样？"
      }
    },
    {
      "id": "s014",
      "text": "She's very well, too, Helen.",
      "translation": {
        "text": "她也很好，海伦。"
      }
    },
    {
      "id": "s015",
      "text": "Goodbye, Helen.",
      "translation": {
        "text": "再见，海伦。"
      }
    },
    {
      "id": "s016",
      "text": "Nice to see you.",
      "translation": {
        "text": "很高兴见到你。"
      }
    },
    {
      "id": "s017",
      "text": "Nice to see you, too, Stephen.",
      "translation": {
        "text": "我也很高兴见到你，史蒂文。"
      }
    },
    {
      "id": "s018",
      "text": "Goodbye.",
      "translation": {
        "text": "再见。"
      }
    }
  ],
