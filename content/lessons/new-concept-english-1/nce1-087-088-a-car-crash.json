  "segments": [
    {
      "id": "s001",
      "text": "Lesson 87–A Car Crash.",
      "translation": {
        "text": "第87课——车祸。"
      }
    },
    {
      "id": "s002",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s003",
      "text": "Can the mechanics repair Mr.",
      "translation": {
        "text": "修理工能修好伍德先生的"
      }
    },
    {
      "id": "s004",
      "text": "Wood's car?",
      "translation": {
        "text": "汽车吗？"
      }
    },
    {
      "id": "s005",
      "text": "Is my car ready yet?",
      "translation": {
        "text": "我的车修好了吗？"
      }
    },
    {
      "id": "s006",
      "text": "I don't know, sir.",
      "translation": {
        "text": "我不知道，先生。"
      }
    },
    {
      "id": "s007",
      "text": "What's the number of your car?",
      "translation": {
        "text": "您的车牌号是多少？"
      }
    },
    {
      "id": "s008",
      "text": "It's L-F-Z-3-1-2-G.",
      "translation": {
        "text": "是L-F-Z-3-1-2-G。"
      }
    },
    {
      "id": "s009",
      "text": "When did you bring it to us?",
      "translation": {
        "text": "您什么时候把车送来的？"
      }
    },
    {
      "id": "s010",
      "text": "I brought it here three days ago.",
      "translation": {
        "text": "三天前送来的。"
      }
    },
    {
      "id": "s011",
      "text": "Ah, yes, I remember now.",
      "translation": {
        "text": "啊，对了，我现在想起来了。"
      }
    },
    {
      "id": "s012",
      "text": "Have your mechanics finished yet?",
      "translation": {
        "text": "你们的修理工修完了吗？"
      }
    },
    {
      "id": "s013",
      "text": "No, they're still working on it.",
      "translation": {
        "text": "还没有，他们还在修。"
      }
    },
    {
      "id": "s014",
      "text": "Let's go into the garage and have a look at it.",
      "translation": {
        "text": "我们去车库看看吧。"
      }
    },
    {
      "id": "s015",
      "text": "Isn't that your car?",
      "translation": {
        "text": "那不是您的车吗？"
      }
    },
    {
      "id": "s016",
      "text": "Well, it was my car.",
      "translation": {
        "text": "嗯，它以前是我的车。"
      }
    },
    {
      "id": "s017",
      "text": "Didn't you have a crash?",
      "translation": {
        "text": "您不是出了车祸吗？"
      }
    },
    {
      "id": "s018",
      "text": "That's right.",
      "translation": {
        "text": "是的。"
      }
    },
    {
      "id": "s019",
      "text": "I drove it into a lamppost.",
      "translation": {
        "text": "我把车撞到路灯杆上了。"
      }
    },
    {
      "id": "s020",
      "text": "Can your mechanics repair it?",
      "translation": {
        "text": "你们的修理工能修好吗？"
      }
    },
    {
      "id": "s021",
      "text": "Well, they're trying to repair it, sir.",
      "translation": {
        "text": "他们正在设法修，先生。"
      }
    },
    {
      "id": "s022",
      "text": "But to tell you the truth, you need a new car.",
      "translation": {
        "text": "不过说实话，您需要一辆新车了。"
      }
    }
  ],
