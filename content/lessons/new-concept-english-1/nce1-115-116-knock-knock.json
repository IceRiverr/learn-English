  "segments": [
    {
      "id": "s001",
      "text": "Lesson 115–Knock, Knock.",
      "translation": {
        "text": "第115课——敲敲门。"
      }
    },
    {
      "id": "s002",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s003",
      "text": "What does Jim have to drink?",
      "translation": {
        "text": "吉姆喝了什么？"
      }
    },
    {
      "id": "s004",
      "text": "Isn't there anyone at home?",
      "translation": {
        "text": "家里没有人吗？"
      }
    },
    {
      "id": "s005",
      "text": "I'll knock again, Helen.",
      "translation": {
        "text": "海伦，我再敲一次。"
      }
    },
    {
      "id": "s006",
      "text": "Everything's very quiet.",
      "translation": {
        "text": "一切都静悄悄的。"
      }
    },
    {
      "id": "s007",
      "text": "I'm sure there's no one at home.",
      "translation": {
        "text": "我肯定家里没人。"
      }
    },
    {
      "id": "s008",
      "text": "But that's impossible.",
      "translation": {
        "text": "但那不可能。"
      }
    },
    {
      "id": "s009",
      "text": "Carol and Tom invited us to lunch.",
      "translation": {
        "text": "卡罗尔和汤姆邀请我们来吃午饭。"
      }
    },
    {
      "id": "s010",
      "text": "Look through the window.",
      "translation": {
        "text": "从窗户往里看看。"
      }
    },
    {
      "id": "s011",
      "text": "Can you see anything?",
      "translation": {
        "text": "你能看到什么吗？"
      }
    },
    {
      "id": "s012",
      "text": "Nothing at all.",
      "translation": {
        "text": "什么也看不见。"
      }
    },
    {
      "id": "s013",
      "text": "Let's try the back door.",
      "translation": {
        "text": "我们试试后门。"
      }
    },
    {
      "id": "s014",
      "text": "Look!",
      "translation": {
        "text": "看！"
      }
    },
    {
      "id": "s015",
      "text": "Everyone's in the garden.",
      "translation": {
        "text": "大家都在花园里。"
      }
    },
    {
      "id": "s016",
      "text": "Hello, Helen.",
      "translation": {
        "text": "你好，海伦。"
      }
    },
    {
      "id": "s017",
      "text": "Hello, Jim.",
      "translation": {
        "text": "你好，吉姆。"
      }
    },
    {
      "id": "s018",
      "text": "Everybody wants to have lunch in the garden.",
      "translation": {
        "text": "大家都想在花园里吃午饭。"
      }
    },
    {
      "id": "s019",
      "text": "It's nice and warm out here.",
      "translation": {
        "text": "外面又暖和又舒服。"
      }
    },
    {
      "id": "s020",
      "text": "Come and have something to drink.",
      "translation": {
        "text": "来喝点东西吧。"
      }
    },
    {
      "id": "s021",
      "text": "Thanks, Carol.",
      "translation": {
        "text": "谢谢，卡罗尔。"
      }
    },
    {
      "id": "s022",
      "text": "May I have a glass of beer, please?",
      "translation": {
        "text": "请给我一杯啤酒好吗？"
      }
    },
    {
      "id": "s023",
      "text": "Beer?",
      "translation": {
        "text": "啤酒？"
      }
    },
    {
      "id": "s024",
      "text": "There's none left.",
      "translation": {
        "text": "一点也没剩。"
      }
    },
    {
      "id": "s025",
      "text": "You can have some lemonade.",
      "translation": {
        "text": "你可以喝柠檬水。"
      }
    },
    {
      "id": "s026",
      "text": "Lemonade?",
      "translation": {
        "text": "柠檬水？"
      }
    },
    {
      "id": "s027",
      "text": "Don't believe her, She's only joking.",
      "translation": {
        "text": "别信她，她只是在开玩笑。"
      }
    },
    {
      "id": "s028",
      "text": "Have some beer.",
      "translation": {
        "text": "喝点啤酒吧。"
      }
    }
  ],
