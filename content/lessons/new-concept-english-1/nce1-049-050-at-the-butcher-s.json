    {
      "id": "s001",
      "text": "Lesson 49.",
      "translation": {
        "text": "第49课。"
      }
    },
    {
      "id": "s002",
      "text": "At the Butcher's.",
      "translation": {
        "text": "在肉店。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "What does Mr. Bird",
      "translation": {
        "text": "伯德先生"
      }
    },
    {
      "id": "s005",
      "text": "like?",
      "translation": {
        "text": "喜欢什么？"
      }
    },
    {
      "id": "s006",
      "text": "Do you want any meat today, Mrs.",
      "translation": {
        "text": "今天要买肉吗，伯德"
      }
    },
    {
      "id": "s007",
      "text": "Bird?",
      "translation": {
        "text": "太太？"
      }
    },
    {
      "id": "s008",
      "text": "Yes, please.",
      "translation": {
        "text": "要的，谢谢。"
      }
    },
    {
      "id": "s009",
      "text": "Do you want beef or lamb?",
      "translation": {
        "text": "您要牛肉还是羊肉？"
      }
    },
    {
      "id": "s010",
      "text": "Beef, please.",
      "translation": {
        "text": "请给我牛肉。"
      }
    },
    {
      "id": "s011",
      "text": "This lamb's very good.",
      "translation": {
        "text": "这羊肉很好。"
      }
    },
    {
      "id": "s012",
      "text": "I like lamb, but my husband doesn't.",
      "translation": {
        "text": "我喜欢羊肉，但我丈夫不喜欢。"
      }
    },
    {
      "id": "s013",
      "text": "What about some steak?",
      "translation": {
        "text": "来点牛排怎么样？"
      }
    },
    {
      "id": "s014",
      "text": "This is a nice piece.",
      "translation": {
        "text": "这块很好。"
      }
    },
    {
      "id": "s015",
      "text": "Give me that piece, please.",
      "translation": {
        "text": "请把那块给我。"
      }
    },
    {
      "id": "s016",
      "text": "And a pound of mince, too.",
      "translation": {
        "text": "再来一磅肉馅。"
      }
    },
    {
      "id": "s017",
      "text": "Do you want a chicken, Mrs. Bird?",
      "translation": {
        "text": "伯德太太，您要只鸡吗？"
      }
    },
    {
      "id": "s018",
      "text": "They're very nice.",
      "translation": {
        "text": "这些鸡都很好。"
      }
    },
    {
      "id": "s019",
      "text": "No, thank you.",
      "translation": {
        "text": "不了，谢谢。"
      }
    },
    {
      "id": "s020",
      "text": "My husband likes steak, but he doesn't like chicken.",
      "translation": {
        "text": "我丈夫喜欢牛排，但他不喜欢鸡肉。"
      }
    },
    {
      "id": "s021",
      "text": "To tell you the truth, Mrs.",
      "translation": {
        "text": "说实话，伯德太太，"
      }
    },
    {
      "id": "s022",
      "text": "I don't like chicken either.",
      "translation": {
        "text": "我也不喜欢鸡肉。"
      }
    }
  ],
