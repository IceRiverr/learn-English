  "segments": [
    {
      "id": "s001",
      "text": "Lesson 57–An Unusual Day.",
      "translation": {
        "text": "第57课——不寻常的一天。"
      }
    },
    {
      "id": "s002",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s003",
      "text": "What is Mr.",
      "translation": {
        "text": "索耶先生"
      }
    },
    {
      "id": "s004",
      "text": "Sawyer doing tonight?",
      "translation": {
        "text": "索耶先生今晚在做什么？"
      }
    },
    {
      "id": "s005",
      "text": "It is eight o'clock.",
      "translation": {
        "text": "现在是八点钟。"
      }
    },
    {
      "id": "s006",
      "text": "The children go to school by car every day, but today they are going to school on foot.",
      "translation": {
        "text": "孩子们每天坐汽车上学，但今天他们正步行去学校。"
      }
    },
    {
      "id": "s007",
      "text": "It is ten o'clock.",
      "translation": {
        "text": "现在是十点钟。"
      }
    },
    {
      "id": "s008",
      "text": "Mrs.",
      "translation": {
        "text": "索耶太太"
      }
    },
    {
      "id": "s009",
      "text": "Sawyer usually stays at home in the morning, but this morning she is going to the shops.",
      "translation": {
        "text": "索耶太太通常上午待在家里，但今天上午她正去商店。"
      }
    },
    {
      "id": "s010",
      "text": "It is four o'clock.",
      "translation": {
        "text": "现在是四点钟。"
      }
    },
    {
      "id": "s011",
      "text": "In the afternoon, Mrs.",
      "translation": {
        "text": "下午，索耶太太"
      }
    },
    {
      "id": "s012",
      "text": "Sawyer usually drinks tea in the living room, but this afternoon she is drinking tea in the garden.",
      "translation": {
        "text": "索耶太太通常在客厅喝茶，但今天下午她正在花园里喝茶。"
      }
    },
    {
      "id": "s013",
      "text": "It is six o'clock.",
      "translation": {
        "text": "现在是六点钟。"
      }
    },
    {
      "id": "s014",
      "text": "In the evening, the children usually do their homework, but this evening they are not doing their homework.",
      "translation": {
        "text": "晚上，孩子们通常做作业，但今天晚上他们没有做作业。"
      }
    },
    {
      "id": "s015",
      "text": "At the moment, they are playing in the garden.",
      "translation": {
        "text": "此刻，他们正在花园里玩。"
      }
    },
    {
      "id": "s016",
      "text": "It is nine o'clock.",
      "translation": {
        "text": "现在是九点钟。"
      }
    },
    {
      "id": "s017",
      "text": "Mr.",
      "translation": {
        "text": "索耶先生"
      }
    },
    {
      "id": "s018",
      "text": "Sawyer usually reads his newspaper at night, but he is not reading his newspaper tonight.",
      "translation": {
        "text": "索耶先生通常晚上看报纸，但他今晚没有看报纸。"
      }
    },
    {
      "id": "s019",
      "text": "At the moment, he is reading an interesting book.",
      "translation": {
        "text": "此刻，他正在看一本有趣的书。"
      }
    }
  ],
