  "segments": [
    {
      "id": "s001",
      "text": "Lesson 39.",
      "translation": {
        "text": "第39课。"
      }
    },
    {
      "id": "s002",
      "text": "Don't Drop It.",
      "translation": {
        "text": "别摔了。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "Where does Sam put the vase in the end?",
      "translation": {
        "text": "最后萨姆把花瓶放在哪里？"
      }
    },
    {
      "id": "s005",
      "text": "What are you going to do with that vase, Penny?",
      "translation": {
        "text": "彭妮，你打算怎么处理那个花瓶？"
      }
    },
    {
      "id": "s006",
      "text": "I'm going to put it on this table, Sam.",
      "translation": {
        "text": "我准备把它放在这张桌子上，萨姆。"
      }
    },
    {
      "id": "s007",
      "text": "Don't do that.",
      "translation": {
        "text": "别那么做。"
      }
    },
    {
      "id": "s008",
      "text": "Give it to me.",
      "translation": {
        "text": "把它给我。"
      }
    },
    {
      "id": "s009",
      "text": "What are you going to do with it?",
      "translation": {
        "text": "你准备怎么处理它？"
      }
    },
    {
      "id": "s010",
      "text": "I'm going to put it here, in front of the window.",
      "translation": {
        "text": "我准备把它放在这里，窗户前面。"
      }
    },
    {
      "id": "s011",
      "text": "Be careful.",
      "translation": {
        "text": "小心。"
      }
    },
    {
      "id": "s012",
      "text": "Don't drop it.",
      "translation": {
        "text": "别把它摔了。"
      }
    },
    {
      "id": "s013",
      "text": "Don't put it there, Sam.",
      "translation": {
        "text": "别把它放在那里，萨姆。"
      }
    },
    {
      "id": "s014",
      "text": "Put it here, on this shelf.",
      "translation": {
        "text": "把它放在这里，这个架子上。"
      }
    },
    {
      "id": "s015",
      "text": "There we are.",
      "translation": {
        "text": "好了。"
      }
    },
    {
      "id": "s016",
      "text": "It's a lovely vase.",
      "translation": {
        "text": "这个花瓶真漂亮。"
      }
    },
    {
      "id": "s017",
      "text": "Those flowers are lovely, too.",
      "translation": {
        "text": "那些花也很漂亮。"
      }
    }
  ],
