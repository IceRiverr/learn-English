  "segments": [
    {
      "id": "s001",
      "text": "Lesson 67.",
      "translation": {
        "text": "第67课。"
      }
    },
    {
      "id": "s002",
      "text": "The Weekend.",
      "translation": {
        "text": "周末。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "What are the Johnsons going to do at the weekend?",
      "translation": {
        "text": "约翰逊一家周末准备做什么？"
      }
    },
    {
      "id": "s005",
      "text": "Hello.",
      "translation": {
        "text": "你好。"
      }
    },
    {
      "id": "s006",
      "text": "Were you at the butcher's?",
      "translation": {
        "text": "你刚才在肉店吗？"
      }
    },
    {
      "id": "s007",
      "text": "Yes, I was.",
      "translation": {
        "text": "是的，我在。"
      }
    },
    {
      "id": "s008",
      "text": "Were you at the butcher's, too?",
      "translation": {
        "text": "你也在肉店吗？"
      }
    },
    {
      "id": "s009",
      "text": "No, I wasn't.",
      "translation": {
        "text": "不，我不在。"
      }
    },
    {
      "id": "s010",
      "text": "I was at the green grocer's.",
      "translation": {
        "text": "我在蔬菜水果店。"
      }
    },
    {
      "id": "s011",
      "text": "How's Jimmy today?",
      "translation": {
        "text": "吉米今天怎么样？"
      }
    },
    {
      "id": "s012",
      "text": "He's very well.",
      "translation": {
        "text": "他很好。"
      }
    },
    {
      "id": "s013",
      "text": "Thank you.",
      "translation": {
        "text": "谢谢。"
      }
    },
    {
      "id": "s014",
      "text": "Was he absent from school last week?",
      "translation": {
        "text": "他上周没去上学吗？"
      }
    },
    {
      "id": "s015",
      "text": "Yes, he was.",
      "translation": {
        "text": "是的，他没去。"
      }
    },
    {
      "id": "s016",
      "text": "He was absent on Monday, Tuesday, Wednesday, and Thursday.",
      "translation": {
        "text": "他星期一、星期二、星期三和星期四都没去上学。"
      }
    },
    {
      "id": "s017",
      "text": "How are you all keeping?",
      "translation": {
        "text": "你们大家近来好吗？"
      }
    },
    {
      "id": "s018",
      "text": "Very well.",
      "translation": {
        "text": "都很好。"
      }
    },
    {
      "id": "s019",
      "text": "Thank you.",
      "translation": {
        "text": "谢谢。"
      }
    },
    {
      "id": "s020",
      "text": "We're going to spend three days in the country.",
      "translation": {
        "text": "我们准备去乡下住三天。"
      }
    },
    {
      "id": "s021",
      "text": "We're going to stay at my mother's for the weekend.",
      "translation": {
        "text": "周末我们准备住在我母亲家。"
      }
    },
    {
      "id": "s022",
      "text": "Friday, Saturday, and Sunday in the country.",
      "translation": {
        "text": "星期五、星期六和星期日在乡下度过。"
      }
    },
    {
      "id": "s023",
      "text": "Aren't you lucky?",
      "translation": {
        "text": "你们真幸运，不是吗？"
      }
    }
  ],
