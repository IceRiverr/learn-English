  "segments": [
    {
      "id": "s001",
      "text": "Lesson 35.",
      "translation": {
        "text": "第35课。"
      }
    },
    {
      "id": "s002",
      "text": "Our Village.",
      "translation": {
        "text": "我们的村庄。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "Are the children coming out of the park or going into it?",
      "translation": {
        "text": "孩子们是在走出公园，还是走进公园？"
      }
    },
    {
      "id": "s005",
      "text": "This is a photograph of our village.",
      "translation": {
        "text": "这是我们村庄的一张照片。"
      }
    },
    {
      "id": "s006",
      "text": "Our village is in a valley.",
      "translation": {
        "text": "我们的村庄坐落在一个山谷中。"
      }
    },
    {
      "id": "s007",
      "text": "It is between two hills.",
      "translation": {
        "text": "它位于两座小山之间。"
      }
    },
    {
      "id": "s008",
      "text": "The village is on a river.",
      "translation": {
        "text": "村庄坐落在一条河边。"
      }
    },
    {
      "id": "s009",
      "text": "Here is another photograph of the village.",
      "translation": {
        "text": "这是村庄的另一张照片。"
      }
    },
    {
      "id": "s010",
      "text": "My wife and I are walking along the banks of the river.",
      "translation": {
        "text": "我和妻子正沿着河岸散步。"
      }
    },
    {
      "id": "s011",
      "text": "We are on the left.",
      "translation": {
        "text": "我们在左边。"
      }
    },
    {
      "id": "s012",
      "text": "There is a boy in the water.",
      "translation": {
        "text": "水里有个男孩。"
      }
    },
    {
      "id": "s013",
      "text": "He is swimming across the river.",
      "translation": {
        "text": "他正游过这条河。"
      }
    },
    {
      "id": "s014",
      "text": "Here is another photograph.",
      "translation": {
        "text": "这是另一张照片。"
      }
    },
    {
      "id": "s015",
      "text": "This is the school building.",
      "translation": {
        "text": "这是学校大楼。"
      }
    },
    {
      "id": "s016",
      "text": "It is beside a park.",
      "translation": {
        "text": "它在一座公园旁边。"
      }
    },
    {
      "id": "s017",
      "text": "The park is on the right.",
      "translation": {
        "text": "公园在右边。"
      }
    },
    {
      "id": "s018",
      "text": "Some children are coming out of the building.",
      "translation": {
        "text": "一些孩子正从大楼里出来。"
      }
    },
    {
      "id": "s019",
      "text": "Some of them are going into the park.",
      "translation": {
        "text": "他们中的一些人正走进公园。"
      }
    }
  ],
