  "speakers": [],
  "segments": [
    {
      "id": "s001",
      "text": "Lesson 95.",
      "translation": {
        "text": "第95课。"
      }
    },
    {
      "id": "s002",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s003",
      "text": "Why did George and Ken miss the train?",
      "translation": {
        "text": "乔治和肯为什么误了火车？"
      }
    },
    {
      "id": "s004",
      "text": "Two return tickets to London, please.",
      "translation": {
        "text": "请给我两张去伦敦的往返票。"
      }
    },
    {
      "id": "s005",
      "text": "What time will the next train leave?",
      "translation": {
        "text": "下一班火车什么时候开？"
      }
    },
    {
      "id": "s006",
      "text": "At nineteen minutes past eight.",
      "translation": {
        "text": "八点十九分。"
      }
    },
    {
      "id": "s007",
      "text": "Which platform?",
      "translation": {
        "text": "在哪个站台？"
      }
    },
    {
      "id": "s008",
      "text": "two.",
      "translation": {
        "text": "2号站台。"
      }
    },
    {
      "id": "s009",
      "text": "Over the bridge.",
      "translation": {
        "text": "过天桥。"
      }
    },
    {
      "id": "s010",
      "text": "What time will the next train leave?",
      "translation": {
        "text": "下一班火车什么时候开？"
      }
    },
    {
      "id": "s011",
      "text": "At eight nineteen.",
      "translation": {
        "text": "八点十九分。"
      }
    },
    {
      "id": "s012",
      "text": "We've got plenty of time.",
      "translation": {
        "text": "我们时间还很充裕。"
      }
    },
    {
      "id": "s013",
      "text": "It's only three minutes to eight.",
      "translation": {
        "text": "现在才差三分八点。"
      }
    },
    {
      "id": "s014",
      "text": "Let's go and have a drink.",
      "translation": {
        "text": "我们去喝一杯吧。"
      }
    },
    {
      "id": "s015",
      "text": "There's a bar next door to the station.",
      "translation": {
        "text": "车站旁边有一家酒吧。"
      }
    },
    {
      "id": "s016",
      "text": "We had better go back to the station now, Ken.",
      "translation": {
        "text": "肯，我们现在最好回车站去。"
      }
    },
    {
      "id": "s017",
      "text": "Tickets, please.",
      "translation": {
        "text": "请出示车票。"
      }
    },
    {
      "id": "s018",
      "text": "We want to catch the eight nineteen to London.",
      "translation": {
        "text": "我们想赶八点十九分去伦敦的火车。"
      }
    },
    {
      "id": "s019",
      "text": "You've just missed it.",
      "translation": {
        "text": "你们刚刚错过了。"
      }
    },
    {
      "id": "s020",
      "text": "What?",
      "translation": {
        "text": "什么？"
      }
    },
    {
      "id": "s021",
      "text": "It's only eight fifteen.",
      "translation": {
        "text": "现在才八点十五分。"
      }
    },
    {
      "id": "s022",
      "text": "I'm sorry, sir.",
      "translation": {
        "text": "对不起，先生。"
      }
    },
    {
      "id": "s023",
      "text": "That clock's ten minutes slow.",
      "translation": {
        "text": "那座钟慢了十分钟。"
      }
    },
    {
      "id": "s024",
      "text": "When's the next train?",
      "translation": {
        "text": "下一班火车是什么时候？"
      }
    },
    {
      "id": "s025",
      "text": "In five hours' time.",
      "translation": {
        "text": "五小时以后。"
      }
    }
  ],
