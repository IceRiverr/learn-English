    {
      "id": "s001",
      "text": "Lesson 23.",
      "translation": {
        "text": "第23课。"
      }
    },
    {
      "id": "s002",
      "text": "Which Glasses.",
      "translation": {
        "text": "哪几只杯子？"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "Which glasses does the man want?",
      "translation": {
        "text": "这位男士想要哪几只杯子？"
      }
    },
    {
      "id": "s005",
      "text": "Give me some glasses, please, Jane.",
      "translation": {
        "text": "简，请给我几只杯子。"
      }
    },
    {
      "id": "s006",
      "text": "Which glasses?",
      "translation": {
        "text": "哪几只？"
      }
    },
    {
      "id": "s007",
      "text": "These glasses?",
      "translation": {
        "text": "这几只吗？"
      }
    },
    {
      "id": "s008",
      "text": "No, not those.",
      "translation": {
        "text": "不，不是那些。"
      }
    },
    {
      "id": "s009",
      "text": "The ones on the shelf.",
      "translation": {
        "text": "架子上的那些。"
      }
    },
    {
      "id": "s010",
      "text": "These?",
      "translation": {
        "text": "这些吗？"
      }
    },
    {
      "id": "s011",
      "text": "Yes, please.",
      "translation": {
        "text": "是的，请给我。"
      }
    },
    {
      "id": "s012",
      "text": "Here you are.",
      "translation": {
        "text": "给你。"
      }
    },
    {
      "id": "s013",
      "text": "Thanks.",
      "translation": {
        "text": "谢谢。"
      }
    }
  ],
