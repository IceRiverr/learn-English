  "segments": [
    {
      "id": "s001",
      "text": "Lesson 109.",
      "translation": {
        "text": "第109课。"
      }
    },
    {
      "id": "s002",
      "text": "A Good Idea.",
      "translation": {
        "text": "好主意。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "What does Jane have with her coffee?",
      "translation": {
        "text": "简喝咖啡时还吃了什么？"
      }
    },
    {
      "id": "s005",
      "text": "Shall I make some coffee, Jane?",
      "translation": {
        "text": "简，我来煮点咖啡好吗？"
      }
    },
    {
      "id": "s006",
      "text": "That's a good idea, Charlotte.",
      "translation": {
        "text": "好主意，夏洛特。"
      }
    },
    {
      "id": "s007",
      "text": "It's ready.",
      "translation": {
        "text": "煮好了。"
      }
    },
    {
      "id": "s008",
      "text": "Do you want any milk?",
      "translation": {
        "text": "要加牛奶吗？"
      }
    },
    {
      "id": "s009",
      "text": "Just a little, please.",
      "translation": {
        "text": "请加一点点。"
      }
    },
    {
      "id": "s010",
      "text": "What about some sugar?",
      "translation": {
        "text": "加点糖怎么样？"
      }
    },
    {
      "id": "s011",
      "text": "Two teaspoonfuls?",
      "translation": {
        "text": "两茶匙？"
      }
    },
    {
      "id": "s012",
      "text": "No, less than that.",
      "translation": {
        "text": "不，比那少一点。"
      }
    },
    {
      "id": "s013",
      "text": "One and a half teaspoonfuls, please.",
      "translation": {
        "text": "请加一茶匙半。"
      }
    },
    {
      "id": "s014",
      "text": "That's enough for me.",
      "translation": {
        "text": "这对我来说够了。"
      }
    },
    {
      "id": "s015",
      "text": "That was very nice.",
      "translation": {
        "text": "味道真不错。"
      }
    },
    {
      "id": "s016",
      "text": "Would you like some more?",
      "translation": {
        "text": "还想再来一点吗？"
      }
    },
    {
      "id": "s017",
      "text": "Yes, please.",
      "translation": {
        "text": "好的，谢谢。"
      }
    },
    {
      "id": "s018",
      "text": "I'd like a cigarette, too.",
      "translation": {
        "text": "我还想抽支烟。"
      }
    },
    {
      "id": "s019",
      "text": "May I have one?",
      "translation": {
        "text": "可以给我一支吗？"
      }
    },
    {
      "id": "s020",
      "text": "Of course.",
      "translation": {
        "text": "当然可以。"
      }
    },
    {
      "id": "s021",
      "text": "I think there are a few in that box.",
      "translation": {
        "text": "我想那个盒子里还有几支。"
      }
    },
    {
      "id": "s022",
      "text": "I'm afraid it's empty.",
      "translation": {
        "text": "恐怕盒子是空的。"
      }
    },
    {
      "id": "s023",
      "text": "What a pity.",
      "translation": {
        "text": "真遗憾。"
      }
    },
    {
      "id": "s024",
      "text": "It doesn't matter.",
      "translation": {
        "text": "没关系。"
      }
    },
    {
      "id": "s025",
      "text": "Have a biscuit instead.",
      "translation": {
        "text": "那就吃块饼干吧。"
      }
    },
    {
      "id": "s026",
      "text": "Eat more and smoke less.",
      "translation": {
        "text": "多吃点，少抽点。"
      }
    },
    {
      "id": "s027",
      "text": "That's very good advice.",
      "translation": {
        "text": "这个建议很好。"
      }
    }
  ],
