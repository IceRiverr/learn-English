  "segments": [
    {
      "id": "s001",
      "text": "Lesson 59.",
      "translation": {
        "text": "第59课。"
      }
    },
    {
      "id": "s002",
      "text": "Is That All?",
      "translation": {
        "text": "就这些吗？"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "Does the lady buy any chalk?",
      "translation": {
        "text": "这位女士买粉笔了吗？"
      }
    },
    {
      "id": "s005",
      "text": "I want some envelopes, please.",
      "translation": {
        "text": "我想买一些信封。"
      }
    },
    {
      "id": "s006",
      "text": "Do you want the large size or the small size?",
      "translation": {
        "text": "您要大号的还是小号的？"
      }
    },
    {
      "id": "s007",
      "text": "The large size, please.",
      "translation": {
        "text": "请给我大号的。"
      }
    },
    {
      "id": "s008",
      "text": "Do you have any writing paper?",
      "translation": {
        "text": "你们有信纸吗？"
      }
    },
    {
      "id": "s009",
      "text": "Yes, we do.",
      "translation": {
        "text": "有。"
      }
    },
    {
      "id": "s010",
      "text": "I don't have any small pads.",
      "translation": {
        "text": "我没有小本的信纸簿。"
      }
    },
    {
      "id": "s011",
      "text": "I only have large ones.",
      "translation": {
        "text": "只有大本的。"
      }
    },
    {
      "id": "s012",
      "text": "Do you want a pad?",
      "translation": {
        "text": "您要一本吗？"
      }
    },
    {
      "id": "s013",
      "text": "Yes, please.",
      "translation": {
        "text": "要的，谢谢。"
      }
    },
    {
      "id": "s014",
      "text": "And I want some glue.",
      "translation": {
        "text": "我还要一些胶水。"
      }
    },
    {
      "id": "s015",
      "text": "A bottle of glue.",
      "translation": {
        "text": "一瓶胶水。"
      }
    },
    {
      "id": "s016",
      "text": "And I want a large box of chalk, too.",
      "translation": {
        "text": "我还想要一大盒粉笔。"
      }
    },
    {
      "id": "s017",
      "text": "I only have small boxes.",
      "translation": {
        "text": "我只有小盒的。"
      }
    },
    {
      "id": "s018",
      "text": "Do you want one?",
      "translation": {
        "text": "您要一盒吗？"
      }
    },
    {
      "id": "s019",
      "text": "No, thank you.",
      "translation": {
        "text": "不了，谢谢。"
      }
    },
    {
      "id": "s020",
      "text": "Is That All?",
      "translation": {
        "text": "就这些吗？"
      }
    },
    {
      "id": "s021",
      "text": "That's All, thank you.",
      "translation": {
        "text": "就这些，谢谢。"
      }
    },
    {
      "id": "s022",
      "text": "What else do you want?",
      "translation": {
        "text": "您还要什么？"
      }
    },
    {
      "id": "s023",
      "text": "I want my change.",
      "translation": {
        "text": "我要找给我的零钱。"
      }
    }
  ],
