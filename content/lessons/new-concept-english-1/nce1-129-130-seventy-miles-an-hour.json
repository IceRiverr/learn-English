  "segments": [
    {
      "id": "s001",
      "text": "Lesson 129–70 Miles an Hour.",
      "translation": {
        "text": "第129课——时速70英里。"
      }
    },
    {
      "id": "s002",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s003",
      "text": "What does Anne advise her husband to do next time?",
      "translation": {
        "text": "安建议她丈夫下次怎么做？"
      }
    },
    {
      "id": "s004",
      "text": "Look, Gary, that policeman's waving to you.",
      "translation": {
        "text": "看，加里，那个警察在向你挥手。"
      }
    },
    {
      "id": "s005",
      "text": "He wants you to stop.",
      "translation": {
        "text": "他要你停车。"
      }
    },
    {
      "id": "s006",
      "text": "Where do you think you are?",
      "translation": {
        "text": "你以为你这是在哪儿？"
      }
    },
    {
      "id": "s007",
      "text": "On a racetrack?",
      "translation": {
        "text": "在赛车场吗？"
      }
    },
    {
      "id": "s008",
      "text": "You must have been driving at seventy miles an hour.",
      "translation": {
        "text": "你刚才的车速一定达到了每小时70英里。"
      }
    },
    {
      "id": "s009",
      "text": "I can't have been.",
      "translation": {
        "text": "不可能。"
      }
    },
    {
      "id": "s010",
      "text": "I was doing eighty when I overtook you.",
      "translation": {
        "text": "我以每小时80英里的速度超过了你。"
      }
    },
    {
      "id": "s011",
      "text": "Didn't you see the speed limit?",
      "translation": {
        "text": "你没看见限速标志吗？"
      }
    },
    {
      "id": "s012",
      "text": "I'm afraid I didn't, officer.",
      "translation": {
        "text": "恐怕没看见，警官。"
      }
    },
    {
      "id": "s013",
      "text": "I must have been dreaming.",
      "translation": {
        "text": "我刚才一定是在开小差。"
      }
    },
    {
      "id": "s014",
      "text": "He wasn't dreaming, officer.",
      "translation": {
        "text": "警官，他可没有开小差。"
      }
    },
    {
      "id": "s015",
      "text": "I was telling him to drive slowly.",
      "translation": {
        "text": "我一直在叫他开慢点。"
      }
    },
    {
      "id": "s016",
      "text": "That's why I didn't see the sign.",
      "translation": {
        "text": "所以我才没看见那个标志。"
      }
    },
    {
      "id": "s017",
      "text": "Let me see your driving license.",
      "translation": {
        "text": "让我看看你的驾驶执照。"
      }
    },
    {
      "id": "s018",
      "text": "I won't charge you this time, but you'd better not do it again.",
      "translation": {
        "text": "这次我不罚你，但你最好别再犯了。"
      }
    },
    {
      "id": "s019",
      "text": "Thank you.",
      "translation": {
        "text": "谢谢您。"
      }
    },
    {
      "id": "s020",
      "text": "I'll certainly be more careful.",
      "translation": {
        "text": "我以后一定会更加小心。"
      }
    },
    {
      "id": "s021",
      "text": "I told you to drive slowly, Gary.",
      "translation": {
        "text": "我早就叫你开慢点了，加里。"
      }
    },
    {
      "id": "s022",
      "text": "You always tell me to drive slowly, darling.",
      "translation": {
        "text": "亲爱的，你总是叫我开慢点。"
      }
    },
    {
      "id": "s023",
      "text": "Well, next time, you'd better take my advice.",
      "translation": {
        "text": "那下次你最好听我的劝。"
      }
    }
  ],
