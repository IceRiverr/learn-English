    {
      "id": "s001",
      "text": "Lesson 47.",
      "translation": {
        "text": "第47课。"
      }
    },
    {
      "id": "s002",
      "text": "A Cup of Coffee.",
      "translation": {
        "text": "一杯咖啡。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "How does Anne like her coffee?",
      "translation": {
        "text": "安喜欢喝什么样的咖啡？"
      }
    },
    {
      "id": "s005",
      "text": "Do you like coffee, Anne?",
      "translation": {
        "text": "安，你喜欢咖啡吗？"
      }
    },
    {
      "id": "s006",
      "text": "Yes, I do.",
      "translation": {
        "text": "喜欢。"
      }
    },
    {
      "id": "s007",
      "text": "Do you want a cup?",
      "translation": {
        "text": "想来一杯吗？"
      }
    },
    {
      "id": "s008",
      "text": "Yes, please, Christine.",
      "translation": {
        "text": "好的，谢谢，克里斯蒂娜。"
      }
    },
    {
      "id": "s009",
      "text": "Do you want any sugar?",
      "translation": {
        "text": "要加糖吗？"
      }
    },
    {
      "id": "s010",
      "text": "Yes, please.",
      "translation": {
        "text": "好的，请加一点。"
      }
    },
    {
      "id": "s011",
      "text": "Do you want any milk?",
      "translation": {
        "text": "要加牛奶吗？"
      }
    },
    {
      "id": "s012",
      "text": "No, thank you.",
      "translation": {
        "text": "不了，谢谢。"
      }
    },
    {
      "id": "s013",
      "text": "I don't like milk in my coffee.",
      "translation": {
        "text": "我不喜欢在咖啡里加牛奶。"
      }
    },
    {
      "id": "s014",
      "text": "I like black coffee.",
      "translation": {
        "text": "我喜欢黑咖啡。"
      }
    },
    {
      "id": "s015",
      "text": "Do you like biscuits?",
      "translation": {
        "text": "你喜欢饼干吗？"
      }
    },
    {
      "id": "s016",
      "text": "Yes, I do.",
      "translation": {
        "text": "喜欢。"
      }
    },
    {
      "id": "s017",
      "text": "Do you want one?",
      "translation": {
        "text": "想来一块吗？"
      }
    },
    {
      "id": "s018",
      "text": "Yes, please.",
      "translation": {
        "text": "好的，谢谢。"
      }
    }
  ],
