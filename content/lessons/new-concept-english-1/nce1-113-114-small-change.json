  "segments": [
    {
      "id": "s001",
      "text": "Lesson 113.",
      "translation": {
        "text": "第113课。"
      }
    },
    {
      "id": "s002",
      "text": "Small Change.",
      "translation": {
        "text": "零钱。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "Who has got some small change?",
      "translation": {
        "text": "谁有零钱？"
      }
    },
    {
      "id": "s005",
      "text": "Fairs, please.",
      "translation": {
        "text": "请买票。"
      }
    },
    {
      "id": "s006",
      "text": "Trafalgar Square, please.",
      "translation": {
        "text": "请给我一张去特拉法加广场的票。"
      }
    },
    {
      "id": "s007",
      "text": "I'm sorry, sir.",
      "translation": {
        "text": "对不起，先生。"
      }
    },
    {
      "id": "s008",
      "text": "I can't change a ten-pound note.",
      "translation": {
        "text": "我找不开十英镑的钞票。"
      }
    },
    {
      "id": "s009",
      "text": "Haven't you got any small change?",
      "translation": {
        "text": "您没有零钱吗？"
      }
    },
    {
      "id": "s010",
      "text": "I've got no small change, I'm afraid.",
      "translation": {
        "text": "恐怕我一点零钱也没有。"
      }
    },
    {
      "id": "s011",
      "text": "I'll ask some of the passengers.",
      "translation": {
        "text": "我问问其他乘客。"
      }
    },
    {
      "id": "s012",
      "text": "Have you any small change, sir?",
      "translation": {
        "text": "先生，您有零钱吗？"
      }
    },
    {
      "id": "s013",
      "text": "I'm sorry, I've got none.",
      "translation": {
        "text": "对不起，我没有。"
      }
    },
    {
      "id": "s014",
      "text": "I haven't got any either.",
      "translation": {
        "text": "我也没有。"
      }
    },
    {
      "id": "s015",
      "text": "Can you change this ten-pound note, madam?",
      "translation": {
        "text": "女士，您能找开这张十英镑的钞票吗？"
      }
    },
    {
      "id": "s016",
      "text": "I'm afraid I can't.",
      "translation": {
        "text": "恐怕不能。"
      }
    },
    {
      "id": "s017",
      "text": "Neither can I.",
      "translation": {
        "text": "我也不能。"
      }
    },
    {
      "id": "s018",
      "text": "I'm very sorry, sir.",
      "translation": {
        "text": "非常抱歉，先生。"
      }
    },
    {
      "id": "s019",
      "text": "You must get off the bus.",
      "translation": {
        "text": "您必须下车。"
      }
    },
    {
      "id": "s020",
      "text": "None of our passengers can change this note.",
      "translation": {
        "text": "我们的乘客谁也找不开这张钞票。"
      }
    },
    {
      "id": "s021",
      "text": "They're all millionaires.",
      "translation": {
        "text": "他们全是百万富翁。"
      }
    },
    {
      "id": "s022",
      "text": "Except us.",
      "translation": {
        "text": "除了我们。"
      }
    },
    {
      "id": "s023",
      "text": "I've got some small change.",
      "translation": {
        "text": "我有一些零钱。"
      }
    },
    {
      "id": "s024",
      "text": "So have I.",
      "translation": {
        "text": "我也有。"
      }
    }
  ],
