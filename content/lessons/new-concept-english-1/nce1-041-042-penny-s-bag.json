  "segments": [
    {
      "id": "s001",
      "text": "Lesson 41–Penny's Bag.",
      "translation": {
        "text": "第41课——彭妮的提包。"
      }
    },
    {
      "id": "s002",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s003",
      "text": "Who is the tin of tobacco for?",
      "translation": {
        "text": "那听烟丝是给谁的？"
      }
    },
    {
      "id": "s004",
      "text": "Is that bag heavy, Penny?",
      "translation": {
        "text": "那个提包重吗，彭妮？"
      }
    },
    {
      "id": "s005",
      "text": "Not very.",
      "translation": {
        "text": "不太重。"
      }
    },
    {
      "id": "s006",
      "text": "Here.",
      "translation": {
        "text": "来。"
      }
    },
    {
      "id": "s007",
      "text": "Put it on this chair.",
      "translation": {
        "text": "把它放在这把椅子上。"
      }
    },
    {
      "id": "s008",
      "text": "What's in it?",
      "translation": {
        "text": "里面有什么？"
      }
    },
    {
      "id": "s009",
      "text": "A piece of cheese.",
      "translation": {
        "text": "一块奶酪。"
      }
    },
    {
      "id": "s010",
      "text": "A loaf of bread.",
      "translation": {
        "text": "一个面包。"
      }
    },
    {
      "id": "s011",
      "text": "A bar of soap.",
      "translation": {
        "text": "一块肥皂。"
      }
    },
    {
      "id": "s012",
      "text": "A bar of chocolate.",
      "translation": {
        "text": "一块巧克力。"
      }
    },
    {
      "id": "s013",
      "text": "A bottle of milk.",
      "translation": {
        "text": "一瓶牛奶。"
      }
    },
    {
      "id": "s014",
      "text": "A pound of sugar.",
      "translation": {
        "text": "一磅糖。"
      }
    },
    {
      "id": "s015",
      "text": "Half a pound of coffee.",
      "translation": {
        "text": "半磅咖啡。"
      }
    },
    {
      "id": "s016",
      "text": "A quarter of a pound of tea.",
      "translation": {
        "text": "四分之一磅茶叶。"
      }
    },
    {
      "id": "s017",
      "text": "And a tin of tobacco.",
      "translation": {
        "text": "还有一听烟丝。"
      }
    },
    {
      "id": "s018",
      "text": "Is that tin of tobacco for me?",
      "translation": {
        "text": "那听烟丝是给我的吗？"
      }
    },
    {
      "id": "s019",
      "text": "Well, it's certainly not for me.",
      "translation": {
        "text": "嗯，反正肯定不是给我的。"
      }
    }
  ],
