  "segments": [
    {
      "id": "s001",
      "text": "Lesson 131.",
      "translation": {
        "text": "第131课。"
      }
    },
    {
      "id": "s002",
      "text": "Don't Be So Sure.",
      "translation": {
        "text": "别那么肯定。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "What's the problem about deciding on a holiday?",
      "translation": {
        "text": "在决定去哪里度假这件事上有什么难题？"
      }
    },
    {
      "id": "s005",
      "text": "Where are you going to spend your holidays this year, Gary?",
      "translation": {
        "text": "加里，你们今年准备去哪里度假？"
      }
    },
    {
      "id": "s006",
      "text": "We may go abroad.",
      "translation": {
        "text": "我们可能会出国。"
      }
    },
    {
      "id": "s007",
      "text": "I'm not sure.",
      "translation": {
        "text": "我还不确定。"
      }
    },
    {
      "id": "s008",
      "text": "My wife wants to go to Egypt.",
      "translation": {
        "text": "我妻子想去埃及。"
      }
    },
    {
      "id": "s009",
      "text": "I'd like to go there too.",
      "translation": {
        "text": "我也想去那里。"
      }
    },
    {
      "id": "s010",
      "text": "We can't make up our minds.",
      "translation": {
        "text": "我们拿不定主意。"
      }
    },
    {
      "id": "s011",
      "text": "Will you travel by sea or by air?",
      "translation": {
        "text": "你们坐船还是坐飞机？"
      }
    },
    {
      "id": "s012",
      "text": "We may travel by sea.",
      "translation": {
        "text": "我们可能坐船。"
      }
    },
    {
      "id": "s013",
      "text": "It's cheaper, isn't it?",
      "translation": {
        "text": "那样便宜些，对吧？"
      }
    },
    {
      "id": "s014",
      "text": "It may be cheaper, but it takes a long time.",
      "translation": {
        "text": "也许便宜些，但要花很长时间。"
      }
    },
    {
      "id": "s015",
      "text": "I'm sure you'll enjoy yourselves.",
      "translation": {
        "text": "我相信你们会玩得很开心。"
      }
    },
    {
      "id": "s016",
      "text": "Don't Be So Sure.",
      "translation": {
        "text": "别那么肯定。"
      }
    },
    {
      "id": "s017",
      "text": "We might not go anywhere.",
      "translation": {
        "text": "我们可能哪儿也不去。"
      }
    },
    {
      "id": "s018",
      "text": "My wife always worries too much.",
      "translation": {
        "text": "我妻子总是担心得太多。"
      }
    },
    {
      "id": "s019",
      "text": "Who's going to look after the dog?",
      "translation": {
        "text": "谁来照看狗呢？"
      }
    },
    {
      "id": "s020",
      "text": "Who's going to look after the house?",
      "translation": {
        "text": "谁来照看房子呢？"
      }
    },
    {
      "id": "s021",
      "text": "Who's going to look after the garden?",
      "translation": {
        "text": "谁来照看花园呢？"
      }
    },
    {
      "id": "s022",
      "text": "We have this problem every year.",
      "translation": {
        "text": "我们每年都有这个难题。"
      }
    },
    {
      "id": "s023",
      "text": "In the end, we stay at home and look after everything.",
      "translation": {
        "text": "最后，我们总是待在家里照看一切。"
      }
    }
  ],
