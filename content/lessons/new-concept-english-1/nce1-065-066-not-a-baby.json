  "segments": [
    {
      "id": "s001",
      "text": "Lesson 65–Not a Baby.",
      "translation": {
        "text": "第65课——不是小孩子了。"
      }
    },
    {
      "id": "s002",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s003",
      "text": "Does Jill take the key to the front door?",
      "translation": {
        "text": "吉尔带走前门钥匙了吗？"
      }
    },
    {
      "id": "s004",
      "text": "What are you going to do this evening, Jill?",
      "translation": {
        "text": "吉尔，你今晚打算做什么？"
      }
    },
    {
      "id": "s005",
      "text": "I'm going to meet some friends, Dad.",
      "translation": {
        "text": "我打算去见几个朋友，爸爸。"
      }
    },
    {
      "id": "s006",
      "text": "You mustn't come home late.",
      "translation": {
        "text": "你不许回家太晚。"
      }
    },
    {
      "id": "s007",
      "text": "You must be home at half past ten.",
      "translation": {
        "text": "你必须十点半到家。"
      }
    },
    {
      "id": "s008",
      "text": "I can't get home so early, Dad.",
      "translation": {
        "text": "我没法那么早回家，爸爸。"
      }
    },
    {
      "id": "s009",
      "text": "Can I have the key to the front door, No, you can't.",
      "translation": {
        "text": "我能带前门钥匙吗？不，你不能。"
      }
    },
    {
      "id": "s010",
      "text": "Jill's eighteen years old, Tom.",
      "translation": {
        "text": "吉尔已经十八岁了，汤姆。"
      }
    },
    {
      "id": "s011",
      "text": "She's not a baby.",
      "translation": {
        "text": "她不是小孩子了。"
      }
    },
    {
      "id": "s012",
      "text": "Give her the key.",
      "translation": {
        "text": "把钥匙给她吧。"
      }
    },
    {
      "id": "s013",
      "text": "She always comes home early.",
      "translation": {
        "text": "她一向回家很早。"
      }
    },
    {
      "id": "s014",
      "text": "Oh, all right.",
      "translation": {
        "text": "哦，那好吧。"
      }
    },
    {
      "id": "s015",
      "text": "Here you are.",
      "translation": {
        "text": "给你。"
      }
    },
    {
      "id": "s016",
      "text": "But you mustn't come home after a quarter past eleven.",
      "translation": {
        "text": "但你不能晚于十一点一刻回家。"
      }
    },
    {
      "id": "s017",
      "text": "Do you hear?",
      "translation": {
        "text": "听见了吗？"
      }
    },
    {
      "id": "s018",
      "text": "Yes, Dad.",
      "translation": {
        "text": "听见了，爸爸。"
      }
    },
    {
      "id": "s019",
      "text": "Thanks, Mom.",
      "translation": {
        "text": "谢谢，妈妈。"
      }
    },
    {
      "id": "s020",
      "text": "That's all right.",
      "translation": {
        "text": "不用谢。"
      }
    },
    {
      "id": "s021",
      "text": "Goodbye.",
      "translation": {
        "text": "再见。"
      }
    },
    {
      "id": "s022",
      "text": "Enjoy yourself.",
      "translation": {
        "text": "玩得开心。"
      }
    },
    {
      "id": "s023",
      "text": "We always enjoy ourselves, Mom.",
      "translation": {
        "text": "我们总会玩得很开心，妈妈。"
      }
    },
    {
      "id": "s024",
      "text": "Bye-bye.",
      "translation": {
        "text": "再见。"
      }
    }
  ],
