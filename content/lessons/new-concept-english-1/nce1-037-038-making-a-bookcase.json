  "segments": [
    {
      "id": "s001",
      "text": "Lesson 37.",
      "translation": {
        "text": "第37课。"
      }
    },
    {
      "id": "s002",
      "text": "Making a Bookcase.",
      "translation": {
        "text": "制作书柜。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "What is Susan's favorite color?",
      "translation": {
        "text": "苏珊最喜欢什么颜色？"
      }
    },
    {
      "id": "s005",
      "text": "You're working hard, George.",
      "translation": {
        "text": "你干得真卖力，乔治。"
      }
    },
    {
      "id": "s006",
      "text": "What are you doing?",
      "translation": {
        "text": "你在做什么？"
      }
    },
    {
      "id": "s007",
      "text": "I'm making a bookcase.",
      "translation": {
        "text": "我在做一个书柜。"
      }
    },
    {
      "id": "s008",
      "text": "Give me that hammer, please, Dan.",
      "translation": {
        "text": "丹，请把那把锤子给我。"
      }
    },
    {
      "id": "s009",
      "text": "Which hammer?",
      "translation": {
        "text": "哪一把锤子？"
      }
    },
    {
      "id": "s010",
      "text": "This one?",
      "translation": {
        "text": "这把吗？"
      }
    },
    {
      "id": "s011",
      "text": "No, not that one.",
      "translation": {
        "text": "不，不是那把。"
      }
    },
    {
      "id": "s012",
      "text": "The big one.",
      "translation": {
        "text": "大的那把。"
      }
    },
    {
      "id": "s013",
      "text": "Here you are.",
      "translation": {
        "text": "给你。"
      }
    },
    {
      "id": "s014",
      "text": "Thanks, Dan.",
      "translation": {
        "text": "谢谢，丹。"
      }
    },
    {
      "id": "s015",
      "text": "What are you going to do now, George?",
      "translation": {
        "text": "乔治，你现在准备做什么？"
      }
    },
    {
      "id": "s016",
      "text": "I'm going to paint it.",
      "translation": {
        "text": "我准备给它刷漆。"
      }
    },
    {
      "id": "s017",
      "text": "What color are you going to paint it?",
      "translation": {
        "text": "你准备把它漆成什么颜色？"
      }
    },
    {
      "id": "s018",
      "text": "I'm going to paint it pink.",
      "translation": {
        "text": "我准备把它漆成粉红色。"
      }
    },
    {
      "id": "s019",
      "text": "Pink?",
      "translation": {
        "text": "粉红色？"
      }
    },
    {
      "id": "s020",
      "text": "This bookcase isn't for me.",
      "translation": {
        "text": "这个书柜不是给我做的。"
      }
    },
    {
      "id": "s021",
      "text": "It's for my daughter, Susan.",
      "translation": {
        "text": "是给我女儿苏珊做的。"
      }
    },
    {
      "id": "s022",
      "text": "Pink's her favorite color.",
      "translation": {
        "text": "粉红色是她最喜欢的颜色。"
      }
    }
  ],
