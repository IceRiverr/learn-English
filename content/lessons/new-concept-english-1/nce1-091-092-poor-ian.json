  "segments": [
    {
      "id": "s001",
      "text": "Lesson 91–Poor Ian.",
      "translation": {
        "text": "第91课——可怜的伊恩。"
      }
    },
    {
      "id": "s002",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s003",
      "text": "Who wanted to sell the house?",
      "translation": {
        "text": "谁想卖掉这所房子？"
      }
    },
    {
      "id": "s004",
      "text": "Has Ian sold his house yet?",
      "translation": {
        "text": "伊恩已经卖掉房子了吗？"
      }
    },
    {
      "id": "s005",
      "text": "Yes, he has.",
      "translation": {
        "text": "是的，已经卖了。"
      }
    },
    {
      "id": "s006",
      "text": "He sold it last week.",
      "translation": {
        "text": "他上星期卖掉的。"
      }
    },
    {
      "id": "s007",
      "text": "Has he moved to his new house yet?",
      "translation": {
        "text": "他已经搬进新房子了吗？"
      }
    },
    {
      "id": "s008",
      "text": "No, not yet.",
      "translation": {
        "text": "还没有。"
      }
    },
    {
      "id": "s009",
      "text": "He's still here.",
      "translation": {
        "text": "他还在这里。"
      }
    },
    {
      "id": "s010",
      "text": "He's going to move tomorrow.",
      "translation": {
        "text": "他准备明天搬家。"
      }
    },
    {
      "id": "s011",
      "text": "When?",
      "translation": {
        "text": "什么时候？"
      }
    },
    {
      "id": "s012",
      "text": "morning?",
      "translation": {
        "text": "上午吗？"
      }
    },
    {
      "id": "s013",
      "text": "No, afternoon.",
      "translation": {
        "text": "不，下午。"
      }
    },
    {
      "id": "s014",
      "text": "I'll miss him.",
      "translation": {
        "text": "我会想念他的。"
      }
    },
    {
      "id": "s015",
      "text": "He has always been a good neighbor.",
      "translation": {
        "text": "他一直是个好邻居。"
      }
    },
    {
      "id": "s016",
      "text": "He's a very nice person.",
      "translation": {
        "text": "他人很好。"
      }
    },
    {
      "id": "s017",
      "text": "We'll all miss him.",
      "translation": {
        "text": "我们大家都会想念他的。"
      }
    },
    {
      "id": "s018",
      "text": "When will the new people move into this house?",
      "translation": {
        "text": "新住户什么时候搬进这所房子？"
      }
    },
    {
      "id": "s019",
      "text": "I think that they'll move in the day after tomorrow.",
      "translation": {
        "text": "我想他们后天会搬进来。"
      }
    },
    {
      "id": "s020",
      "text": "Will you see Ian today, Jenny?",
      "translation": {
        "text": "珍妮，你今天会见到伊恩吗？"
      }
    },
    {
      "id": "s021",
      "text": "Yes, I will.",
      "translation": {
        "text": "会的。"
      }
    },
    {
      "id": "s022",
      "text": "Please give him my regards.",
      "translation": {
        "text": "请代我向他问好。"
      }
    },
    {
      "id": "s023",
      "text": "Poor Ian.",
      "translation": {
        "text": "可怜的伊恩。"
      }
    },
    {
      "id": "s024",
      "text": "He didn't want to leave this house.",
      "translation": {
        "text": "他并不想离开这所房子。"
      }
    },
    {
      "id": "s025",
      "text": "No, he didn't want to leave, but his wife did.",
      "translation": {
        "text": "是的，他不想离开，但他妻子想。"
      }
    }
  ],
