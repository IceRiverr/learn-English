  "segments": [
    {
      "id": "s001",
      "text": "Lesson 17.",
      "translation": {
        "text": "第17课。"
      }
    },
    {
      "id": "s002",
      "text": "How do you do.",
      "translation": {
        "text": "你好。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "What are Michael Baker and Jeremy Short's jobs?",
      "translation": {
        "text": "迈克尔·贝克和杰里米·肖特是做什么工作的？"
      }
    },
    {
      "id": "s005",
      "text": "Come and meet our employees, Mr. Richards.",
      "translation": {
        "text": "理查兹先生，来认识一下我们的雇员。"
      }
    },
    {
      "id": "s006",
      "text": "Thank you, Mr.",
      "translation": {
        "text": "谢谢您，"
      }
    },
    {
      "id": "s007",
      "text": "Jackson.",
      "translation": {
        "text": "杰克逊先生。"
      }
    },
    {
      "id": "s008",
      "text": "This is Nicola Gray.",
      "translation": {
        "text": "这位是尼古拉·格雷。"
      }
    },
    {
      "id": "s009",
      "text": "And this is Claire Taylor.",
      "translation": {
        "text": "这位是克莱尔·泰勒。"
      }
    },
    {
      "id": "s010",
      "text": "How do you do.",
      "translation": {
        "text": "你好。"
      }
    },
    {
      "id": "s011",
      "text": "Those women are very hard-working.",
      "translation": {
        "text": "那些女士工作很勤奋。"
      }
    },
    {
      "id": "s012",
      "text": "What are their jobs?",
      "translation": {
        "text": "她们是做什么工作的？"
      }
    },
    {
      "id": "s013",
      "text": "They're keyboard operators.",
      "translation": {
        "text": "她们是电脑录入员。"
      }
    },
    {
      "id": "s014",
      "text": "This is Michael Baker.",
      "translation": {
        "text": "这位是迈克尔·贝克。"
      }
    },
    {
      "id": "s015",
      "text": "And this is Jeremy Short.",
      "translation": {
        "text": "这位是杰里米·肖特。"
      }
    },
    {
      "id": "s016",
      "text": "How do you do.",
      "translation": {
        "text": "你好。"
      }
    },
    {
      "id": "s017",
      "text": "They aren't very busy.",
      "translation": {
        "text": "他们不太忙。"
      }
    },
    {
      "id": "s018",
      "text": "What are their jobs?",
      "translation": {
        "text": "他们是做什么工作的？"
      }
    },
    {
      "id": "s019",
      "text": "They're sales reps.",
      "translation": {
        "text": "他们是推销员。"
      }
    },
    {
      "id": "s020",
      "text": "They're very lazy.",
      "translation": {
        "text": "他们很懒。"
      }
    },
    {
      "id": "s021",
      "text": "Who is this young man?",
      "translation": {
        "text": "这位年轻人是谁？"
      }
    },
    {
      "id": "s022",
      "text": "This is Jim.",
      "translation": {
        "text": "这是吉姆。"
      }
    },
    {
      "id": "s023",
      "text": "He's our office assistant.",
      "translation": {
        "text": "他是我们的办公室助理。"
      }
    }
  ],
