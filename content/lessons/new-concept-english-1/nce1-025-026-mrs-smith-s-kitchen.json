    {
      "id": "s001",
      "text": "Lesson 25.",
      "translation": {
        "text": "第25课。"
      }
    },
    {
      "id": "s002",
      "text": "Mrs.",
      "translation": {
        "text": "史密斯太太的"
      }
    },
    {
      "id": "s003",
      "text": "Smith's Kitchen.",
      "translation": {
        "text": "厨房。"
      }
    },
    {
      "id": "s004",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s005",
      "text": "What color is the electric cooker?",
      "translation": {
        "text": "电灶是什么颜色的？"
      }
    },
    {
      "id": "s006",
      "text": "Mrs.",
      "translation": {
        "text": "史密斯太太的"
      }
    },
    {
      "id": "s007",
      "text": "Smith's is small.",
      "translation": {
        "text": "厨房很小。"
      }
    },
    {
      "id": "s008",
      "text": "There is a refrigerator in the kitchen.",
      "translation": {
        "text": "厨房里有一台冰箱。"
      }
    },
    {
      "id": "s009",
      "text": "The refrigerator is white.",
      "translation": {
        "text": "冰箱是白色的。"
      }
    },
    {
      "id": "s010",
      "text": "It is on the right.",
      "translation": {
        "text": "它在右边。"
      }
    },
    {
      "id": "s011",
      "text": "There is an electric cooker in the kitchen.",
      "translation": {
        "text": "厨房里有一个电灶。"
      }
    },
    {
      "id": "s012",
      "text": "The cooker is blue.",
      "translation": {
        "text": "电灶是蓝色的。"
      }
    },
    {
      "id": "s013",
      "text": "It is on the left.",
      "translation": {
        "text": "它在左边。"
      }
    },
    {
      "id": "s014",
      "text": "There is a table in the middle of the room.",
      "translation": {
        "text": "房间中央有一张桌子。"
      }
    },
    {
      "id": "s015",
      "text": "There is a bottle on the table.",
      "translation": {
        "text": "桌子上有一个瓶子。"
      }
    },
    {
      "id": "s016",
      "text": "The bottle is empty.",
      "translation": {
        "text": "瓶子是空的。"
      }
    },
    {
      "id": "s017",
      "text": "There is a cup on the table too.",
      "translation": {
        "text": "桌子上还有一只杯子。"
      }
    },
    {
      "id": "s018",
      "text": "The cup is clean.",
      "translation": {
        "text": "杯子很干净。"
      }
    }
  ],
