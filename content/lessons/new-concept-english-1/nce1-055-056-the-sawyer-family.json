    {
      "id": "s001",
      "text": "Lesson 55.",
      "translation": {
        "text": "第55课。"
      }
    },
    {
      "id": "s002",
      "text": "The Sawyer Family.",
      "translation": {
        "text": "索耶一家。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "When do the children do their homework?",
      "translation": {
        "text": "孩子们什么时候做作业？"
      }
    },
    {
      "id": "s005",
      "text": "The Sawyers live at 87 King Street.",
      "translation": {
        "text": "索耶一家住在国王街87号。"
      }
    },
    {
      "id": "s006",
      "text": "In the morning, Mr.",
      "translation": {
        "text": "早晨，索耶先生"
      }
    },
    {
      "id": "s007",
      "text": "Sawyer goes to work, and the children go to school.",
      "translation": {
        "text": "索耶先生去上班，孩子们去上学。"
      }
    },
    {
      "id": "s008",
      "text": "Their father takes them to school every day.",
      "translation": {
        "text": "他们的父亲每天送他们上学。"
      }
    },
    {
      "id": "s009",
      "text": "Mrs.",
      "translation": {
        "text": "索耶太太"
      }
    },
    {
      "id": "s010",
      "text": "Sawyer stays at home every day.",
      "translation": {
        "text": "索耶太太每天待在家里。"
      }
    },
    {
      "id": "s011",
      "text": "She does the housework.",
      "translation": {
        "text": "她料理家务。"
      }
    },
    {
      "id": "s012",
      "text": "She always eats her lunch at noon.",
      "translation": {
        "text": "她总是在中午吃午饭。"
      }
    },
    {
      "id": "s013",
      "text": "In the afternoon, she usually sees her friends.",
      "translation": {
        "text": "下午，她通常会见朋友。"
      }
    },
    {
      "id": "s014",
      "text": "They often drink tea together.",
      "translation": {
        "text": "她们经常一起喝茶。"
      }
    },
    {
      "id": "s015",
      "text": "In the evening, the children come home from school.",
      "translation": {
        "text": "傍晚，孩子们放学回家。"
      }
    },
    {
      "id": "s016",
      "text": "They arrive home early.",
      "translation": {
        "text": "他们到家很早。"
      }
    },
    {
      "id": "s017",
      "text": "Mr.",
      "translation": {
        "text": "索耶先生"
      }
    },
    {
      "id": "s018",
      "text": "Sawyer comes home from work.",
      "translation": {
        "text": "索耶先生下班回家。"
      }
    },
    {
      "id": "s019",
      "text": "He arrives home late.",
      "translation": {
        "text": "他到家很晚。"
      }
    },
    {
      "id": "s020",
      "text": "At night, the children always do their homework.",
      "translation": {
        "text": "晚上，孩子们总是做作业。"
      }
    },
    {
      "id": "s021",
      "text": "Then they go to bed.",
      "translation": {
        "text": "然后他们上床睡觉。"
      }
    },
    {
      "id": "s022",
      "text": "Mr.",
      "translation": {
        "text": "索耶先生"
      }
    },
    {
      "id": "s023",
      "text": "Sawyer usually reads his newspaper, but sometimes he and his wife watch television.",
      "translation": {
        "text": "索耶先生通常看报纸，但有时他和妻子一起看电视。"
      }
    }
  ],
