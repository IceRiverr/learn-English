    {
      "id": "s001",
      "text": "Lesson 3.",
      "translation": {
        "text": "第3课。"
      }
    },
    {
      "id": "s002",
      "text": "Sorry, Sir.",
      "translation": {
        "text": "对不起，先生。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "Does the man get his umbrella back?",
      "translation": {
        "text": "这位男士拿回自己的雨伞了吗？"
      }
    },
    {
      "id": "s005",
      "text": "My coat and my umbrella, please.",
      "translation": {
        "text": "请把我的大衣和雨伞给我。"
      }
    },
    {
      "id": "s006",
      "text": "Here is my ticket.",
      "translation": {
        "text": "这是我的牌子。"
      }
    },
    {
      "id": "s007",
      "text": "Thank you, Sir.",
      "translation": {
        "text": "谢谢您，先生。"
      }
    },
    {
      "id": "s008",
      "text": "Number 5.",
      "translation": {
        "text": "5号。"
      }
    },
    {
      "id": "s009",
      "text": "Here's your umbrella and your coat.",
      "translation": {
        "text": "这是您的雨伞和大衣。"
      }
    },
    {
      "id": "s010",
      "text": "This is not my umbrella.",
      "translation": {
        "text": "这不是我的雨伞。"
      }
    },
    {
      "id": "s011",
      "text": "Sorry, Sir.",
      "translation": {
        "text": "对不起，先生。"
      }
    },
    {
      "id": "s012",
      "text": "Is this your umbrella?",
      "translation": {
        "text": "这是您的雨伞吗？"
      }
    },
    {
      "id": "s013",
      "text": "No, it isn't.",
      "translation": {
        "text": "不，不是。"
      }
    },
    {
      "id": "s014",
      "text": "Is this it?",
      "translation": {
        "text": "是这把吗？"
      }
    },
    {
      "id": "s015",
      "text": "Yes, it is.",
      "translation": {
        "text": "是的，是这把。"
      }
    },
    {
      "id": "s016",
      "text": "Thank you very much.",
      "translation": {
        "text": "非常感谢。"
      }
    }
  ],
