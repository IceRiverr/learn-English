  "segments": [
    {
      "id": "s001",
      "text": "Lesson 101.",
      "translation": {
        "text": "第101课。"
      }
    },
    {
      "id": "s002",
      "text": "A Card From Jimmy.",
      "translation": {
        "text": "吉米寄来的明信片。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "Does grandmother seem pleased to get a card from Jimmy?",
      "translation": {
        "text": "祖母收到吉米的明信片后似乎高兴吗？"
      }
    },
    {
      "id": "s005",
      "text": "Why?",
      "translation": {
        "text": "为什么？"
      }
    },
    {
      "id": "s006",
      "text": "Why not?",
      "translation": {
        "text": "为什么不高兴？"
      }
    },
    {
      "id": "s007",
      "text": "Read Jimmy's card to me, please. I have just arrived in Scotland, and I'm staying at a youth hostel.",
      "translation": {
        "text": "请把吉米的明信片读给我听。“我刚到苏格兰，现在住在一家青年旅舍。”"
      }
    },
    {
      "id": "s008",
      "text": "Eh?",
      "translation": {
        "text": "什么？"
      }
    },
    {
      "id": "s009",
      "text": "He says he's just arrived in Scotland.",
      "translation": {
        "text": "他说他刚到苏格兰。"
      }
    },
    {
      "id": "s010",
      "text": "He says he's staying at a youth hostel.",
      "translation": {
        "text": "他说他正住在一家青年旅舍。"
      }
    },
    {
      "id": "s011",
      "text": "You know, he's a member of the YHA.",
      "translation": {
        "text": "你知道，他是青年旅舍协会的会员。"
      }
    },
    {
      "id": "s012",
      "text": "The what?",
      "translation": {
        "text": "什么协会？"
      }
    },
    {
      "id": "s013",
      "text": "The YHA, Mum.",
      "translation": {
        "text": "青年旅舍协会，妈妈。"
      }
    },
    {
      "id": "s014",
      "text": "The Youth Hostels Association.",
      "translation": {
        "text": "青年旅舍协会。"
      }
    },
    {
      "id": "s015",
      "text": "What else does he say?",
      "translation": {
        "text": "他还说了什么？"
      }
    },
    {
      "id": "s016",
      "text": "I'll write a letter soon.",
      "translation": {
        "text": "“我很快会写信。"
      }
    },
    {
      "id": "s017",
      "text": "I hope you are all well.",
      "translation": {
        "text": "希望你们都好。”"
      }
    },
    {
      "id": "s018",
      "text": "What?",
      "translation": {
        "text": "什么？"
      }
    },
    {
      "id": "s019",
      "text": "Speak up, Penny.",
      "translation": {
        "text": "大声点，彭妮。"
      }
    },
    {
      "id": "s020",
      "text": "I'm afraid I can't hear you.",
      "translation": {
        "text": "恐怕我听不见。"
      }
    },
    {
      "id": "s021",
      "text": "He says he'll write a letter soon.",
      "translation": {
        "text": "他说他很快会写信。"
      }
    },
    {
      "id": "s022",
      "text": "He hopes we are all well.",
      "translation": {
        "text": "他希望我们都好。"
      }
    },
    {
      "id": "s023",
      "text": "Love, Jimmy.",
      "translation": {
        "text": "爱你们的吉米。"
      }
    },
    {
      "id": "s024",
      "text": "Is that all?",
      "translation": {
        "text": "就这些吗？"
      }
    },
    {
      "id": "s025",
      "text": "He doesn't say very much, does he?",
      "translation": {
        "text": "他说得不多，是吧？"
      }
    },
    {
      "id": "s026",
      "text": "He can't write very much on a card, Mum.",
      "translation": {
        "text": "明信片上写不了太多，妈妈。"
      }
    }
  ],
