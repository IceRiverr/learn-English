  "segments": [
    {
      "id": "s001",
      "text": "Lesson 11.",
      "translation": {
        "text": "第11课。"
      }
    },
    {
      "id": "s002",
      "text": "Is This Your Shirt?",
      "translation": {
        "text": "这是你的衬衫吗？"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "Whose shirt is white?",
      "translation": {
        "text": "谁的衬衫是白色的？"
      }
    },
    {
      "id": "s005",
      "text": "Whose shirt is that?",
      "translation": {
        "text": "那是谁的衬衫？"
      }
    },
    {
      "id": "s006",
      "text": "Is this your shirt, Dave?",
      "translation": {
        "text": "戴夫，这是你的衬衫吗？"
      }
    },
    {
      "id": "s007",
      "text": "No, sir.",
      "translation": {
        "text": "不是，先生。"
      }
    },
    {
      "id": "s008",
      "text": "It's not my shirt.",
      "translation": {
        "text": "这不是我的衬衫。"
      }
    },
    {
      "id": "s009",
      "text": "This is my shirt.",
      "translation": {
        "text": "这件才是我的衬衫。"
      }
    },
    {
      "id": "s010",
      "text": "My shirt's blue.",
      "translation": {
        "text": "我的衬衫是蓝色的。"
      }
    },
    {
      "id": "s011",
      "text": "Is this shirt Tim's?",
      "translation": {
        "text": "这件衬衫是蒂姆的吗？"
      }
    },
    {
      "id": "s012",
      "text": "Perhaps it is, sir.",
      "translation": {
        "text": "也许是他的，先生。"
      }
    },
    {
      "id": "s013",
      "text": "Tim's shirt's white.",
      "translation": {
        "text": "蒂姆的衬衫是白色的。"
      }
    },
    {
      "id": "s014",
      "text": "Tim!",
      "translation": {
        "text": "蒂姆！"
      }
    },
    {
      "id": "s015",
      "text": "Yes, sir?",
      "translation": {
        "text": "什么事，先生？"
      }
    },
    {
      "id": "s016",
      "text": "Is this your shirt?",
      "translation": {
        "text": "这是你的衬衫吗？"
      }
    },
    {
      "id": "s017",
      "text": "Yes, sir.",
      "translation": {
        "text": "是的，先生。"
      }
    },
    {
      "id": "s018",
      "text": "Here you are.",
      "translation": {
        "text": "给你。"
      }
    },
    {
      "id": "s019",
      "text": "Catch!",
      "translation": {
        "text": "接着！"
      }
    },
    {
      "id": "s020",
      "text": "Thank you, sir.",
      "translation": {
        "text": "谢谢您，先生。"
      }
    }
  ],
