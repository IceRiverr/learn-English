  "segments": [
    {
      "id": "s001",
      "text": "Lesson 71.",
      "translation": {
        "text": "第71课。"
      }
    },
    {
      "id": "s002",
      "text": "He's Awful.",
      "translation": {
        "text": "他讨厌透了。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "How did Pauline answer the telephone at nine o'clock?",
      "translation": {
        "text": "九点钟时，波琳是怎样接电话的？"
      }
    },
    {
      "id": "s005",
      "text": "What's Ron Marston like, Pauline?",
      "translation": {
        "text": "波琳，罗恩·马斯顿这个人怎么样？"
      }
    },
    {
      "id": "s006",
      "text": "He's awful!",
      "translation": {
        "text": "他讨厌透了！"
      }
    },
    {
      "id": "s007",
      "text": "He telephoned me four times yesterday, and three times the day before yesterday.",
      "translation": {
        "text": "他昨天给我打了四次电话，前天打了三次。"
      }
    },
    {
      "id": "s008",
      "text": "He telephoned the office yesterday morning and yesterday afternoon.",
      "translation": {
        "text": "他昨天上午和下午都给办公室打了电话。"
      }
    },
    {
      "id": "s009",
      "text": "My boss answered the telephone.",
      "translation": {
        "text": "我的老板接了电话。"
      }
    },
    {
      "id": "s010",
      "text": "What did your boss say to him?",
      "translation": {
        "text": "你的老板对他说了什么？"
      }
    },
    {
      "id": "s011",
      "text": "He said, Pauline is typing letters.",
      "translation": {
        "text": "他说：“波琳正在打信。"
      }
    },
    {
      "id": "s012",
      "text": "She can't speak to you now.",
      "translation": {
        "text": "她现在不能和你说话。”"
      }
    },
    {
      "id": "s013",
      "text": "Then I arrived home at six o'clock yesterday evening.",
      "translation": {
        "text": "后来我昨晚六点钟到家。"
      }
    },
    {
      "id": "s014",
      "text": "He telephoned again, but I didn't answer the phone.",
      "translation": {
        "text": "他又打来电话，但我没有接。"
      }
    },
    {
      "id": "s015",
      "text": "Did he telephone again last night?",
      "translation": {
        "text": "他昨晚又打电话了吗？"
      }
    },
    {
      "id": "s016",
      "text": "Yes, he did.",
      "translation": {
        "text": "是的，打了。"
      }
    },
    {
      "id": "s017",
      "text": "He telephoned at nine o'clock.",
      "translation": {
        "text": "他九点钟打来的。"
      }
    },
    {
      "id": "s018",
      "text": "What did you say to him?",
      "translation": {
        "text": "你对他说了什么？"
      }
    },
    {
      "id": "s019",
      "text": "I said, this is Pauline's mother.",
      "translation": {
        "text": "我说：“我是波琳的母亲。"
      }
    },
    {
      "id": "s020",
      "text": "Please don't telephone my daughter again.",
      "translation": {
        "text": "请别再给我女儿打电话了。”"
      }
    },
    {
      "id": "s021",
      "text": "Did he telephone again?",
      "translation": {
        "text": "他后来又打了吗？"
      }
    },
    {
      "id": "s022",
      "text": "No, he didn't.",
      "translation": {
        "text": "不，没有。"
      }
    }
  ],
