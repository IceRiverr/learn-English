      "id": "s001",
      "text": "Lesson 7.",
      "translation": {
        "text": "第7课。"
      }
    },
    {
      "id": "s002",
      "text": "Are You a Teacher?",
      "translation": {
        "text": "你是教师吗？"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "What is Robert's job?",
      "translation": {
        "text": "罗伯特是做什么工作的？"
      }
    },
    {
      "id": "s005",
      "text": "I am a new student.",
      "translation": {
        "text": "我是一名新学生。"
      }
    },
    {
      "id": "s006",
      "text": "My name's Robert.",
      "translation": {
        "text": "我叫罗伯特。"
      }
    },
    {
      "id": "s007",
      "text": "Nice to meet you.",
      "translation": {
        "text": "很高兴见到你。"
      }
    },
    {
      "id": "s008",
      "text": "My name's Sophie.",
      "translation": {
        "text": "我叫索菲。"
      }
    },
    {
      "id": "s009",
      "text": "Are you French?",
      "translation": {
        "text": "你是法国人吗？"
      }
    },
    {
      "id": "s010",
      "text": "Yes, I am.",
      "translation": {
        "text": "是的，我是。"
      }
    },
    {
      "id": "s011",
      "text": "Are you French too?",
      "translation": {
        "text": "你也是法国人吗？"
      }
    },
    {
      "id": "s012",
      "text": "No, I am not.",
      "translation": {
        "text": "不，我不是。"
      }
    },
    {
      "id": "s013",
      "text": "What nationality are you?",
      "translation": {
        "text": "你是哪国人？"
      }
    },
    {
      "id": "s014",
      "text": "I'm Italian.",
      "translation": {
        "text": "我是意大利人。"
      }
    },
    {
      "id": "s015",
      "text": "Are you a teacher?",
      "translation": {
        "text": "你是教师吗？"
      }
    },
    {
      "id": "s016",
      "text": "No, I'm not.",
      "translation": {
        "text": "不，我不是。"
      }
    },
    {
      "id": "s017",
      "text": "What's your job?",
      "translation": {
        "text": "你是做什么工作的？"
      }
    },
    {
      "id": "s018",
      "text": "I'm a keyboard operator.",
      "translation": {
        "text": "我是一名电脑录入员。"
      }
    },
    {
      "id": "s019",
      "text": "What's your job?",
      "translation": {
        "text": "你是做什么工作的？"
      }
    },
    {
      "id": "s020",
      "text": "I'm an engineer.",
      "translation": {
        "text": "我是一名工程师。"
      }
    }
  ],
