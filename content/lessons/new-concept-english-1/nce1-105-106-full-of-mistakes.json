  "segments": [
    {
      "id": "s001",
      "text": "Lesson 105.",
      "translation": {
        "text": "第105课。"
      }
    },
    {
      "id": "s002",
      "text": "Full of Mistakes.",
      "translation": {
        "text": "错误百出。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "What was Sandra's present?",
      "translation": {
        "text": "桑德拉得到的礼物是什么？"
      }
    },
    {
      "id": "s005",
      "text": "Where's Sandra, Bob?",
      "translation": {
        "text": "鲍勃，桑德拉在哪里？"
      }
    },
    {
      "id": "s006",
      "text": "I want her.",
      "translation": {
        "text": "我要找她。"
      }
    },
    {
      "id": "s007",
      "text": "Do you want to speak to her?",
      "translation": {
        "text": "您想和她说话吗？"
      }
    },
    {
      "id": "s008",
      "text": "Yes, I do.",
      "translation": {
        "text": "是的。"
      }
    },
    {
      "id": "s009",
      "text": "I want her to come to my office.",
      "translation": {
        "text": "我要她到我的办公室来。"
      }
    },
    {
      "id": "s010",
      "text": "Tell her to come at once.",
      "translation": {
        "text": "告诉她马上过来。"
      }
    },
    {
      "id": "s011",
      "text": "Did you want to see me?",
      "translation": {
        "text": "您找我吗？"
      }
    },
    {
      "id": "s012",
      "text": "Ah, yes, Sandra.",
      "translation": {
        "text": "啊，是的，桑德拉。"
      }
    },
    {
      "id": "s013",
      "text": "How do you spell intelligent?",
      "translation": {
        "text": "intelligent这个词怎么拼？"
      }
    },
    {
      "id": "s014",
      "text": "Can you tell me?",
      "translation": {
        "text": "你能告诉我吗？"
      }
    },
    {
      "id": "s015",
      "text": "I-N-T-E-L-L-I-G-E-N-T.",
      "translation": {
        "text": "I-N-T-E-L-L-I-G-E-N-T。"
      }
    },
    {
      "id": "s016",
      "text": "That's right.",
      "translation": {
        "text": "对。"
      }
    },
    {
      "id": "s017",
      "text": "You've typed it with only one L.",
      "translation": {
        "text": "你只打了一个L。"
      }
    },
    {
      "id": "s018",
      "text": "This letter's full of mistakes.",
      "translation": {
        "text": "这封信错误百出。"
      }
    },
    {
      "id": "s019",
      "text": "I want you to type it again.",
      "translation": {
        "text": "我要你重新打一遍。"
      }
    },
    {
      "id": "s020",
      "text": "Yes, I'll do that.",
      "translation": {
        "text": "好的，我会重打。"
      }
    },
    {
      "id": "s021",
      "text": "I'm sorry about that.",
      "translation": {
        "text": "这件事很抱歉。"
      }
    },
    {
      "id": "s022",
      "text": "And here's a little present for you.",
      "translation": {
        "text": "这里还有一份小礼物送给你。"
      }
    },
    {
      "id": "s023",
      "text": "What is it?",
      "translation": {
        "text": "是什么？"
      }
    },
    {
      "id": "s024",
      "text": "It's a dictionary.",
      "translation": {
        "text": "一本词典。"
      }
    },
    {
      "id": "s025",
      "text": "I hope it'll help you.",
      "translation": {
        "text": "希望它能帮到你。"
      }
    }
  ],
