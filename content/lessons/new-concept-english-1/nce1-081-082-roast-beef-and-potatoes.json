  "segments": [
    {
      "id": "s001",
      "text": "Lesson 81–Roast Beef and Potatoes.",
      "translation": {
        "text": "第81课——烤牛肉和土豆。"
      }
    },
    {
      "id": "s002",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s003",
      "text": "Why is Carol disappointed?",
      "translation": {
        "text": "卡罗尔为什么感到失望？"
      }
    },
    {
      "id": "s004",
      "text": "Hi, Carol.",
      "translation": {
        "text": "你好，卡罗尔。"
      }
    },
    {
      "id": "s005",
      "text": "Where's Tom?",
      "translation": {
        "text": "汤姆在哪里？"
      }
    },
    {
      "id": "s006",
      "text": "He's upstairs.",
      "translation": {
        "text": "他在楼上。"
      }
    },
    {
      "id": "s007",
      "text": "He's having a bath.",
      "translation": {
        "text": "他正在洗澡。"
      }
    },
    {
      "id": "s008",
      "text": "Tom?",
      "translation": {
        "text": "汤姆？"
      }
    },
    {
      "id": "s009",
      "text": "Yes.",
      "translation": {
        "text": "什么事？"
      }
    },
    {
      "id": "s010",
      "text": "Sam's here.",
      "translation": {
        "text": "萨姆来了。"
      }
    },
    {
      "id": "s011",
      "text": "I'm nearly ready.",
      "translation": {
        "text": "我马上就好。"
      }
    },
    {
      "id": "s012",
      "text": "Hello, Sam.",
      "translation": {
        "text": "你好，萨姆。"
      }
    },
    {
      "id": "s013",
      "text": "Have a cigarette.",
      "translation": {
        "text": "来支香烟吧。"
      }
    },
    {
      "id": "s014",
      "text": "No, thanks, Tom.",
      "translation": {
        "text": "不了，谢谢，汤姆。"
      }
    },
    {
      "id": "s015",
      "text": "Have a glass of whiskey, then.",
      "translation": {
        "text": "那就喝杯威士忌吧。"
      }
    },
    {
      "id": "s016",
      "text": "Okay, thanks.",
      "translation": {
        "text": "好的，谢谢。"
      }
    },
    {
      "id": "s017",
      "text": "Is dinner ready? It's nearly ready.",
      "translation": {
        "text": "晚饭好了吗？快好了。"
      }
    },
    {
      "id": "s018",
      "text": "We can have dinner at seven o'clock.",
      "translation": {
        "text": "我们七点钟可以吃晚饭。"
      }
    },
    {
      "id": "s019",
      "text": "Sam and I had lunch together today.",
      "translation": {
        "text": "萨姆和我今天一起吃了午饭。"
      }
    },
    {
      "id": "s020",
      "text": "We went to a restaurant.",
      "translation": {
        "text": "我们去了一家餐馆。"
      }
    },
    {
      "id": "s021",
      "text": "What did you have?",
      "translation": {
        "text": "你们吃了什么？"
      }
    },
    {
      "id": "s022",
      "text": "We had roast beef and potatoes.",
      "translation": {
        "text": "我们吃了烤牛肉和土豆。"
      }
    },
    {
      "id": "s023",
      "text": "Oh!",
      "translation": {
        "text": "哦！"
      }
    },
    {
      "id": "s024",
      "text": "What's the matter, Carol?",
      "translation": {
        "text": "怎么了，卡罗尔？"
      }
    },
    {
      "id": "s025",
      "text": "Well, you're going to have roast beef and potatoes again tonight.",
      "translation": {
        "text": "嗯，今晚你们又要吃烤牛肉和土豆了。"
      }
    }
  ],
