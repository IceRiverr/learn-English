  "segments": [
    {
      "id": "s001",
      "text": "Lesson 61.",
      "translation": {
        "text": "第61课。"
      }
    },
    {
      "id": "s002",
      "text": "A Bad Cold.",
      "translation": {
        "text": "重感冒。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "What is good news for Jimmy?",
      "translation": {
        "text": "对吉米来说，什么是好消息？"
      }
    },
    {
      "id": "s005",
      "text": "Where's Jimmy?",
      "translation": {
        "text": "吉米在哪里？"
      }
    },
    {
      "id": "s006",
      "text": "He's in bed.",
      "translation": {
        "text": "他躺在床上。"
      }
    },
    {
      "id": "s007",
      "text": "What's the matter with him?",
      "translation": {
        "text": "他怎么了？"
      }
    },
    {
      "id": "s008",
      "text": "He feels ill.",
      "translation": {
        "text": "他觉得不舒服。"
      }
    },
    {
      "id": "s009",
      "text": "He looks ill.",
      "translation": {
        "text": "他看起来病了。"
      }
    },
    {
      "id": "s010",
      "text": "We must call the doctor.",
      "translation": {
        "text": "我们必须叫医生。"
      }
    },
    {
      "id": "s011",
      "text": "Yes, we must.",
      "translation": {
        "text": "是的，必须叫。"
      }
    },
    {
      "id": "s012",
      "text": "Can you remember the doctor's telephone number?",
      "translation": {
        "text": "你记得医生的电话号码吗？"
      }
    },
    {
      "id": "s013",
      "text": "Yes.",
      "translation": {
        "text": "记得。"
      }
    },
    {
      "id": "s014",
      "text": "It's 0-9-7-5-4.",
      "translation": {
        "text": "是0-9-7-5-4。"
      }
    },
    {
      "id": "s015",
      "text": "Open your mouth, Jimmy.",
      "translation": {
        "text": "张开嘴，吉米。"
      }
    },
    {
      "id": "s016",
      "text": "Show me your tongue.",
      "translation": {
        "text": "让我看看你的舌头。"
      }
    },
    {
      "id": "s017",
      "text": "Say, ah.",
      "translation": {
        "text": "说“啊”。"
      }
    },
    {
      "id": "s018",
      "text": "What's the matter with him, doctor?",
      "translation": {
        "text": "医生，他怎么了？"
      }
    },
    {
      "id": "s019",
      "text": "He has a bad cold, Mr. Williams,",
      "translation": {
        "text": "威廉斯先生，他得了重感冒，"
      }
    },
    {
      "id": "s020",
      "text": "so he must stay in bed for a week.",
      "translation": {
        "text": "所以他必须卧床一周。"
      }
    },
    {
      "id": "s021",
      "text": "That's good news for Jimmy.",
      "translation": {
        "text": "这对吉米来说是个好消息。"
      }
    },
    {
      "id": "s022",
      "text": "Good news?",
      "translation": {
        "text": "好消息？"
      }
    },
    {
      "id": "s023",
      "text": "Why?",
      "translation": {
        "text": "为什么？"
      }
    },
    {
      "id": "s024",
      "text": "Because he doesn't like school.",
      "translation": {
        "text": "因为他不喜欢上学。"
      }
    }
  ],
