    {
      "id": "s001",
      "text": "Lesson 29–Come In, Amy.",
      "translation": {
        "text": "第29课——进来吧，艾米。"
      }
    },
    {
      "id": "s002",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s003",
      "text": "How must Amy clean the floor?",
      "translation": {
        "text": "艾米必须怎样清扫地板？"
      }
    },
    {
      "id": "s004",
      "text": "Come in, Amy.",
      "translation": {
        "text": "进来吧，艾米。"
      }
    },
    {
      "id": "s005",
      "text": "Shut the door, please.",
      "translation": {
        "text": "请把门关上。"
      }
    },
    {
      "id": "s006",
      "text": "This bedroom's very untidy.",
      "translation": {
        "text": "这间卧室太不整洁了。"
      }
    },
    {
      "id": "s007",
      "text": "What must I do, Mrs.",
      "translation": {
        "text": "我必须做什么，"
      }
    },
    {
      "id": "s008",
      "text": "Jones?",
      "translation": {
        "text": "琼斯太太？"
      }
    },
    {
      "id": "s009",
      "text": "Open the window and air the room.",
      "translation": {
        "text": "打开窗户，给房间通通风。"
      }
    },
    {
      "id": "s010",
      "text": "Then put these clothes in the wardrobe.",
      "translation": {
        "text": "然后把这些衣服放进衣柜里。"
      }
    },
    {
      "id": "s011",
      "text": "Then make the bed.",
      "translation": {
        "text": "接着整理床铺。"
      }
    },
    {
      "id": "s012",
      "text": "Dust the dressing table.",
      "translation": {
        "text": "给梳妆台掸灰。"
      }
    },
    {
      "id": "s013",
      "text": "Then sweep the floor.",
      "translation": {
        "text": "然后扫地。"
      }
    }
  ],
