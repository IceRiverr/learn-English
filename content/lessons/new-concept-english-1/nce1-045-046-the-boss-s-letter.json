  "segments": [
    {
      "id": "s001",
      "text": "Lesson 45.",
      "translation": {
        "text": "第45课。"
      }
    },
    {
      "id": "s002",
      "text": "The Boss's Letter.",
      "translation": {
        "text": "老板的信。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "Why can't Pamela type the letter?",
      "translation": {
        "text": "帕梅拉为什么不能把这封信打出来？"
      }
    },
    {
      "id": "s005",
      "text": "Can you come here a minute, please, Bob?",
      "translation": {
        "text": "鲍勃，请你来一下好吗？"
      }
    },
    {
      "id": "s006",
      "text": "Yes, sir.",
      "translation": {
        "text": "好的，先生。"
      }
    },
    {
      "id": "s007",
      "text": "Where's Pamela?",
      "translation": {
        "text": "帕梅拉在哪里？"
      }
    },
    {
      "id": "s008",
      "text": "She's next door.",
      "translation": {
        "text": "她在隔壁。"
      }
    },
    {
      "id": "s009",
      "text": "She's in her office, sir.",
      "translation": {
        "text": "她在自己的办公室里，先生。"
      }
    },
    {
      "id": "s010",
      "text": "Can she type this letter for me?",
      "translation": {
        "text": "她能替我把这封信打出来吗？"
      }
    },
    {
      "id": "s011",
      "text": "Ask her, please.",
      "translation": {
        "text": "请去问问她。"
      }
    },
    {
      "id": "s012",
      "text": "Yes, sir.",
      "translation": {
        "text": "好的，先生。"
      }
    },
    {
      "id": "s013",
      "text": "Can you type this letter for the boss, Pamela?",
      "translation": {
        "text": "帕梅拉，你能替老板把这封信打出来吗？"
      }
    },
    {
      "id": "s014",
      "text": "Yes, of course I can.",
      "translation": {
        "text": "能，我当然能。"
      }
    },
    {
      "id": "s015",
      "text": "Here you are.",
      "translation": {
        "text": "给你。"
      }
    },
    {
      "id": "s016",
      "text": "Thank you, Bob.",
      "translation": {
        "text": "谢谢你，鲍勃。"
      }
    },
    {
      "id": "s017",
      "text": "Bob?",
      "translation": {
        "text": "鲍勃？"
      }
    },
    {
      "id": "s018",
      "text": "Yes, what's the matter?",
      "translation": {
        "text": "怎么了？"
      }
    },
    {
      "id": "s019",
      "text": "I can't type this letter.",
      "translation": {
        "text": "这封信我打不了。"
      }
    },
    {
      "id": "s020",
      "text": "I can't read it.",
      "translation": {
        "text": "我看不懂。"
      }
    },
    {
      "id": "s021",
      "text": "The Boss's handwriting is terrible.",
      "translation": {
        "text": "老板的字迹太糟糕了。"
      }
    }
  ],
