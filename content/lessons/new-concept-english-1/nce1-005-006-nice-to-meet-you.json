      "id": "s001",
      "text": "Lesson 5– Nice to Meet You.",
      "translation": {
        "text": "第5课——很高兴见到你。"
      }
    },
    {
      "id": "s002",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s003",
      "text": "Is Chang-woo Chinese?",
      "translation": {
        "text": "昌宇是中国人吗？"
      }
    },
    {
      "id": "s004",
      "text": "Good morning.",
      "translation": {
        "text": "早上好。"
      }
    },
    {
      "id": "s005",
      "text": "Good morning, Mr.",
      "translation": {
        "text": "早上好，"
      }
    },
    {
      "id": "s006",
      "text": "Blake.",
      "translation": {
        "text": "布莱克先生。"
      }
    },
    {
      "id": "s007",
      "text": "This is Miss Sophie DuPont.",
      "translation": {
        "text": "这位是索菲·杜邦小姐。"
      }
    },
    {
      "id": "s008",
      "text": "Sophie is a new student.",
      "translation": {
        "text": "索菲是一名新学生。"
      }
    },
    {
      "id": "s009",
      "text": "She is French.",
      "translation": {
        "text": "她是法国人。"
      }
    },
    {
      "id": "s010",
      "text": "Sophie, this is Hans.",
      "translation": {
        "text": "索菲，这位是汉斯。"
      }
    },
    {
      "id": "s011",
      "text": "He is German.",
      "translation": {
        "text": "他是德国人。"
      }
    },
    {
      "id": "s012",
      "text": "Nice to meet you.",
      "translation": {
        "text": "很高兴见到你。"
      }
    },
    {
      "id": "s013",
      "text": "And this is Naoko.",
      "translation": {
        "text": "这位是直子。"
      }
    },
    {
      "id": "s014",
      "text": "She's Japanese.",
      "translation": {
        "text": "她是日本人。"
      }
    },
    {
      "id": "s015",
      "text": "Nice to meet you.",
      "translation": {
        "text": "很高兴见到你。"
      }
    },
    {
      "id": "s016",
      "text": "And this is Chang-woo.",
      "translation": {
        "text": "这位是昌宇。"
      }
    },
    {
      "id": "s017",
      "text": "He's Korean.",
      "translation": {
        "text": "他是韩国人。"
      }
    },
    {
      "id": "s018",
      "text": "Nice to meet you.",
      "translation": {
        "text": "很高兴见到你。"
      }
    },
    {
      "id": "s019",
      "text": "And this is Lu Ming.",
      "translation": {
        "text": "这位是鲁明。"
      }
    },
    {
      "id": "s020",
      "text": "He's Chinese.",
      "translation": {
        "text": "他是中国人。"
      }
    },
    {
      "id": "s021",
      "text": "Nice to meet you.",
      "translation": {
        "text": "很高兴见到你。"
      }
    },
    {
      "id": "s022",
      "text": "And this is Xiaohui.",
      "translation": {
        "text": "这位是晓惠。"
      }
    },
    {
      "id": "s023",
      "text": "She's Chinese too.",
      "translation": {
        "text": "她也是中国人。"
      }
    },
    {
      "id": "s024",
      "text": "Nice to meet you.",
      "translation": {
        "text": "很高兴见到你。"
      }
    }
