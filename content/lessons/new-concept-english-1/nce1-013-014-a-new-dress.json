    {
      "id": "s001",
      "text": "Lesson 13.",
      "translation": {
        "text": "第13课。"
      }
    },
    {
      "id": "s002",
      "text": "A New Dress.",
      "translation": {
        "text": "一件新连衣裙。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "What color is Anna's hat?",
      "translation": {
        "text": "安娜的帽子是什么颜色的？"
      }
    },
    {
      "id": "s005",
      "text": "What color's your new dress?",
      "translation": {
        "text": "你的新连衣裙是什么颜色的？"
      }
    },
    {
      "id": "s006",
      "text": "It's green.",
      "translation": {
        "text": "是绿色的。"
      }
    },
    {
      "id": "s007",
      "text": "Come upstairs and see it.",
      "translation": {
        "text": "上楼来看看吧。"
      }
    },
    {
      "id": "s008",
      "text": "Thank you.",
      "translation": {
        "text": "谢谢。"
      }
    },
    {
      "id": "s009",
      "text": "Look!",
      "translation": {
        "text": "看！"
      }
    },
    {
      "id": "s010",
      "text": "Here it is.",
      "translation": {
        "text": "就是这件。"
      }
    },
    {
      "id": "s011",
      "text": "That's a nice dress.",
      "translation": {
        "text": "这件连衣裙真漂亮。"
      }
    },
    {
      "id": "s012",
      "text": "It's very smart.",
      "translation": {
        "text": "它很时髦。"
      }
    },
    {
      "id": "s013",
      "text": "My hat's new, too.",
      "translation": {
        "text": "我的帽子也是新的。"
      }
    },
    {
      "id": "s014",
      "text": "What color is it?",
      "translation": {
        "text": "是什么颜色的？"
      }
    },
    {
      "id": "s015",
      "text": "It's the same color.",
      "translation": {
        "text": "颜色是一样的。"
      }
    },
    {
      "id": "s016",
      "text": "It's green, too.",
      "translation": {
        "text": "也是绿色的。"
      }
    },
    {
      "id": "s017",
      "text": "That is a lovely hat.",
      "translation": {
        "text": "这顶帽子真可爱。"
      }
    }
  ],
