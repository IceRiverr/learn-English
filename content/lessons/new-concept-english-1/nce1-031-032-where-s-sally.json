    {
      "id": "s001",
      "text": "Lesson 31.",
      "translation": {
        "text": "第31课。"
      }
    },
    {
      "id": "s002",
      "text": "Where's Sally?",
      "translation": {
        "text": "萨莉在哪里？"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "Is the cat climbing the tree?",
      "translation": {
        "text": "猫正在爬树吗？"
      }
    },
    {
      "id": "s005",
      "text": "Where's Sally, Jack?",
      "translation": {
        "text": "杰克，萨莉在哪里？"
      }
    },
    {
      "id": "s006",
      "text": "She's in the garden, Jean.",
      "translation": {
        "text": "她在花园里，琼。"
      }
    },
    {
      "id": "s007",
      "text": "What's she doing?",
      "translation": {
        "text": "她在做什么？"
      }
    },
    {
      "id": "s008",
      "text": "She's sitting under the tree.",
      "translation": {
        "text": "她正坐在树下。"
      }
    },
    {
      "id": "s009",
      "text": "Is Tim in the garden, too?",
      "translation": {
        "text": "蒂姆也在花园里吗？"
      }
    },
    {
      "id": "s010",
      "text": "Yes, he is.",
      "translation": {
        "text": "是的，他在。"
      }
    },
    {
      "id": "s011",
      "text": "He's climbing the tree.",
      "translation": {
        "text": "他正在爬树。"
      }
    },
    {
      "id": "s012",
      "text": "I beg your pardon.",
      "translation": {
        "text": "请再说一遍。"
      }
    },
    {
      "id": "s013",
      "text": "Who's climbing the tree?",
      "translation": {
        "text": "谁在爬树？"
      }
    },
    {
      "id": "s014",
      "text": "Tim is.",
      "translation": {
        "text": "蒂姆。"
      }
    },
    {
      "id": "s015",
      "text": "What about the dog?",
      "translation": {
        "text": "那只狗呢？"
      }
    },
    {
      "id": "s016",
      "text": "The dog's in the garden, too.",
      "translation": {
        "text": "那只狗也在花园里。"
      }
    },
    {
      "id": "s017",
      "text": "It's running across the grass.",
      "translation": {
        "text": "它正跑过草地。"
      }
    },
    {
      "id": "s018",
      "text": "It's running after a cat.",
      "translation": {
        "text": "它正在追一只猫。"
      }
    }
  ],
