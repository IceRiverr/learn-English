  "segments": [
    {
      "id": "s001",
      "text": "Lesson 123.",
      "translation": {
        "text": "第123课。"
      }
    },
    {
      "id": "s002",
      "text": "A Trip to Australia.",
      "translation": {
        "text": "澳大利亚之旅。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "Who is the man with the beard?",
      "translation": {
        "text": "那个留胡子的男人是谁？"
      }
    },
    {
      "id": "s005",
      "text": "Look, Scott!",
      "translation": {
        "text": "看，斯科特！"
      }
    },
    {
      "id": "s006",
      "text": "This is a photograph I took during my trip to Australia.",
      "translation": {
        "text": "这是我去澳大利亚旅行时拍的一张照片。"
      }
    },
    {
      "id": "s007",
      "text": "Let me see it, Mike.",
      "translation": {
        "text": "让我看看，迈克。"
      }
    },
    {
      "id": "s008",
      "text": "This is a good photograph.",
      "translation": {
        "text": "这张照片拍得真好。"
      }
    },
    {
      "id": "s009",
      "text": "Who are these people?",
      "translation": {
        "text": "这些人是谁？"
      }
    },
    {
      "id": "s010",
      "text": "They're people I met during the trip.",
      "translation": {
        "text": "他们是我在旅行途中认识的人。"
      }
    },
    {
      "id": "s011",
      "text": "That's the ship we traveled on.",
      "translation": {
        "text": "那就是我们乘坐的船。"
      }
    },
    {
      "id": "s012",
      "text": "What a beautiful ship!",
      "translation": {
        "text": "多漂亮的船啊！"
      }
    },
    {
      "id": "s013",
      "text": "Who's this?",
      "translation": {
        "text": "这个人是谁？"
      }
    },
    {
      "id": "s014",
      "text": "That's the man I told you about, remember?",
      "translation": {
        "text": "他就是我跟你提过的那个人，还记得吗？"
      }
    },
    {
      "id": "s015",
      "text": "Ah, yes.",
      "translation": {
        "text": "啊，记得。"
      }
    },
    {
      "id": "s016",
      "text": "The one who offered you a job in Australia.",
      "translation": {
        "text": "就是那个请你去澳大利亚工作的人。"
      }
    },
    {
      "id": "s017",
      "text": "That's right.",
      "translation": {
        "text": "没错。"
      }
    },
    {
      "id": "s018",
      "text": "Who's this?",
      "translation": {
        "text": "这个人是谁？"
      }
    },
    {
      "id": "s019",
      "text": "Guess.",
      "translation": {
        "text": "猜猜看。"
      }
    },
    {
      "id": "s020",
      "text": "It's not you, is it?",
      "translation": {
        "text": "不会是你吧？"
      }
    },
    {
      "id": "s021",
      "text": "That's right.",
      "translation": {
        "text": "正是我。"
      }
    },
    {
      "id": "s022",
      "text": "I grew a beard during the trip, but I shaved it off when I came home.",
      "translation": {
        "text": "旅行期间我留了胡子，不过回家后就把它刮掉了。"
      }
    },
    {
      "id": "s023",
      "text": "Why did you shave it off?",
      "translation": {
        "text": "你为什么把胡子刮掉？"
      }
    },
    {
      "id": "s024",
      "text": "My wife didn't like it.",
      "translation": {
        "text": "我妻子不喜欢。"
      }
    }
  ],
