  "segments": [
    {
      "id": "s001",
      "text": "Lesson 77–Terrible Toothache.",
      "translation": {
        "text": "第77课——要命的牙痛。"
      }
    },
    {
      "id": "s001a",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s001b",
      "text": "What time of day is it, do you think? How do you know?",
      "translation": {
        "text": "你认为当时是一天中的什么时间？你是怎么知道的？"
      }
    },
    {
      "id": "s001c",
      "text": "Good morning, Mr. Croft.",
      "translation": {
        "text": "早上好，克罗夫特先生。"
      }
    },
    {
      "id": "s001d",
      "text": "Good morning, nurse. I want to see the dentist, please.",
      "translation": {
        "text": "早上好，护士。我想见牙医。"
      }
    },
    {
      "id": "s002",
      "text": "Do you have an appointment?",
      "translation": {
        "text": "您预约了吗？"
      }
    },
    {
      "id": "s003",
      "text": "No, I don't.",
      "translation": {
        "text": "没有。"
      }
    },
    {
      "id": "s004",
      "text": "Is it urgent?",
      "translation": {
        "text": "很紧急吗？"
      }
    },
    {
      "id": "s005",
      "text": "Yes, it is.",
      "translation": {
        "text": "是的。"
      }
    },
    {
      "id": "s006",
      "text": "It's very urgent.",
      "translation": {
        "text": "非常紧急。"
      }
    },
    {
      "id": "s007",
      "text": "I feel awful.",
      "translation": {
        "text": "我难受极了。"
      }
    },
    {
      "id": "s008",
      "text": "I have a terrible toothache.",
      "translation": {
        "text": "我牙痛得要命。"
      }
    },
    {
      "id": "s009",
      "text": "Can you come at 10 a.m.",
      "translation": {
        "text": "您能在上午十点来吗？"
      }
    },
    {
      "id": "s010",
      "text": "on Monday, April 24th?",
      "translation": {
        "text": "4月24日，星期一。"
      }
    },
    {
      "id": "s011",
      "text": "I must see the dentist now, nurse.",
      "translation": {
        "text": "护士，我现在就必须见牙医。"
      }
    },
    {
      "id": "s012",
      "text": "The dentist is very busy at the moment.",
      "translation": {
        "text": "牙医此刻很忙。"
      }
    },
    {
      "id": "s013",
      "text": "Can you come at 2 p.m.?",
      "translation": {
        "text": "您下午两点来可以吗？"
      }
    },
    {
      "id": "s014",
      "text": "That's very late.",
      "translation": {
        "text": "那太晚了。"
      }
    },
    {
      "id": "s015",
      "text": "Can the dentist see me now?",
      "translation": {
        "text": "牙医现在能给我看吗？"
      }
    },
    {
      "id": "s016",
      "text": "I'm afraid that he can't, Mr.",
      "translation": {
        "text": "恐怕不能，克罗夫特"
      }
    },
    {
      "id": "s017",
      "text": "Croft.",
      "translation": {
        "text": "先生。"
      }
    },
    {
      "id": "s018",
      "text": "Can't you wait till this afternoon?",
      "translation": {
        "text": "您不能等到今天下午吗？"
      }
    },
    {
      "id": "s019",
      "text": "I can wait, but my toothache can't.",
      "translation": {
        "text": "我能等，但我的牙痛等不了。"
      }
    }
  ],
