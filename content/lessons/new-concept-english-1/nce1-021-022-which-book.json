    {
      "id": "s001",
      "text": "Lesson 21.",
      "translation": {
        "text": "第21课。"
      }
    },
    {
      "id": "s002",
      "text": "Which Book.",
      "translation": {
        "text": "哪一本书？"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "Which book does the man want?",
      "translation": {
        "text": "这位男士想要哪一本书？"
      }
    },
    {
      "id": "s005",
      "text": "Give me a book, please, Jane.",
      "translation": {
        "text": "简，请给我一本书。"
      }
    },
    {
      "id": "s006",
      "text": "Which book?",
      "translation": {
        "text": "哪一本？"
      }
    },
    {
      "id": "s007",
      "text": "This one?",
      "translation": {
        "text": "这一本吗？"
      }
    },
    {
      "id": "s008",
      "text": "No, not that one.",
      "translation": {
        "text": "不，不是那一本。"
      }
    },
    {
      "id": "s009",
      "text": "The red one.",
      "translation": {
        "text": "红色的那一本。"
      }
    },
    {
      "id": "s010",
      "text": "This one?",
      "translation": {
        "text": "这一本吗？"
      }
    },
    {
      "id": "s011",
      "text": "Yes, please.",
      "translation": {
        "text": "是的，请给我。"
      }
    },
    {
      "id": "s012",
      "text": "Here you are.",
      "translation": {
        "text": "给你。"
      }
    },
    {
      "id": "s013",
      "text": "Thank you.",
      "translation": {
        "text": "谢谢。"
      }
    }
  ],
