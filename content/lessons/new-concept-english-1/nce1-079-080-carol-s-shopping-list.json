  "segments": [
    {
      "id": "s001",
      "text": "Lesson 79–Carol's Shopping List.",
      "translation": {
        "text": "第79课——卡罗尔的购物单。"
      }
    },
    {
      "id": "s002",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s003",
      "text": "What is Carol not going to buy?",
      "translation": {
        "text": "卡罗尔不准备买什么？"
      }
    },
    {
      "id": "s004",
      "text": "What are you doing, Carol?",
      "translation": {
        "text": "你在做什么，卡罗尔？"
      }
    },
    {
      "id": "s005",
      "text": "I'm making a shopping list, Tom.",
      "translation": {
        "text": "我在列购物单，汤姆。"
      }
    },
    {
      "id": "s006",
      "text": "What do we need?",
      "translation": {
        "text": "我们需要什么？"
      }
    },
    {
      "id": "s007",
      "text": "We need a lot of things this week.",
      "translation": {
        "text": "这星期我们需要很多东西。"
      }
    },
    {
      "id": "s008",
      "text": "I must go to the grocers.",
      "translation": {
        "text": "我必须去杂货店。"
      }
    },
    {
      "id": "s009",
      "text": "We haven't got much tea or coffee, and we haven't got any sugar or jam.",
      "translation": {
        "text": "我们的茶叶和咖啡不多了，糖和果酱也一点儿没有了。"
      }
    },
    {
      "id": "s010",
      "text": "What about vegetables?",
      "translation": {
        "text": "蔬菜呢？"
      }
    },
    {
      "id": "s011",
      "text": "I must go to the green grocers.",
      "translation": {
        "text": "我必须去蔬菜水果店。"
      }
    },
    {
      "id": "s012",
      "text": "We haven't got many tomatoes, but we've got a lot of potatoes.",
      "translation": {
        "text": "我们的西红柿不多了，但土豆还有很多。"
      }
    },
    {
      "id": "s013",
      "text": "I must go to the butchers, too.",
      "translation": {
        "text": "我还必须去肉店。"
      }
    },
    {
      "id": "s014",
      "text": "We need some meat.",
      "translation": {
        "text": "我们需要一些肉。"
      }
    },
    {
      "id": "s015",
      "text": "We haven't got any meat at all.",
      "translation": {
        "text": "我们一点肉也没有了。"
      }
    },
    {
      "id": "s016",
      "text": "Have we got any beer and wine?",
      "translation": {
        "text": "我们还有啤酒和葡萄酒吗？"
      }
    },
    {
      "id": "s017",
      "text": "No, we haven't, and I'm not going to get any.",
      "translation": {
        "text": "没有了，而且我也不准备买。"
      }
    },
    {
      "id": "s018",
      "text": "I hope that you've got some money.",
      "translation": {
        "text": "我希望你还有钱。"
      }
    },
    {
      "id": "s019",
      "text": "I haven't got much.",
      "translation": {
        "text": "我没有多少钱了。"
      }
    },
    {
      "id": "s020",
      "text": "Well, I haven't got much either.",
      "translation": {
        "text": "嗯，我也没有多少钱了。"
      }
    }
  ],
