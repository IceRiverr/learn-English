  "segments": [
    {
      "id": "s001",
      "text": "Lesson 15.",
      "translation": {
        "text": "第15课。"
      }
    },
    {
      "id": "s002",
      "text": "Your Passports, Listen to the tape, then answer this question.",
      "translation": {
        "text": "请出示护照。听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s003",
      "text": "Is there a problem with the customs officer?",
      "translation": {
        "text": "海关官员那里有什么问题吗？"
      }
    },
    {
      "id": "s004",
      "text": "Are you Swedish?",
      "translation": {
        "text": "你们是瑞典人吗？"
      }
    },
    {
      "id": "s005",
      "text": "No, we are not.",
      "translation": {
        "text": "不，我们不是。"
      }
    },
    {
      "id": "s006",
      "text": "We are Danish.",
      "translation": {
        "text": "我们是丹麦人。"
      }
    },
    {
      "id": "s007",
      "text": "Are your friends Danish too?",
      "translation": {
        "text": "你们的朋友也是丹麦人吗？"
      }
    },
    {
      "id": "s008",
      "text": "No, they aren't.",
      "translation": {
        "text": "不，他们不是。"
      }
    },
    {
      "id": "s009",
      "text": "They are Norwegian.",
      "translation": {
        "text": "他们是挪威人。"
      }
    },
    {
      "id": "s010",
      "text": "Your Passports, Please.",
      "translation": {
        "text": "请出示护照。"
      }
    },
    {
      "id": "s011",
      "text": "Here they are.",
      "translation": {
        "text": "给您。"
      }
    },
    {
      "id": "s012",
      "text": "Are these your cases?",
      "translation": {
        "text": "这些是你们的箱子吗？"
      }
    },
    {
      "id": "s013",
      "text": "No, they aren't.",
      "translation": {
        "text": "不，不是。"
      }
    },
    {
      "id": "s014",
      "text": "Our cases are brown.",
      "translation": {
        "text": "我们的箱子是棕色的。"
      }
    },
    {
      "id": "s015",
      "text": "Here they are.",
      "translation": {
        "text": "箱子在这里。"
      }
    },
    {
      "id": "s016",
      "text": "Are you tourists?",
      "translation": {
        "text": "你们是游客吗？"
      }
    },
    {
      "id": "s017",
      "text": "Yes, we are.",
      "translation": {
        "text": "是的，我们是。"
      }
    },
    {
      "id": "s018",
      "text": "Are your friends tourists too?",
      "translation": {
        "text": "你们的朋友也是游客吗？"
      }
    },
    {
      "id": "s019",
      "text": "Yes, they are.",
      "translation": {
        "text": "是的，他们是。"
      }
    },
    {
      "id": "s020",
      "text": "That's fine.",
      "translation": {
        "text": "那就没问题了。"
      }
    },
    {
      "id": "s021",
      "text": "Thank you very much.",
      "translation": {
        "text": "非常感谢。"
      }
    }
  ],
