  "segments": [
    {
      "id": "s001",
      "text": "Lesson 83–Going on Holiday.",
      "translation": {
        "text": "第83课——度假。"
      }
    },
    {
      "id": "s002",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s003",
      "text": "Where did Sam go for his holiday this year?",
      "translation": {
        "text": "萨姆今年去哪里度假了？"
      }
    },
    {
      "id": "s004",
      "text": "Hello, Sam.",
      "translation": {
        "text": "你好，萨姆。"
      }
    },
    {
      "id": "s005",
      "text": "Come in.",
      "translation": {
        "text": "进来吧。"
      }
    },
    {
      "id": "s006",
      "text": "Hi, Sam.",
      "translation": {
        "text": "你好，萨姆。"
      }
    },
    {
      "id": "s007",
      "text": "We're having lunch.",
      "translation": {
        "text": "我们正在吃午饭。"
      }
    },
    {
      "id": "s008",
      "text": "Do you want to have lunch with us?",
      "translation": {
        "text": "你想和我们一起吃午饭吗？"
      }
    },
    {
      "id": "s009",
      "text": "No, thank you, Tom.",
      "translation": {
        "text": "不了，谢谢，汤姆。"
      }
    },
    {
      "id": "s010",
      "text": "I've already had lunch.",
      "translation": {
        "text": "我已经吃过午饭了。"
      }
    },
    {
      "id": "s011",
      "text": "I had lunch at half past twelve.",
      "translation": {
        "text": "我十二点半吃的午饭。"
      }
    },
    {
      "id": "s012",
      "text": "Have a cup of coffee, then?",
      "translation": {
        "text": "那喝杯咖啡吧？"
      }
    },
    {
      "id": "s013",
      "text": "I've just had a cup, thank you.",
      "translation": {
        "text": "我刚喝过一杯，谢谢。"
      }
    },
    {
      "id": "s014",
      "text": "I had one after my lunch.",
      "translation": {
        "text": "午饭后喝的。"
      }
    },
    {
      "id": "s015",
      "text": "Let's go into the living room, Carol.",
      "translation": {
        "text": "我们去客厅吧，卡罗尔。"
      }
    },
    {
      "id": "s016",
      "text": "We can have our coffee there.",
      "translation": {
        "text": "我们可以在那里喝咖啡。"
      }
    },
    {
      "id": "s017",
      "text": "Excuse the mess. This room's very untidy.",
      "translation": {
        "text": "屋里很乱，请别介意。这房间太不整洁了。"
      }
    },
    {
      "id": "s018",
      "text": "We're packing our suitcases.",
      "translation": {
        "text": "我们正在收拾行李箱。"
      }
    },
    {
      "id": "s019",
      "text": "We're going to leave tomorrow.",
      "translation": {
        "text": "我们明天就要出发。"
      }
    },
    {
      "id": "s020",
      "text": "Tom and I are going to have a holiday.",
      "translation": {
        "text": "汤姆和我要去度假。"
      }
    },
    {
      "id": "s021",
      "text": "Aren't you lucky?",
      "translation": {
        "text": "你们真幸运，不是吗？"
      }
    },
    {
      "id": "s022",
      "text": "When are you going to have a holiday, Sam?",
      "translation": {
        "text": "萨姆，你准备什么时候去度假？"
      }
    },
    {
      "id": "s023",
      "text": "I don't know.",
      "translation": {
        "text": "我不知道。"
      }
    },
    {
      "id": "s024",
      "text": "I've already had my holiday this year.",
      "translation": {
        "text": "我今年已经度过假了。"
      }
    },
    {
      "id": "s025",
      "text": "Where did you go?",
      "translation": {
        "text": "你去了哪里？"
      }
    },
    {
      "id": "s026",
      "text": "I stayed at home.",
      "translation": {
        "text": "我待在家里。"
      }
    }
  ],
