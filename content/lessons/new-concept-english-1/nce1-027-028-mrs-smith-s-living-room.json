  "segments": [
    {
      "id": "s001",
      "text": "Lesson 27.",
      "translation": {
        "text": "第27课。"
      }
    },
    {
      "id": "s002",
      "text": "Mrs.",
      "translation": {
        "text": "史密斯太太的"
      }
    },
    {
      "id": "s003",
      "text": "Smith's Living Room.",
      "translation": {
        "text": "客厅。"
      }
    },
    {
      "id": "s004",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s005",
      "text": "Where are the books?",
      "translation": {
        "text": "书在哪里？"
      }
    },
    {
      "id": "s006",
      "text": "Mrs.",
      "translation": {
        "text": "史密斯太太的"
      }
    },
    {
      "id": "s007",
      "text": "Smith's living room is large.",
      "translation": {
        "text": "客厅很大。"
      }
    },
    {
      "id": "s008",
      "text": "There is a television in the room.",
      "translation": {
        "text": "房间里有一台电视机。"
      }
    },
    {
      "id": "s009",
      "text": "The television is near the window.",
      "translation": {
        "text": "电视机靠近窗户。"
      }
    },
    {
      "id": "s010",
      "text": "There are some magazines on the television.",
      "translation": {
        "text": "电视机上放着几本杂志。"
      }
    },
    {
      "id": "s011",
      "text": "There is a table in the room.",
      "translation": {
        "text": "房间里有一张桌子。"
      }
    },
    {
      "id": "s012",
      "text": "There are some newspapers on the table.",
      "translation": {
        "text": "桌子上放着几份报纸。"
      }
    },
    {
      "id": "s013",
      "text": "There are some armchairs in the room.",
      "translation": {
        "text": "房间里有几把扶手椅。"
      }
    },
    {
      "id": "s014",
      "text": "The armchairs are near the table.",
      "translation": {
        "text": "扶手椅在桌子附近。"
      }
    },
    {
      "id": "s015",
      "text": "There is a stereo in the room.",
      "translation": {
        "text": "房间里有一套音响。"
      }
    },
    {
      "id": "s016",
      "text": "The stereo is near the door.",
      "translation": {
        "text": "音响靠近门。"
      }
    },
    {
      "id": "s017",
      "text": "There are some books on the stereo.",
      "translation": {
        "text": "音响上放着几本书。"
      }
    },
    {
      "id": "s018",
      "text": "There are some pictures in the room.",
      "translation": {
        "text": "房间里有几幅画。"
      }
    },
    {
      "id": "s019",
      "text": "The pictures are on the wall.",
      "translation": {
        "text": "这些画挂在墙上。"
      }
    }
  ],
