      "id": "s001",
      "text": "Lesson 1.",
      "translation": {
        "text": "第1课。"
      }
    },
    {
      "id": "s002",
      "text": "Excuse Me.",
      "translation": {
        "text": "对不起。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "Whose handbag is it?",
      "translation": {
        "text": "这是谁的手提包？"
      }
    },
    {
      "id": "s005",
      "text": "Excuse me.",
      "translation": {
        "text": "对不起。"
      }
    },
    {
      "id": "s006",
      "text": "Yes.",
      "translation": {
        "text": "什么事？"
      }
    },
    {
      "id": "s007",
      "text": "Is this your handbag?",
      "translation": {
        "text": "这是您的手提包吗？"
      }
    },
    {
      "id": "s008",
      "text": "Pardon.",
      "translation": {
        "text": "请再说一遍。"
      }
    },
    {
      "id": "s009",
      "text": "Is this your handbag?",
      "translation": {
        "text": "这是您的手提包吗？"
      }
    },
    {
      "id": "s010",
      "text": "Yes, it is.",
      "translation": {
        "text": "是的，是我的。"
      }
    },
    {
      "id": "s011",
      "text": "Thank you very much.",
      "translation": {
        "text": "非常感谢。"
      }
    }
  ],
