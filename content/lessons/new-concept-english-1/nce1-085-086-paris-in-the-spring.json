  "segments": [
    {
      "id": "s001",
      "text": "Lesson 85—Paris in the Spring.",
      "translation": {
        "text": "第85课——巴黎之春。"
      }
    },
    {
      "id": "s002",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s003",
      "text": "At what time of year did Ken visit Paris?",
      "translation": {
        "text": "肯是在一年中的什么时候游览巴黎的？"
      }
    },
    {
      "id": "s004",
      "text": "Hello, Ken.",
      "translation": {
        "text": "你好，肯。"
      }
    },
    {
      "id": "s005",
      "text": "Hi, George.",
      "translation": {
        "text": "你好，乔治。"
      }
    },
    {
      "id": "s006",
      "text": "Have you just been to the cinema?",
      "translation": {
        "text": "你刚去过电影院吗？"
      }
    },
    {
      "id": "s007",
      "text": "Yes, I have.",
      "translation": {
        "text": "是的，刚去过。"
      }
    },
    {
      "id": "s008",
      "text": "What's on?",
      "translation": {
        "text": "放映什么片子？"
      }
    },
    {
      "id": "s009",
      "text": "Paris in the Spring.",
      "translation": {
        "text": "《巴黎之春》。"
      }
    },
    {
      "id": "s010",
      "text": "Oh, I've already seen it.",
      "translation": {
        "text": "哦，我已经看过了。"
      }
    },
    {
      "id": "s011",
      "text": "I saw it on television last year.",
      "translation": {
        "text": "我去年在电视上看的。"
      }
    },
    {
      "id": "s012",
      "text": "It's an old film, but it's very good.",
      "translation": {
        "text": "这是一部老电影，但很好看。"
      }
    },
    {
      "id": "s013",
      "text": "Paris is a beautiful city.",
      "translation": {
        "text": "巴黎是一座美丽的城市。"
      }
    },
    {
      "id": "s014",
      "text": "I've never been there.",
      "translation": {
        "text": "我从未去过那里。"
      }
    },
    {
      "id": "s015",
      "text": "Have you ever been there? Yes, I have.",
      "translation": {
        "text": "你去过那里吗？是的，去过。"
      }
    },
    {
      "id": "s016",
      "text": "I was there in April.",
      "translation": {
        "text": "我是四月份去的。"
      }
    },
    {
      "id": "s017",
      "text": "Paris in the Spring, eh?",
      "translation": {
        "text": "巴黎之春，是吗？"
      }
    },
    {
      "id": "s018",
      "text": "It was spring, but the weather was awful.",
      "translation": {
        "text": "当时是春天，但天气糟透了。"
      }
    },
    {
      "id": "s019",
      "text": "It rained all the time.",
      "translation": {
        "text": "一直在下雨。"
      }
    },
    {
      "id": "s020",
      "text": "Just like London.",
      "translation": {
        "text": "就像伦敦一样。"
      }
    }
  ],
