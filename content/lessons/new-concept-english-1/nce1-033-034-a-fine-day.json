    {
      "id": "s001",
      "text": "Lesson 33.",
      "translation": {
        "text": "第33课。"
      }
    },
    {
      "id": "s002",
      "text": "A Fine Day.",
      "translation": {
        "text": "天气晴朗。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "Where is the Jones family?",
      "translation": {
        "text": "琼斯一家在哪里？"
      }
    },
    {
      "id": "s005",
      "text": "It is a fine day today.",
      "translation": {
        "text": "今天天气很好。"
      }
    },
    {
      "id": "s006",
      "text": "There are some clouds in the sky, but the sun is shining.",
      "translation": {
        "text": "天空中有几朵云，但阳光灿烂。"
      }
    },
    {
      "id": "s007",
      "text": "Mr.",
      "translation": {
        "text": "琼斯先生"
      }
    },
    {
      "id": "s008",
      "text": "Jones is with his family.",
      "translation": {
        "text": "琼斯和家人在一起。"
      }
    },
    {
      "id": "s009",
      "text": "They are walking over the bridge.",
      "translation": {
        "text": "他们正走过桥。"
      }
    },
    {
      "id": "s010",
      "text": "There are some boats on the river.",
      "translation": {
        "text": "河上有几条船。"
      }
    },
    {
      "id": "s011",
      "text": "Mr.",
      "translation": {
        "text": "琼斯"
      }
    },
    {
      "id": "s012",
      "text": "Jones and his wife are looking at them.",
      "translation": {
        "text": "先生和他的妻子正在看着它们。"
      }
    },
    {
      "id": "s013",
      "text": "Sally is looking at a big ship.",
      "translation": {
        "text": "萨莉正在看一艘大轮船。"
      }
    },
    {
      "id": "s014",
      "text": "The ship is going under the bridge.",
      "translation": {
        "text": "那艘轮船正从桥下驶过。"
      }
    },
    {
      "id": "s015",
      "text": "Tim is looking at an airplane.",
      "translation": {
        "text": "蒂姆正在看一架飞机。"
      }
    },
    {
      "id": "s016",
      "text": "The airplane is flying over the river.",
      "translation": {
        "text": "那架飞机正从河上空飞过。"
      }
    }
  ],
