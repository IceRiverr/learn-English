  "segments": [
    {
      "id": "s001",
      "text": "Lesson 133—Sensational News.",
      "translation": {
        "text": "第133课——爆炸性新闻。"
      }
    },
    {
      "id": "s002",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s003",
      "text": "What reasons did Karen Marsh give for wanting to retire?",
      "translation": {
        "text": "卡伦·马什说她想退休的理由是什么？"
      }
    },
    {
      "id": "s004",
      "text": "Have you just made a new film, Miss Marsh?",
      "translation": {
        "text": "马什小姐，您刚拍完一部新电影吗？"
      }
    },
    {
      "id": "s005",
      "text": "Yes, I have.",
      "translation": {
        "text": "是的。"
      }
    },
    {
      "id": "s006",
      "text": "Are you going to make another?",
      "translation": {
        "text": "您还准备再拍一部吗？"
      }
    },
    {
      "id": "s007",
      "text": "No, I'm not.",
      "translation": {
        "text": "不，不准备了。"
      }
    },
    {
      "id": "s008",
      "text": "I'm going to retire.",
      "translation": {
        "text": "我准备退休。"
      }
    },
    {
      "id": "s009",
      "text": "I feel very tired.",
      "translation": {
        "text": "我觉得很累。"
      }
    },
    {
      "id": "s010",
      "text": "I don't want to make another film for a long time.",
      "translation": {
        "text": "我很长一段时间都不想再拍电影了。"
      }
    },
    {
      "id": "s011",
      "text": "Let's buy a newspaper, Liz.",
      "translation": {
        "text": "莉兹，我们买份报纸吧。"
      }
    },
    {
      "id": "s012",
      "text": "Listen to this.",
      "translation": {
        "text": "听听这篇报道。"
      }
    },
    {
      "id": "s013",
      "text": "Karen Marsh—Sensational News.",
      "translation": {
        "text": "卡伦·马什——爆炸性新闻。"
      }
    },
    {
      "id": "s014",
      "text": "By Our Reporter, Alan Jones.",
      "translation": {
        "text": "本报记者艾伦·琼斯报道。"
      }
    },
    {
      "id": "s015",
      "text": "Karen Marsh arrived at London Airport today.",
      "translation": {
        "text": "卡伦·马什今天抵达伦敦机场。"
      }
    },
    {
      "id": "s016",
      "text": "She was wearing a blue dress and a mink coat.",
      "translation": {
        "text": "她身穿蓝色连衣裙和一件貂皮大衣。"
      }
    },
    {
      "id": "s017",
      "text": "She told me she had just made a new film.",
      "translation": {
        "text": "她告诉我，她刚拍完一部新电影。"
      }
    },
    {
      "id": "s018",
      "text": "She said she was not going to make another.",
      "translation": {
        "text": "她说她不准备再拍一部。"
      }
    },
    {
      "id": "s019",
      "text": "She said she was going to retire.",
      "translation": {
        "text": "她说她准备退休。"
      }
    },
    {
      "id": "s020",
      "text": "She told reporters she felt very tired and didn't want to make another film for a long time.",
      "translation": {
        "text": "她告诉记者，她感到很累，很长一段时间内都不想再拍电影。"
      }
    },
    {
      "id": "s021",
      "text": "I wonder why.",
      "translation": {
        "text": "我想知道为什么。"
      }
    }
  ],
