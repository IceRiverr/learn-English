  "segments": [
    {
      "id": "s001",
      "text": "Lesson 63.",
      "translation": {
        "text": "第63课。"
      }
    },
    {
      "id": "s002",
      "text": "Thank You, Doctor.",
      "translation": {
        "text": "谢谢您，医生。"
      }
    },
    {
      "id": "s003",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s004",
      "text": "Who else is in bed today?",
      "translation": {
        "text": "今天还有谁卧床了？"
      }
    },
    {
      "id": "s005",
      "text": "Why?",
      "translation": {
        "text": "为什么？"
      }
    },
    {
      "id": "s006",
      "text": "How's Jimmy today?",
      "translation": {
        "text": "吉米今天怎么样？"
      }
    },
    {
      "id": "s007",
      "text": "He's better.",
      "translation": {
        "text": "他好些了。"
      }
    },
    {
      "id": "s008",
      "text": "Thank you, Doctor. Can I see him, please, Mrs. Williams?",
      "translation": {
        "text": "谢谢您，医生。我可以看看他吗，威廉斯太太？"
      }
    },
    {
      "id": "s009",
      "text": "Certainly, Doctor.",
      "translation": {
        "text": "当然可以，医生。"
      }
    },
    {
      "id": "s010",
      "text": "Come upstairs.",
      "translation": {
        "text": "请上楼。"
      }
    },
    {
      "id": "s011",
      "text": "You look very well, Jimmy.",
      "translation": {
        "text": "你看起来很好，吉米。"
      }
    },
    {
      "id": "s012",
      "text": "You are better now, but you mustn't get up yet.",
      "translation": {
        "text": "你现在好多了，但还不能起床。"
      }
    },
    {
      "id": "s013",
      "text": "You must stay in bed for another two days.",
      "translation": {
        "text": "你必须再卧床两天。"
      }
    },
    {
      "id": "s014",
      "text": "The boy mustn't go to school yet, Mrs.",
      "translation": {
        "text": "这个孩子还不能去上学，威廉斯"
      }
    },
    {
      "id": "s015",
      "text": "Williams, and he mustn't eat rich food.",
      "translation": {
        "text": "太太，而且他不能吃油腻的食物。"
      }
    },
    {
      "id": "s016",
      "text": "Does he have a temperature, Doctor?",
      "translation": {
        "text": "他发烧吗，医生？"
      }
    },
    {
      "id": "s017",
      "text": "No, he doesn't.",
      "translation": {
        "text": "不发烧。"
      }
    },
    {
      "id": "s018",
      "text": "Must he stay in bed?",
      "translation": {
        "text": "他必须卧床吗？"
      }
    },
    {
      "id": "s019",
      "text": "Yes, he must remain in bed for another two days.",
      "translation": {
        "text": "是的，他必须再卧床两天。"
      }
    },
    {
      "id": "s020",
      "text": "He can get up for about two hours each day.",
      "translation": {
        "text": "他每天可以起床两小时左右。"
      }
    },
    {
      "id": "s021",
      "text": "But you must keep the room warm.",
      "translation": {
        "text": "但您必须保持房间温暖。"
      }
    },
    {
      "id": "s022",
      "text": "Where's Mr. Williams",
      "translation": {
        "text": "威廉斯先生在哪里"
      }
    },
    {
      "id": "s023",
      "text": "this evening?",
      "translation": {
        "text": "今晚在哪里？"
      }
    },
    {
      "id": "s024",
      "text": "He's in bed, Doctor.",
      "translation": {
        "text": "他躺在床上，医生。"
      }
    },
    {
      "id": "s025",
      "text": "Can you see him, please?",
      "translation": {
        "text": "您能看看他吗？"
      }
    },
    {
      "id": "s026",
      "text": "He has a bad cold, too.",
      "translation": {
        "text": "他也得了重感冒。"
      }
    }
  ],
