  "segments": [
    {
      "id": "s001",
      "text": "Lesson 99.",
      "translation": {
        "text": "第99课。"
      }
    },
    {
      "id": "s002",
      "text": "Listen to the tape, then answer this question.",
      "translation": {
        "text": "听录音，然后回答这个问题。"
      }
    },
    {
      "id": "s003",
      "text": "Must Andy go to see the doctor?",
      "translation": {
        "text": "安迪必须去看医生吗？"
      }
    },
    {
      "id": "s004",
      "text": "What's the matter, Andy?",
      "translation": {
        "text": "怎么了，安迪？"
      }
    },
    {
      "id": "s005",
      "text": "I slipped and fell downstairs.",
      "translation": {
        "text": "我滑了一跤，从楼梯上摔了下来。"
      }
    },
    {
      "id": "s006",
      "text": "Have you hurt yourself?",
      "translation": {
        "text": "你伤着自己了吗？"
      }
    },
    {
      "id": "s007",
      "text": "Yes, I have.",
      "translation": {
        "text": "是的，伤着了。"
      }
    },
    {
      "id": "s008",
      "text": "I think that I've hurt my back.",
      "translation": {
        "text": "我想我的背受伤了。"
      }
    },
    {
      "id": "s009",
      "text": "Try and stand up.",
      "translation": {
        "text": "试着站起来。"
      }
    },
    {
      "id": "s010",
      "text": "Can you stand up?",
      "translation": {
        "text": "你能站起来吗？"
      }
    },
    {
      "id": "s011",
      "text": "Here, let me help you.",
      "translation": {
        "text": "来，让我帮你。"
      }
    },
    {
      "id": "s012",
      "text": "I'm sorry, Lucy.",
      "translation": {
        "text": "对不起，露西。"
      }
    },
    {
      "id": "s013",
      "text": "I'm afraid that I can't get up.",
      "translation": {
        "text": "恐怕我站不起来。"
      }
    },
    {
      "id": "s014",
      "text": "I think that the doctor had better see you.",
      "translation": {
        "text": "我想最好让医生给你看看。"
      }
    },
    {
      "id": "s015",
      "text": "I'll phone Dr. Carter.",
      "translation": {
        "text": "我给卡特医生打电话。"
      }
    },
    {
      "id": "s016",
      "text": "The doctor says that he will come at once.",
      "translation": {
        "text": "医生说他马上就来。"
      }
    },
    {
      "id": "s017",
      "text": "I'm sure that you need an x-ray, Andy.",
      "translation": {
        "text": "安迪，我敢肯定你需要拍X光片。"
      }
    }
  ],
