  "segments": [
    {
      "id": "s001",
      "text": "Lesson 9.",
      "translation": {
        "text": "第9课。"
      }
    },
    {
      "id": "s002",
      "text": "A Cold Welcome.",
      "translation": {
        "text": "冷遇。"
      }
    },
    {
      "id": "s003",
      "text": "First listen and then answer the question.",
      "translation": {
        "text": "先听录音，然后回答问题。"
      }
    },
    {
      "id": "s004",
      "text": "What does a cold welcome refer to?",
      "translation": {
        "text": "“冷遇”指的是什么？"
      }
    },
    {
      "id": "s005",
      "text": "On Wednesday evening we went to the town hall.",
      "translation": {
        "text": "星期三晚上，我们去了市政厅。"
      }
    },
    {
      "id": "s006",
      "text": "It was the last day of the year and a large crowd of people had gathered under the town hall clock.",
      "translation": {
        "text": "那是一年的最后一天，一大群人聚集在市政厅的大钟下面。"
      }
    },
    {
      "id": "s007",
      "text": "It would strike twelve in twenty minutes' time.",
      "translation": {
        "text": "再过20分钟，大钟将敲响12点。"
      }
    },
    {
      "id": "s008",
      "text": "Fifteen minutes passed and then, at five to twelve, the clock stopped.",
      "translation": {
        "text": "15分钟过去了，就在11点55分时，大钟停了。"
      }
    },
    {
      "id": "s009",
      "text": "The big minute hand did not move.",
      "translation": {
        "text": "巨大的分针一动不动。"
      }
    },
    {
      "id": "s010",
      "text": "We waited and waited, but nothing happened.",
      "translation": {
        "text": "我们等了又等，却什么也没有发生。"
      }
    },
    {
      "id": "s011",
      "text": "Suddenly someone shouted, It's two minutes past twelve.",
      "translation": {
        "text": "突然有人喊道：“已经过12点两分钟了！”"
      }
    },
    {
      "id": "s012",
      "text": "The clock has stopped.",
      "translation": {
        "text": "大钟停了。"
      }
    },
    {
      "id": "s013",
      "text": "I looked at my watch.",
      "translation": {
        "text": "我看了看手表。"
      }
    },
    {
      "id": "s014",
      "text": "It was true.",
      "translation": {
        "text": "果真如此。"
      }
    },
    {
      "id": "s015",
      "text": "The big clock refused to welcome the new year.",
      "translation": {
        "text": "这座大钟拒绝迎接新年。"
      }
    },
    {
      "id": "s016",
      "text": "At that moment, everybody began to laugh and sing.",
      "translation": {
        "text": "就在那一刻，大家开始又笑又唱。"
      }
    }
  ],
