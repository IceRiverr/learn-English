  "segments": [
    {
      "id": "s001",
      "text": "Lesson 2.",
      "translation": {
        "text": "第2课。"
      }
    },
    {
      "id": "s002",
      "text": "Breakfast or Lunch.",
      "translation": {
        "text": "早餐还是午餐？"
      }
    },
    {
      "id": "s003",
      "text": "First listen, and then answer the question.",
      "translation": {
        "text": "先听录音，然后回答问题。"
      }
    },
    {
      "id": "s004",
      "text": "Why was the writer's aunt surprised?",
      "translation": {
        "text": "作者的姑妈为什么感到惊讶？"
      }
    },
    {
      "id": "s005",
      "text": "It was Sunday.",
      "translation": {
        "text": "那天是星期日。"
      }
    },
    {
      "id": "s006",
      "text": "I never get up early on Sundays.",
      "translation": {
        "text": "星期日我从不早起。"
      }
    },
    {
      "id": "s007",
      "text": "I sometimes stay in bed until lunchtime.",
      "translation": {
        "text": "有时我要一直躺到吃午饭的时候。"
      }
    },
    {
      "id": "s008",
      "text": "Last Sunday I got up very late.",
      "translation": {
        "text": "上个星期日我起得很晚。"
      }
    },
    {
      "id": "s009",
      "text": "I looked out of the window.",
      "translation": {
        "text": "我望望窗外。"
      }
    },
    {
      "id": "s010",
      "text": "It was dark outside.",
      "translation": {
        "text": "外面一片昏暗。"
      }
    },
    {
      "id": "s011",
      "text": "What a day!",
      "translation": {
        "text": "鬼天气！"
      }
    },
    {
      "id": "s012",
      "text": "I thought.",
      "translation": {
        "text": "我想。"
      }
    },
    {
      "id": "s013",
      "text": "It's raining again.",
      "translation": {
        "text": "又下雨了。"
      }
    },
    {
      "id": "s014",
      "text": "Just then the telephone rang.",
      "translation": {
        "text": "正在这时，电话铃响了。"
      }
    },
    {
      "id": "s015",
      "text": "It was my Aunt Lucy.",
      "translation": {
        "text": "是我姑妈露西打来的。"
      }
    },
    {
      "id": "s016",
      "text": "I've just arrived by train, she said.",
      "translation": {
        "text": "“我刚坐火车到达，”她说。"
      }
    },
    {
      "id": "s017",
      "text": "I'm coming to see you.",
      "translation": {
        "text": "“我这就来看你。”"
      }
    },
    {
      "id": "s018",
      "text": "But I'm still having breakfast, I said.",
      "translation": {
        "text": "“可我还在吃早饭，”我说。"
      }
    },
    {
      "id": "s019",
      "text": "What are you doing?",
      "translation": {
        "text": "“你在干什么？”"
      }
    },
    {
      "id": "s020",
      "text": "She asked.",
      "translation": {
        "text": "她问道。"
      }
    },
    {
      "id": "s021",
      "text": "I'm having breakfast, I repeated.",
      "translation": {
        "text": "“我在吃早饭，”我又说了一遍。"
      }
    },
    {
      "id": "s022",
      "text": "Dear me, she said.",
      "translation": {
        "text": "“天哪，”她说。"
      }
    },
    {
      "id": "s023",
      "text": "Do you always get up so late?",
      "translation": {
        "text": "“你总是起得这么晚吗？”"
      }
    },
    {
      "id": "s024",
      "text": "It's one o'clock.",
      "translation": {
        "text": "“现在已经一点钟了！”"
      }
    }
  ],
