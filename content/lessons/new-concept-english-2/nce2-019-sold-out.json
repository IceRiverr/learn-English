  "segments": [
    {
      "id": "s001",
      "text": "Lesson 19.",
      "translation": {
        "text": "第19课。"
      }
    },
    {
      "id": "s002",
      "text": "Sold Out.",
      "translation": {
        "text": "票已售完。"
      }
    },
    {
      "id": "s003",
      "text": "First listen and then answer the question.",
      "translation": {
        "text": "先听录音，然后回答问题。"
      }
    },
    {
      "id": "s004",
      "text": "When will the writer see the play?",
      "translation": {
        "text": "作者什么时候能看到这出戏？"
      }
    },
    {
      "id": "s005",
      "text": "The play may begin at any moment, I said.",
      "translation": {
        "text": "“戏随时都会开演，”我说。"
      }
    },
    {
      "id": "s006",
      "text": "It may have begun already, Susan answered.",
      "translation": {
        "text": "“也许已经开演了，”苏珊回答。"
      }
    },
    {
      "id": "s007",
      "text": "I hurried to the ticket office.",
      "translation": {
        "text": "我匆忙赶到售票处。"
      }
    },
    {
      "id": "s008",
      "text": "May I have two tickets, please?",
      "translation": {
        "text": "“请给我两张票好吗？”"
      }
    },
    {
      "id": "s009",
      "text": "I asked.",
      "translation": {
        "text": "我问。"
      }
    },
    {
      "id": "s010",
      "text": "I'm sorry, we've sold out, the girl said.",
      "translation": {
        "text": "“对不起，票已售完，”那姑娘说。"
      }
    },
    {
      "id": "s011",
      "text": "What a pity, Susan exclaimed.",
      "translation": {
        "text": "“真可惜！”苏珊惊呼道。"
      }
    },
    {
      "id": "s012",
      "text": "Just then, a man hurried to the ticket office.",
      "translation": {
        "text": "正在这时，一个男人匆匆赶到售票处。"
      }
    },
    {
      "id": "s013",
      "text": "Can I return these two tickets?",
      "translation": {
        "text": "“我可以退掉这两张票吗？”"
      }
    },
    {
      "id": "s014",
      "text": "he asked.",
      "translation": {
        "text": "他问。"
      }
    },
    {
      "id": "s015",
      "text": "Certainly, the girl said.",
      "translation": {
        "text": "“当然可以，”那姑娘说。"
      }
    },
    {
      "id": "s016",
      "text": "I went back to the ticket office at once.",
      "translation": {
        "text": "我马上又回到售票处。"
      }
    },
    {
      "id": "s017",
      "text": "Could I have those two tickets, please?",
      "translation": {
        "text": "“我可以买那两张票吗？”"
      }
    },
    {
      "id": "s018",
      "text": "I asked.",
      "translation": {
        "text": "我问。"
      }
    },
    {
      "id": "s019",
      "text": "Certainly, the girl said.",
      "translation": {
        "text": "“当然可以，”那姑娘说。"
      }
    },
    {
      "id": "s020",
      "text": "But they're for next Wednesday's performance. Do you still want them?",
      "translation": {
        "text": "“不过那是下星期三演出的票。您还要吗？”"
      }
    },
    {
      "id": "s021",
      "text": "I might as well have them, I said sadly.",
      "translation": {
        "text": "“我还是买下吧，”我难过地说。"
      }
    }
  ],
