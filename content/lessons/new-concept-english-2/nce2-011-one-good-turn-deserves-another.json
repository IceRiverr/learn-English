  "segments": [
    {
      "id": "s001",
      "text": "First listen, and then answer the question.",
      "translation": {
        "text": "先听录音，然后回答问题。"
      }
    },
    {
      "id": "s002",
      "text": "Who paid for Tony's dinner?",
      "translation": {
        "text": "谁付了托尼的饭钱？"
      }
    },
    {
      "id": "s003",
      "text": "I was having dinner at a restaurant when Tony Steele came in.",
      "translation": {
        "text": "我正在一家餐馆吃饭，托尼·斯蒂尔走了进来。"
      }
    },
    {
      "id": "s004",
      "text": "Tony worked in a lawyer's office years ago, but he is now working at a bank.",
      "translation": {
        "text": "托尼几年前在一家律师事务所工作，现在在一家银行任职。"
      }
    },
    {
      "id": "s005",
      "text": "He gets a good salary, but he always borrows money from his friends and never pays it back.",
      "translation": {
        "text": "他的薪水很高，但他总是向朋友借钱，而且从来不还。"
      }
    },
    {
      "id": "s006",
      "text": "Tony saw me and came and sat at the same table.",
      "translation": {
        "text": "托尼看见我，便走过来坐到同一张桌旁。"
      }
    },
    {
      "id": "s007",
      "text": "He has never borrowed money from me.",
      "translation": {
        "text": "他从未向我借过钱。"
      }
    },
    {
      "id": "s008",
      "text": "While he was eating, I asked him to lend me twenty pounds.",
      "translation": {
        "text": "他吃饭时，我请他借给我20英镑。"
      }
    },
    {
      "id": "s009",
      "text": "To my surprise, he gave me the money immediately.",
      "translation": {
        "text": "令我惊讶的是，他立刻把钱给了我。"
      }
    },
    {
      "id": "s010",
      "text": "I have never borrowed any money from you, Tony said.",
      "translation": {
        "text": "“我从没向你借过钱，”托尼说。"
      }
    },
    {
      "id": "s011",
      "text": "So now you can pay for my dinner.",
      "translation": {
        "text": "“所以现在你可以替我付饭钱了。”"
      }
    }
  ],
