  "segments": [
    {
      "id": "s001",
      "text": "Lesson 3.",
      "translation": {
        "text": "第3课。"
      }
    },
    {
      "id": "s002",
      "text": "Please Send Me a Card.",
      "translation": {
        "text": "请给我寄一张明信片。"
      }
    },
    {
      "id": "s003",
      "text": "First listen, and then answer the question.",
      "translation": {
        "text": "先听录音，然后回答问题。"
      }
    },
    {
      "id": "s004",
      "text": "How many cards did the writer send?",
      "translation": {
        "text": "作者寄出了多少张明信片？"
      }
    },
    {
      "id": "s005",
      "text": "Postcards always spoil my holidays.",
      "translation": {
        "text": "明信片总是搅得我度假不得安宁。"
      }
    },
    {
      "id": "s006",
      "text": "Last summer I went to Italy.",
      "translation": {
        "text": "去年夏天我去了意大利。"
      }
    },
    {
      "id": "s007",
      "text": "I visited museums and sat in public gardens.",
      "translation": {
        "text": "我参观了博物馆，还常坐在公共花园里。"
      }
    },
    {
      "id": "s008",
      "text": "A friendly waiter taught me a few words of Italian.",
      "translation": {
        "text": "一位友好的服务员教了我几句意大利语。"
      }
    },
    {
      "id": "s009",
      "text": "Then he lent me a book.",
      "translation": {
        "text": "后来他借给我一本书。"
      }
    },
    {
      "id": "s010",
      "text": "I read a few lines, but I did not understand a word.",
      "translation": {
        "text": "我读了几行，却一个字也不懂。"
      }
    },
    {
      "id": "s011",
      "text": "Every day I thought about postcards.",
      "translation": {
        "text": "我每天都想着明信片的事。"
      }
    },
    {
      "id": "s012",
      "text": "My holidays passed quickly, but I did not send cards to my friends.",
      "translation": {
        "text": "假期过得很快，可我没有给朋友们寄明信片。"
      }
    },
    {
      "id": "s013",
      "text": "On the last day I made a big decision.",
      "translation": {
        "text": "到了最后一天，我作出了一项重大决定。"
      }
    },
    {
      "id": "s014",
      "text": "I got up early and bought 37 cards.",
      "translation": {
        "text": "我早早起床，买了37张明信片。"
      }
    },
    {
      "id": "s015",
      "text": "I spent the whole day in my room, but I did not write a single card.",
      "translation": {
        "text": "我在房间里待了一整天，却连一张明信片也没有写。"
      }
    }
  ],
