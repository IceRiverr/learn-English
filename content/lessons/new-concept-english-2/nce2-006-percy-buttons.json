  "segments": [
    {
      "id": "s001",
      "text": "Who is Percy Buttons?",
      "translation": {
        "text": "珀西·巴顿斯是谁？"
      }
    },
    {
      "id": "s002",
      "text": "I have just moved to a house in Bridge Street.",
      "translation": {
        "text": "我刚搬进了大桥街的一所房子。"
      }
    },
    {
      "id": "s003",
      "text": "Yesterday a beggar knocked at my door.",
      "translation": {
        "text": "昨天一个乞丐来敲我的门。"
      }
    },
    {
      "id": "s004",
      "text": "He asked me for a meal and a glass of beer.",
      "translation": {
        "text": "他向我要一顿饭和一杯啤酒。"
      }
    },
    {
      "id": "s005",
      "text": "In return for this, the beggar stood on his head and sang songs.",
      "translation": {
        "text": "作为回报，那乞丐倒立起来，还唱了几支歌。"
      }
    },
    {
      "id": "s006",
      "text": "I gave him a meal.",
      "translation": {
        "text": "我给了他一顿饭。"
      }
    },
    {
      "id": "s007",
      "text": "He ate the food and drank the beer.",
      "translation": {
        "text": "他吃完食物，喝了啤酒。"
      }
    },
    {
      "id": "s008",
      "text": "Then he put a piece of cheese in his pocket and went away.",
      "translation": {
        "text": "然后把一块奶酪装进口袋，走了。"
      }
    },
    {
      "id": "s009",
      "text": "Later a neighbor told me about him.",
      "translation": {
        "text": "后来，一位邻居告诉了我他的情况。"
      }
    },
    {
      "id": "s010",
      "text": "Everybody knows him.",
      "translation": {
        "text": "人人都认识他。"
      }
    },
    {
      "id": "s011",
      "text": "His name is Percy Buttons.",
      "translation": {
        "text": "他叫珀西·巴顿斯。"
      }
    },
    {
      "id": "s012",
      "text": "He calls at every house in the street once a month and always asks for a meal and a glass of beer.",
      "translation": {
        "text": "他每月在这条街上每户人家登门一次，总是要一顿饭和一杯啤酒。"
      }
    }
  ],
