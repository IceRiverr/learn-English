  "segments": [
    {
      "id": "s001",
      "text": "First listen, and then answer the question.",
      "translation": {
        "text": "先听录音，然后回答问题。"
      }
    },
    {
      "id": "s002",
      "text": "What was the good news?",
      "translation": {
        "text": "好消息是什么？"
      }
    },
    {
      "id": "s003",
      "text": "The secretary told me that Mr.",
      "translation": {
        "text": "秘书告诉我，哈姆斯沃斯"
      }
    },
    {
      "id": "s004",
      "text": "Harmsworth would see me.",
      "translation": {
        "text": "先生会见我。"
      }
    },
    {
      "id": "s005",
      "text": "I felt very nervous when I went into his office.",
      "translation": {
        "text": "走进他的办公室时，我感到非常紧张。"
      }
    },
    {
      "id": "s006",
      "text": "He did not look up from his desk when I entered.",
      "translation": {
        "text": "我进去时，他头也没抬，仍然看着办公桌。"
      }
    },
    {
      "id": "s007",
      "text": "After I had sat down, he said that business was very bad.",
      "translation": {
        "text": "我坐下后，他说生意非常不景气。"
      }
    },
    {
      "id": "s008",
      "text": "He told me that the firm could not afford to pay such large salaries.",
      "translation": {
        "text": "他告诉我，公司支付不起这么高的薪水。"
      }
    },
    {
      "id": "s009",
      "text": "Twenty people had already left.",
      "translation": {
        "text": "已经有20个人离开了。"
      }
    },
    {
      "id": "s010",
      "text": "I knew that my turn had come.",
      "translation": {
        "text": "我知道轮到我了。"
      }
    },
    {
      "id": "s011",
      "text": "Mr.",
      "translation": {
        "text": "哈姆斯沃斯"
      }
    },
    {
      "id": "s012",
      "text": "Harmsworth, I said in a weak voice.",
      "translation": {
        "text": "先生，我声音微弱地说。"
      }
    },
    {
      "id": "s013",
      "text": "Don't interrupt, he said.",
      "translation": {
        "text": "“不要打断我，”他说。"
      }
    },
    {
      "id": "s014",
      "text": "Then he smiled and told me I would receive an extra thousand pounds a year.",
      "translation": {
        "text": "然后他笑了，告诉我每年将给我加薪1,000英镑。"
      }
    }
  ],
