  "segments": [
    {
      "id": "s001",
      "text": "Lesson 69.",
      "translation": {
        "text": "第69课。"
      }
    },
    {
      "id": "s002",
      "text": "But not Murder.",
      "translation": {
        "text": "但并非谋杀。"
      }
    },
    {
      "id": "s003",
      "text": "First listen and then answer the question.",
      "translation": {
        "text": "先听录音，然后回答问题。"
      }
    },
    {
      "id": "s004",
      "text": "Do you think that the writer passed his driving test?",
      "translation": {
        "text": "你认为作者通过驾驶考试了吗？"
      }
    },
    {
      "id": "s005",
      "text": "Why?",
      "translation": {
        "text": "为什么？"
      }
    },
    {
      "id": "s006",
      "text": "I was being tested for a driving license for the third time.",
      "translation": {
        "text": "我正在第三次参加驾驶执照考试。"
      }
    },
    {
      "id": "s007",
      "text": "I had been asked to drive in heavy traffic and had done so successfully.",
      "translation": {
        "text": "考官要求我在拥挤的车流中驾驶，我顺利地做到了。"
      }
    },
    {
      "id": "s008",
      "text": "After having been instructed to drive out of town, I began to acquire confidence.",
      "translation": {
        "text": "接到把车开出城的指令后，我开始有了信心。"
      }
    },
    {
      "id": "s009",
      "text": "Sure that I had passed, I was almost beginning to enjoy my test.",
      "translation": {
        "text": "我确信自己已经通过考试，甚至开始享受这次考试了。"
      }
    },
    {
      "id": "s010",
      "text": "The examiner must have been pleased with my performance, for he smiled and said, Just one more thing, Mr.",
      "translation": {
        "text": "考官一定对我的表现很满意，因为他微笑着说：“还有最后一项，艾姆斯先生。”"
      }
    },
    {
      "id": "s011",
      "text": "Ames.",
      "translation": {
        "text": "艾姆斯。"
      }
    },
    {
      "id": "s012",
      "text": "Let us suppose that a child suddenly crosses the road in front of you.",
      "translation": {
        "text": "“假设一个孩子突然从你前面横穿马路。”"
      }
    },
    {
      "id": "s013",
      "text": "As soon as I tap on the window, you must stop within five feet.",
      "translation": {
        "text": "“我一敲车窗，你就必须在五英尺之内把车停下。”"
      }
    },
    {
      "id": "s014",
      "text": "I continued driving and after some time the examiner tapped loudly.",
      "translation": {
        "text": "我继续驾车，过了一会儿，考官重重地敲了敲车窗。"
      }
    },
    {
      "id": "s015",
      "text": "Though the sound could be heard clearly, it took me a long time to react.",
      "translation": {
        "text": "虽然敲击声听得很清楚，我却过了很久才反应过来。"
      }
    },
    {
      "id": "s016",
      "text": "I suddenly pressed the brake pedal hard and we were both thrown forward.",
      "translation": {
        "text": "我猛踩刹车踏板，我们俩都被甩向前方。"
      }
    },
    {
      "id": "s017",
      "text": "The examiner looked at me sadly.",
      "translation": {
        "text": "考官悲伤地看着我。"
      }
    },
    {
      "id": "s018",
      "text": "Mr. Ames,",
      "translation": {
        "text": "艾姆斯先生，"
      }
    },
    {
      "id": "s019",
      "text": "he said, in a mournful voice, you have just killed that child.",
      "translation": {
        "text": "他用悲哀的语调说：“你刚刚撞死了那个孩子。”"
      }
    }
  ],
