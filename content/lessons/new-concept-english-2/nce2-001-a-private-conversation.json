  "segments": [
    {
      "id": "s001",
      "text": "Lesson 1.",
      "translation": {
        "text": "第1课。"
      }
    },
    {
      "id": "s002",
      "text": "A Private Conversation.",
      "translation": {
        "text": "私人谈话。"
      }
    },
    {
      "id": "s003",
      "text": "First listen, and then answer the question.",
      "translation": {
        "text": "先听录音，然后回答问题。"
      }
    },
    {
      "id": "s004",
      "text": "Why did the writer complain to the people behind him?",
      "translation": {
        "text": "作者为什么向坐在他身后的人抱怨？"
      }
    },
    {
      "id": "s005",
      "text": "Last week I went to the theater.",
      "translation": {
        "text": "上星期我去看戏。"
      }
    },
    {
      "id": "s006",
      "text": "I had a very good seat.",
      "translation": {
        "text": "我的座位很好。"
      }
    },
    {
      "id": "s007",
      "text": "The play was very interesting.",
      "translation": {
        "text": "那出戏很有意思。"
      }
    },
    {
      "id": "s008",
      "text": "I did not enjoy it.",
      "translation": {
        "text": "但我却无法欣赏。"
      }
    },
    {
      "id": "s009",
      "text": "A young man and a young woman were sitting behind me.",
      "translation": {
        "text": "一青年男子和一青年女子坐在我的身后。"
      }
    },
    {
      "id": "s010",
      "text": "They were talking loudly.",
      "translation": {
        "text": "他们在大声地说话。"
      }
    },
    {
      "id": "s011",
      "text": "I got very angry.",
      "translation": {
        "text": "我非常生气。"
      }
    },
    {
      "id": "s012",
      "text": "I could not hear the actors.",
      "translation": {
        "text": "我听不见演员在说什么。"
      }
    },
    {
      "id": "s013",
      "text": "I turned round.",
      "translation": {
        "text": "我转过身去。"
      }
    },
    {
      "id": "s014",
      "text": "I looked at the man and the woman angrily.",
      "translation": {
        "text": "我生气地看着那一男一女。"
      }
    },
    {
      "id": "s015",
      "text": "They did not pay any attention.",
      "translation": {
        "text": "他们毫不理会。"
      }
    },
    {
      "id": "s016",
      "text": "In the end, I could not bear it.",
      "translation": {
        "text": "最后，我忍不住了。"
      }
    },
    {
      "id": "s017",
      "text": "I turned round again.",
      "translation": {
        "text": "我又转过身去。"
      }
    },
    {
      "id": "s018",
      "text": "I can't hear a word.",
      "translation": {
        "text": "“我一个字也听不见了！”"
      }
    },
    {
      "id": "s019",
      "text": "I said angrily.",
      "translation": {
        "text": "我生气地说。"
      }
    },
    {
      "id": "s020",
      "text": "It's none of your business.",
      "translation": {
        "text": "“不关你的事。”"
      }
    },
    {
      "id": "s021",
      "text": "The young man said rudely.",
      "translation": {
        "text": "那青年男子粗鲁地说。"
      }
    },
    {
      "id": "s022",
      "text": "This is a private conversation.",
      "translation": {
        "text": "“这是私人谈话！”"
      }
    }
  ],
