  "segments": [
    {
      "id": "s001",
      "text": "Lesson 18.",
      "translation": {
        "text": "第18课。"
      }
    },
    {
      "id": "s002",
      "text": "He often does this.",
      "translation": {
        "text": "他经常干这种事。"
      }
    },
    {
      "id": "s003",
      "text": "First listen and then answer the question.",
      "translation": {
        "text": "先听录音，然后回答问题。"
      }
    },
    {
      "id": "s004",
      "text": "What had happened to the writer's bag?",
      "translation": {
        "text": "作者的包出了什么事？"
      }
    },
    {
      "id": "s005",
      "text": "After I had had lunch at a village pub, I looked for my bag.",
      "translation": {
        "text": "我在一家乡村小酒馆吃过午饭后，开始寻找我的包。"
      }
    },
    {
      "id": "s006",
      "text": "I had left it on a chair beside the door, and now it wasn't there.",
      "translation": {
        "text": "我原来把它放在门边的椅子上，可现在不见了。"
      }
    },
    {
      "id": "s007",
      "text": "As I was looking for it, the landlord came in.",
      "translation": {
        "text": "我正在寻找时，店主走了进来。"
      }
    },
    {
      "id": "s008",
      "text": "Did you have a good meal?",
      "translation": {
        "text": "“饭吃得好吗？”"
      }
    },
    {
      "id": "s009",
      "text": "he asked.",
      "translation": {
        "text": "他问道。"
      }
    },
    {
      "id": "s010",
      "text": "Yes, thank you, I answered.",
      "translation": {
        "text": "“很好，谢谢。”我回答。"
      }
    },
    {
      "id": "s011",
      "text": "But I can't pay the bill.",
      "translation": {
        "text": "“但我没法付账。"
      }
    },
    {
      "id": "s012",
      "text": "I haven't got my bag.",
      "translation": {
        "text": "我的包不见了。”"
      }
    },
    {
      "id": "s013",
      "text": "The landlord smiled and immediately went out.",
      "translation": {
        "text": "店主笑了笑，立刻走了出去。"
      }
    },
    {
      "id": "s014",
      "text": "In a few minutes, he returned with my bag and gave it back to me.",
      "translation": {
        "text": "几分钟后，他拿着我的包回来，把它还给了我。"
      }
    },
    {
      "id": "s015",
      "text": "I'm very sorry, he said.",
      "translation": {
        "text": "“非常抱歉，”他说。"
      }
    },
    {
      "id": "s016",
      "text": "My dog had taken it into the garden.",
      "translation": {
        "text": "“我的狗把它叼到花园里去了。"
      }
    },
    {
      "id": "s017",
      "text": "He often does this.",
      "translation": {
        "text": "它经常干这种事。”"
      }
    }
  ],
